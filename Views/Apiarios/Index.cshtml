@model IEnumerable<ObligatorioIntegrador2026.Models.Apiario>

@{
    ViewData["Title"] = "Gestión de Apiarios";
}

<main class="flex-grow w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-[80px]">
    <!-- Header Section -->
    <section class="flex flex-col mb-[40px] gap-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-start gap-6">
            <div>
                <p class="font-label-caps text-label-caps text-on-surface-variant mb-2">GESTIÓN DE INSTALACIONES</p>
                <h1 class="font-display text-headline-lg-mobile md:text-display text-on-surface mb-2">Gestión de Apiarios</h1>
                <p class="font-body-md text-body-md text-on-surface-variant">Monitoreo y administración de instalaciones apícolas.</p>
            </div>
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full md:w-auto mt-4 md:mt-0 justify-end">
                <a asp-controller="Mas" asp-action="CompararApiarios" class="border border-outline text-on-surface font-label-caps text-label-caps px-6 py-0 h-[46px] rounded hover:bg-surface-container-high transition-colors flex items-center justify-center gap-2 whitespace-nowrap">
                    <span class="material-symbols-outlined text-[18px]">compare_arrows</span>
                    Comparar Apiarios
                </a>
                <button id="btnOpenRegistrar" class="bg-primary-container text-on-primary font-label-caps text-label-caps px-6 py-0 h-[46px] rounded hover:bg-primary-fixed-dim transition-colors flex items-center justify-center gap-2 whitespace-nowrap">
                    <span class="material-symbols-outlined text-[18px]">add</span>
                    Registrar Nuevo Apiario
                </button>
            </div>
        </div>
        <div class="flex items-center gap-4 w-full">
            <div class="flex-grow h-px bg-surface-container-highest"></div>
            <form method="get" class="flex gap-2 items-stretch h-[38px] w-full sm:w-auto justify-end shrink-0">
                <select name="sortBy" class="bg-background border border-outline-variant px-3 py-0 h-full rounded text-on-surface focus:border-primary-container outline-none transition-colors text-sm" onchange="this.form.submit()">
                    <option value="">Por defecto</option>
                    @if (ViewBag.SortBy == "nombre") { <option value="nombre" selected>Nombre</option> } else { <option value="nombre">Nombre</option> }
                    @if (ViewBag.SortBy == "produccion") { <option value="produccion" selected>Producción de Miel</option> } else { <option value="produccion">Producción de Miel</option> }
                    @if (ViewBag.SortBy == "fecha") { <option value="fecha" selected>Fecha de Inspección</option> } else { <option value="fecha">Fecha de Inspección</option> }
                    @if (ViewBag.SortBy == "colmenas") { <option value="colmenas" selected>Cantidad de Colmenas</option> } else { <option value="colmenas">Cantidad de Colmenas</option> }
                </select>
                <input type="hidden" name="desc" id="descToggle" value="@(ViewBag.Desc == true ? "true" : "false")" />
                <button type="button" onclick="document.getElementById('descToggle').value = document.getElementById('descToggle').value === 'true' ? 'false' : 'true'; this.form.submit();" class="bg-surface-container-high border border-outline w-[38px] h-full px-0 rounded hover:text-primary-container transition-colors flex items-center justify-center shrink-0" title="Alternar Asc/Desc">
                    <span class="material-symbols-outlined text-[18px]">
                        @(ViewBag.Desc == true ? "arrow_downward" : "arrow_upward")
                    </span>
                </button>
            </form>
        </div>
    </section>

    <!-- Apiary Grid (Cards) -->
    <section class="bg-surface-container-low border border-outline-variant rounded p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        @foreach (var apiario in Model)
        {
            var colmenasCount = apiario.Colmenas?.Count() ?? 0;
            var prodTotal = apiario.Colmenas?.Sum(c => c.ProduccionMielKg) ?? 0;
            var prodPercent = Math.Min(100, Math.Round((prodTotal / 300.0) * 100));
            var estadoProd = "Media";
            var colorProd = "primary-container";
            
            if (prodPercent >= 90)
            {
                estadoProd = "Crítica"; // Near limit
                colorProd = "error";
            }
            else if (prodPercent >= 70)
            {
                estadoProd = "Alta";
            }

            <article class="bg-background border border-outline-variant p-4 rounded flex flex-col hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-outline-variant group-hover:bg-primary-container transition-colors"></div>
                <div class="flex-grow flex flex-col justify-between pl-3 relative z-10">
                    <div class="flex justify-between items-start mb-4">
                        <h2 class="font-headline-lg text-headline-lg text-on-surface">@apiario.Nombre</h2>
                        <span class="font-label-caps text-label-caps bg-surface-variant text-on-surface-variant px-2 py-1 rounded whitespace-nowrap shrink-0">ID: @apiario.StringIdentificador</span>
                    </div>
                    <div class="space-y-3 mb-6">
                        <div class="flex items-center gap-2 text-on-surface-variant">
                            <span class="material-symbols-outlined text-[16px]">location_on</span>
                            <span class="font-body-md text-body-md">@apiario.UbicacionTexto</span>
                        </div>
                        <div class="flex items-center gap-2 text-on-surface-variant">
                            <span class="material-symbols-outlined text-[16px]">hive</span>
                            <span class="font-body-md text-body-md">@colmenasCount @(colmenasCount == 1 ? "Colmena" : "Colmenas")</span>
                        </div>
                        <div class="flex items-center gap-2 text-on-surface-variant">
                            <span class="material-symbols-outlined text-[16px]">calendar_today</span>
                            <span class="font-body-md text-body-md">Últ. Insp: @(apiario.UltimaInspeccion?.ToString("dd MMM yyyy") ?? "N/A")</span>
                        </div>
                    </div>

                    <!-- Progress/Status -->
                    <div class="mb-4">
                        <div class="flex justify-between items-center mb-1">
                            <span class="font-label-caps text-label-caps text-on-surface-variant">Producción: @estadoProd</span>
                            <span class="font-label-caps text-label-caps text-@colorProd">@prodPercent%</span>
                        </div>
                        <div class="w-full bg-surface-variant h-1 rounded-full overflow-hidden">
                            <div class="bg-@colorProd h-full" style="width: @prodPercent%"></div>
                        </div>
                </div>
                <div class="mt-4 pt-4 border-t border-surface-container-highest pl-3">
                    <a asp-action="Detalles" asp-route-id="@apiario.Id" class="w-full bg-transparent border border-outline-variant text-on-surface font-label-caps text-label-caps px-4 py-2 rounded hover:text-primary-container hover:border-primary-container transition-colors flex justify-center items-center gap-2">
                        Ver Detalles
                        <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                    </a>
                </div>
            </article>
        }
        </div>
    </section>
</main>

<!-- Registrar Nuevo Apiario Modal -->
<div id="registrarModal" class="fixed inset-0 z-50 flex items-center justify-center modal-backdrop bg-black/85 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-xl modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface">Registrar Nuevo Apiario</h4>
            <button type="button" id="btnCancelRegistrarIcon" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar">
            <form asp-action="RegistrarNuevo" method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label for="Nombre" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Nombre *</label>
                    <input type="text" id="Nombre" name="Nombre" required placeholder="Ej. Apiario Central" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                </div>
                <div>
                    <label for="StringIdentificador" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Identificador (Opcional)</label>
                    <input type="text" id="StringIdentificador" name="StringIdentificador" placeholder="Ej. 004" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                </div>
                <div>
                    <label for="UbicacionTexto" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Ubicación *</label>
                    <input type="text" id="UbicacionTexto" name="UbicacionTexto" required placeholder="Ej. Lote 5, Sector Este" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                </div>
                <div>
                    <label for="Departamento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Departamento</label>
                    <input type="text" id="Departamento" name="Departamento" placeholder="Ej. Flores" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="SeccionPolicial" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Sección Policial</label>
                        <input type="text" id="SeccionPolicial" name="SeccionPolicial" placeholder="Ej. 6" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                    </div>
                    <div>
                        <label for="Paraje" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Paraje</label>
                        <input type="text" id="Paraje" name="Paraje" placeholder="Ej. Talar" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                    </div>
                </div>
                <div>
                    <label for="UbicacionCoordenadas" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Coordenadas (Lat, Lng) (Opcional)</label>
                    <input type="text" id="UbicacionCoordenadas" name="UbicacionCoordenadas" placeholder="Ej. 34°05'12.1&quot;S 70°45'22.4&quot;W" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                </div>
                <div>
                    <label for="FechaCreacion" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Fecha de Creación</label>
                    <input type="text" id="FechaCreacion" value="@DateTime.Now.ToString("dd MMMM, yyyy")" disabled class="w-full bg-surface-variant border border-outline-variant px-4 py-2.5 rounded text-on-surface-variant outline-none cursor-not-allowed opacity-70" />
                </div>
                <div class="pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-end gap-3 mt-4">
                    <button type="button" id="btnCancelRegistrar" class="border border-outline text-on-surface hover:bg-surface-container-high px-5 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex transition-colors">
                        Cancelar
                    </button>
                    <button type="submit" class="bg-primary-container text-on-primary hover:bg-primary-fixed px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex transition-colors">
                        Registrar Apiario
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const btnOpen = document.getElementById('btnOpenRegistrar');
        const modal = document.getElementById('registrarModal');
        const btnCancel1 = document.getElementById('btnCancelRegistrar');
        const btnCancel2 = document.getElementById('btnCancelRegistrarIcon');

        function openModal() {
            modal.classList.remove('modal-hidden');
        }

        function closeModal() {
            modal.classList.add('modal-hidden');
        }

        btnOpen.addEventListener('click', openModal);
        btnCancel1.addEventListener('click', closeModal);
        btnCancel2.addEventListener('click', closeModal);
    </script>
}
