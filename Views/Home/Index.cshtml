@{
    ViewData["Title"] = "Dashboard";
}

<!-- Global Apiary Overview -->
<section class="pt-12 pb-8 bg-surface border-b border-secondary-container">
    <div class="max-w-container-max mx-auto px-margin-desktop">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4 md:gap-0">
            <div>
                <h1 class="font-display text-display text-primary mb-2">Resumen Global de Apiarios</h1>
                <p class="font-body-md text-on-surface-variant">Estado del sistema y métricas clave de todas las ubicaciones gestionadas.</p>
            </div>
            <div class="flex gap-4">
                <button class="bg-primary-container text-surface-container-lowest font-display font-bold py-2 px-6 rounded-DEFAULT hover:opacity-80 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">download</span> Exportar Informe
                </button>
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
            <!-- Active Hives -->
            <div class="bg-surface-container border border-secondary-container p-6 rounded-lg">
                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-primary-container" data-icon="agriculture">agriculture</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">TOTAL COLMENAS ACTIVAS</span>
                </div>
                <div class="text-headline-lg font-display text-primary">124</div>
                <div class="text-body-sm text-on-surface-variant mt-2 flex items-center gap-1">
                    <span class="material-symbols-outlined text-primary-container text-sm">trending_up</span> +12 este mes
                </div>
            </div>
            <!-- Production YTD -->
            <div class="bg-surface-container border border-secondary-container p-6 rounded-lg">
                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-primary-container" data-icon="inventory_2">inventory_2</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">PROD. MIEL ANUAL</span>
                </div>
                <div class="text-headline-lg font-display text-primary">1,240 <span class="text-body-md text-on-surface-variant">kg</span></div>
                <div class="text-body-sm text-on-surface-variant mt-2 flex items-center gap-1">
                    <span class="material-symbols-outlined text-primary-container text-sm">trending_up</span> +15% vs año anterior
                </div>
            </div>
            <!-- Active Alerts -->
            <div class="bg-error-container border border-error p-6 rounded-lg">
                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-error" data-icon="warning">warning</span>
                    <span class="font-label-caps text-label-caps text-error">ALERTAS ACTIVAS</span>
                </div>
                <div class="text-headline-lg font-display text-on-error-container">3</div>
                <div class="text-body-sm text-error mt-2">Colonias requieren atención</div>
            </div>
            <!-- Average Temp -->
            <div class="bg-surface-container border border-secondary-container p-6 rounded-lg">
                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-primary-container" data-icon="thermostat">thermostat</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">TEMP. PROMEDIO COLMENA</span>
                </div>
                <div class="text-headline-lg font-display text-primary">35.2°C</div>
                <div class="text-body-sm text-on-surface-variant mt-2 flex items-center gap-1">
                    <span class="material-symbols-outlined text-primary-container text-sm">check_circle</span> Rango óptimo
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Main Dashboard Content -->
<section class="py-12 bg-surface">
    <div class="max-w-container-max mx-auto px-margin-desktop grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Col: Chart & Search -->
        <div class="lg:col-span-1 space-y-8">
            <!-- Data Viz -->
            <div class="bg-surface-container border border-secondary-container p-6 rounded-lg">
                <h3 class="font-display text-headline-lg-mobile text-primary mb-6">Tendencias de Producción</h3>
                <div class="h-48 w-full flex items-end gap-2 border-b border-secondary-container pb-2">
                    <div class="w-full bg-primary-container/20 hover:bg-primary-container/40 transition-colors h-[40%] rounded-t-sm relative group"><span class="absolute -top-6 left-1/2 -translate-x-1/2 text-xs opacity-0 group-hover:opacity-100 transition-opacity">40kg</span></div>
                    <div class="w-full bg-primary-container/20 hover:bg-primary-container/40 transition-colors h-[50%] rounded-t-sm relative group"><span class="absolute -top-6 left-1/2 -translate-x-1/2 text-xs opacity-0 group-hover:opacity-100 transition-opacity">50kg</span></div>
                    <div class="w-full bg-primary-container/20 hover:bg-primary-container/40 transition-colors h-[30%] rounded-t-sm relative group"><span class="absolute -top-6 left-1/2 -translate-x-1/2 text-xs opacity-0 group-hover:opacity-100 transition-opacity">30kg</span></div>
                    <div class="w-full bg-primary-container/20 hover:bg-primary-container/40 transition-colors h-[70%] rounded-t-sm relative group"><span class="absolute -top-6 left-1/2 -translate-x-1/2 text-xs opacity-0 group-hover:opacity-100 transition-opacity">70kg</span></div>
                    <div class="w-full bg-primary-container hover:bg-primary-container/80 transition-colors h-[85%] rounded-t-sm relative group"><span class="absolute -top-6 left-1/2 -translate-x-1/2 text-xs opacity-0 group-hover:opacity-100 transition-opacity">85kg</span></div>
                    <div class="w-full bg-primary-container/20 hover:bg-primary-container/40 transition-colors h-[60%] rounded-t-sm relative group"><span class="absolute -top-6 left-1/2 -translate-x-1/2 text-xs opacity-0 group-hover:opacity-100 transition-opacity">60kg</span></div>
                </div>
                <div class="flex justify-between mt-2 text-label-caps text-on-surface-variant font-label-caps">
                    <span>May</span><span>Jun</span><span>Jul</span><span>Ago</span><span>Sep</span><span>Oct</span>
                </div>
            </div>
            <!-- Search / Filter -->
            <div class="bg-surface-container border border-secondary-container p-6 rounded-lg">
                <h3 class="font-display text-headline-lg-mobile text-primary mb-4">Buscar Colmenas</h3>
                <div class="relative mb-4">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
                    <input class="w-full bg-surface border border-secondary-container rounded-DEFAULT py-2 pl-10 pr-4 text-primary focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none placeholder:text-on-surface-variant/50" placeholder="ID Colmena, Ubicación, Estado..." type="text" />
                </div>
                <div class="flex gap-2 flex-wrap">
                    <button class="px-3 py-1 rounded-full border border-primary-container text-primary-container text-sm hover:bg-primary-container hover:text-surface-container-lowest transition-colors">Todas las Colmenas</button>
                    <button class="px-3 py-1 rounded-full border border-secondary-container text-on-surface text-sm hover:border-primary-container transition-colors">Requiere Atención</button>
                    <button class="px-3 py-1 rounded-full border border-secondary-container text-on-surface text-sm hover:border-primary-container transition-colors">Lista para Cosecha</button>
                </div>
            </div>
        </div>
        <!-- Right Col: Hive Status Table -->
        <div class="lg:col-span-2">
            <div class="bg-surface-container border border-secondary-container rounded-lg overflow-hidden">
                <div class="p-6 border-b border-secondary-container flex justify-between items-center bg-surface-container-high">
                    <h3 class="font-display text-headline-lg-mobile text-primary">Monitoreo de Estado de Colmenas</h3>
                    <button class="text-primary-container text-sm font-bold hover:underline flex items-center gap-1"><span class="material-symbols-outlined text-sm">filter_list</span> Filtrar</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-secondary-container bg-surface-container">
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-medium">ID COLMENA</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-medium">ESTADO</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-medium">ÚLTIMA INSPECCIÓN</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-medium">PESO</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-medium">TEMP.</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant font-medium text-right">ACCIÓN</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-secondary-container">
                            <tr class="hover:bg-surface-container-high transition-colors">
                                <td class="p-4 font-display font-bold text-primary">Alpha-01</td>
                                <td class="p-4"><span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-primary-container/10 text-primary-container text-xs font-bold"><span class="w-2 h-2 rounded-full bg-primary-container"></span> Óptimo</span></td>
                                <td class="p-4 text-on-surface-variant text-sm">Hace 2 días</td>
                                <td class="p-4 text-primary">42.5 kg</td>
                                <td class="p-4 text-primary">35.1°C</td>
                                <td class="p-4 text-right"><button class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined">more_vert</span></button></td>
                            </tr>
                            <tr class="hover:bg-surface-container-high transition-colors">
                                <td class="p-4 font-display font-bold text-primary">Alpha-02</td>
                                <td class="p-4"><span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-primary-container/10 text-primary-container text-xs font-bold"><span class="w-2 h-2 rounded-full bg-primary-container"></span> Óptimo</span></td>
                                <td class="p-4 text-on-surface-variant text-sm">Hace 2 días</td>
                                <td class="p-4 text-primary">45.0 kg</td>
                                <td class="p-4 text-primary">35.3°C</td>
                                <td class="p-4 text-right"><button class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined">more_vert</span></button></td>
                            </tr>
                            <tr class="hover:bg-surface-container-high transition-colors bg-error-container/10">
                                <td class="p-4 font-display font-bold text-primary">Beta-04</td>
                                <td class="p-4"><span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-error/10 text-error text-xs font-bold"><span class="w-2 h-2 rounded-full bg-error"></span> Advertencia - Ácaros</span></td>
                                <td class="p-4 text-on-surface-variant text-sm">Hace 1 día</td>
                                <td class="p-4 text-primary">38.2 kg</td>
                                <td class="p-4 text-primary">36.5°C</td>
                                <td class="p-4 text-right"><button class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined">more_vert</span></button></td>
                            </tr>
                            <tr class="hover:bg-surface-container-high transition-colors">
                                <td class="p-4 font-display font-bold text-primary">Beta-05</td>
                                <td class="p-4"><span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-primary-container/10 text-primary-container text-xs font-bold"><span class="w-2 h-2 rounded-full bg-primary-container"></span> Óptimo</span></td>
                                <td class="p-4 text-on-surface-variant text-sm">Hace 3 días</td>
                                <td class="p-4 text-primary">51.1 kg</td>
                                <td class="p-4 text-primary">34.9°C</td>
                                <td class="p-4 text-right"><button class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined">more_vert</span></button></td>
                            </tr>
                            <tr class="hover:bg-surface-container-high transition-colors bg-error-container/10">
                                <td class="p-4 font-display font-bold text-primary">Gamma-12</td>
                                <td class="p-4"><span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-error/10 text-error text-xs font-bold"><span class="w-2 h-2 rounded-full bg-error"></span> Advertencia - Poco Alimento</span></td>
                                <td class="p-4 text-on-surface-variant text-sm">Hace 5 días</td>
                                <td class="p-4 text-error">22.4 kg</td>
                                <td class="p-4 text-primary">34.2°C</td>
                                <td class="p-4 text-right"><button class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined">more_vert</span></button></td>
                            </tr>
                            <tr class="hover:bg-surface-container-high transition-colors">
                                <td class="p-4 font-display font-bold text-primary">Gamma-13</td>
                                <td class="p-4"><span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-primary-container/10 text-primary-container text-xs font-bold"><span class="w-2 h-2 rounded-full bg-primary-container"></span> Óptimo</span></td>
                                <td class="p-4 text-on-surface-variant text-sm">Hace 5 días</td>
                                <td class="p-4 text-primary">40.8 kg</td>
                                <td class="p-4 text-primary">35.0°C</td>
                                <td class="p-4 text-right"><button class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined">more_vert</span></button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
