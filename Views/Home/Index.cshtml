@model ObligatorioIntegrador2026.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="px-margin-desktop py-8 max-w-container-max mx-auto space-y-8 animate-fade-in">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
        <div>
            <h1 class="font-display text-display text-primary mb-2">Resumen Global del Sistema</h1>
            <p class="font-body-md text-on-surface-variant">Estado actual, alertas y métricas clave de tu operación apícola.</p>
        </div>
        <div class="flex gap-4">
            <a href="/Home/DescargarReporte" target="_blank" class="bg-primary-container text-on-primary-container font-label-caps text-label-caps py-2.5 px-6 rounded hover:bg-primary-fixed transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">download</span> Descargar Reporte
            </a>
        </div>
    </div>

    <!-- KPIs Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Apiarios -->
        <div class="bg-surface-container border border-outline-variant p-6 rounded-lg flex flex-col justify-between hover:border-primary-container transition-colors">
            <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-primary-container">location_on</span>
                <span class="font-label-caps text-label-caps text-on-surface-variant">TOTAL APIARIOS</span>
            </div>
            <div class="text-display font-display text-primary">@Model.TotalApiarios</div>
        </div>

        <!-- Colmenas -->
        <div class="bg-surface-container border border-outline-variant p-6 rounded-lg flex flex-col justify-between hover:border-primary-container transition-colors">
            <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-primary-container">agriculture</span>
                <span class="font-label-caps text-label-caps text-on-surface-variant">TOTAL COLMENAS ACTIVAS</span>
            </div>
            <div class="text-display font-display text-primary">@Model.TotalColmenas</div>
        </div>

        <!-- Produccion -->
        <div class="bg-surface-container border border-outline-variant p-6 rounded-lg flex flex-col justify-between hover:border-primary-container transition-colors">
            <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-primary-container">inventory_2</span>
                <span class="font-label-caps text-label-caps text-on-surface-variant">MIEL ACUMULADA</span>
            </div>
            <div class="text-display font-display text-primary">@Model.TotalProduccionMielKg.ToString("0.##") <span class="text-body-lg text-on-surface-variant">kg</span></div>
        </div>

        <!-- Alertas -->
        <div class="bg-error-container border border-error p-6 rounded-lg flex flex-col justify-between hover:border-error transition-colors">
            <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-error">warning</span>
                <span class="font-label-caps text-label-caps text-error">ALERTAS ACTIVAS</span>
            </div>
            <div class="text-display font-display text-on-error-container">@Model.AlertasActivas</div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Col: Tendencias -->
        <div class="lg:col-span-2">
            <div class="bg-surface-container border border-outline-variant p-6 rounded-lg h-full flex flex-col">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-display text-headline-sm text-primary">Tendencias de Producción (Últimos 6 meses)</h3>
                </div>
                <!-- Gráfico de barras rediseñado -->
                <div class="flex-grow flex items-end gap-3 border-b border-outline-variant pb-2 mt-4 min-h-[200px]">
                    @foreach (var mesInfo in Model.TendenciaProduccion)
                    {
                        <div class="w-full bg-[#B28F05] hover:bg-[#FFD900] transition-colors rounded-t-sm relative group flex justify-center" style="height: @(mesInfo.PorcentajeAltura.ToString("0"))%">
                            <span class="absolute -top-8 bg-surface-container-high px-2 py-1 rounded text-xs font-bold text-primary shadow-sm opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">@mesInfo.CantidadKg.ToString("0.#") kg</span>
                        </div>
                    }
                </div>
                <div class="flex justify-between mt-3 text-label-caps text-on-surface-variant font-label-caps px-1">
                    @foreach (var mesInfo in Model.TendenciaProduccion)
                    {
                        <span class="w-full text-center @(mesInfo.EsMesActual ? "text-primary font-bold" : "")">@mesInfo.Mes</span>
                    }
                </div>
            </div>
        </div>

        <!-- Right Col: Colmenas en Alerta -->
        <div class="lg:col-span-1">
            <div class="bg-surface-container border border-outline-variant p-6 rounded-lg h-full flex flex-col">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-display text-headline-sm text-primary">Colmenas en Alerta</h3>
                    <a href="/Apiarios" class="text-primary-container text-sm font-label-caps hover:underline">Ver todas</a>
                </div>
                
                @if (Model.ColmenasEnAlerta.Count > 0)
                {
                    <div class="flex flex-col gap-3 overflow-y-auto max-h-[300px] pr-2 custom-scrollbar">
                        @foreach(var colmena in Model.ColmenasEnAlerta)
                        {
                            <div class="p-3 border @(colmena.Estado == "Crítico" ? "border-error bg-error-container/10" : "border-outline-variant bg-surface") rounded flex justify-between items-center">
                                <div>
                                    <div class="font-bold font-display text-primary text-sm">@(colmena.Identificador ?? colmena.CodigoEscaneo)</div>
                                    <div class="text-xs text-on-surface-variant flex items-center gap-1 mt-1">
                                        <span class="material-symbols-outlined text-[12px]">location_on</span> @colmena.Apiario.Nombre
                                    </div>
                                </div>
                                <div>
                                    <div class="inline-flex items-center gap-1.5 px-2 py-1 border @(colmena.Estado == "Crítico" ? "border-error bg-error/10 text-error" : "border-primary-container bg-primary-container/10 text-primary-container") rounded font-label-caps text-label-caps">
                                        <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">@(colmena.Estado == "Crítico" ? "warning" : "info")</span>
                                        @colmena.Estado
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="flex-grow flex flex-col items-center justify-center text-center p-4">
                        <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2">check_circle</span>
                        <p class="text-sm text-on-surface-variant">No hay colmenas que requieran atención inmediata.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Bottom Row Left: Movimientos Vigentes -->
        <div class="lg:col-span-2">
            <div class="bg-surface-container border border-outline-variant p-6 rounded-lg h-full">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-display text-headline-sm text-primary">Movimientos Activos</h3>
                    <a href="/Mas/Movimientos" class="text-primary-container text-sm font-label-caps hover:underline">Ver sección</a>
                </div>
                
                @if (Model.MovimientosVigentes.Count > 0)
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-outline-variant">
                                    <th class="py-2 text-xs font-label-caps text-on-surface-variant">COLMENA</th>
                                    <th class="py-2 text-xs font-label-caps text-on-surface-variant">ORIGEN</th>
                                    <th class="py-2 text-xs font-label-caps text-on-surface-variant">DESTINO</th>
                                    <th class="py-2 text-xs font-label-caps text-on-surface-variant">RETORNO ESTIMADO</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-outline-variant/50">
                                @foreach(var mov in Model.MovimientosVigentes)
                                {
                                    <tr class="hover:bg-surface transition-colors">
                                        <td class="py-3 text-sm font-medium text-primary">@(mov.Colmena?.Identificador ?? mov.Colmena?.CodigoEscaneo)</td>
                                        <td class="py-3 text-sm text-on-surface-variant">@mov.ApiarioOrigen?.Nombre</td>
                                        <td class="py-3 text-sm text-on-surface-variant">@mov.ApiarioDestino?.Nombre</td>
                                        <td class="py-3 text-sm text-primary-container font-medium">@mov.FechaRegreso.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-sm text-on-surface-variant">No hay movimientos activos en este momento.</p>
                }
            </div>
        </div>

        <!-- Bottom Row Right: Inventario Crítico -->
        <div class="lg:col-span-1">
            <div class="bg-surface-container border border-outline-variant p-6 rounded-lg h-full">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-display text-headline-sm text-primary">Inventario Bajo Stock</h3>
                    <a href="/Mas/Inventario" class="text-primary-container text-sm font-label-caps hover:underline">Ir a inventario</a>
                </div>

                @if (Model.InventarioBajoStock.Count > 0)
                {
                    <div class="flex flex-col gap-3">
                        @foreach(var item in Model.InventarioBajoStock)
                        {
                            <div class="flex justify-between items-center border-b border-outline-variant/30 pb-2 last:border-0 last:pb-0">
                                <div>
                                    <div class="font-medium text-primary text-sm">@item.Name</div>
                                    <div class="text-[11px] text-on-surface-variant uppercase tracking-wider">@item.Category</div>
                                </div>
                                <div class="text-right">
                                    <div class="font-bold text-error text-sm">@item.Stock u.</div>
                                    <div class="text-[10px] text-on-surface-variant">Mín: @item.LowThreshold</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="flex flex-col items-center justify-center text-center p-4 h-full">
                        <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-2">inventory_2</span>
                        <p class="text-sm text-on-surface-variant">Todo el equipamiento tiene stock adecuado.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Row 3 Left: Finanzas del Análisis Activo -->
        <div class="lg:col-span-2">
            <div class="bg-surface-container border border-outline-variant p-6 rounded-lg h-full flex flex-col justify-between">
                <div>
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-display text-headline-sm text-primary">Análisis Financiero Activo</h3>
                        <a href="/Mas/Finanzacion" class="text-primary-container text-sm font-label-caps hover:underline">Ver sección</a>
                    </div>

                    @if (Model.HasActiveAnalysis)
                    {
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <!-- Inversión Total -->
                            <div class="bg-surface-container-high border border-outline-variant p-4 rounded-lg flex flex-col justify-between hover:border-primary-container transition-colors relative overflow-hidden group">
                                <div class="absolute top-0 right-0 w-24 h-24 bg-error/5 rounded-full -mr-8 -mt-8 blur-lg group-hover:bg-error/10 transition-all duration-500"></div>
                                <div class="flex justify-between items-center z-10 mb-2">
                                    <span class="font-label-caps text-[11px] text-on-surface-variant uppercase tracking-wider">Inversión Total</span>
                                    <span class="material-symbols-outlined text-error text-xl" style="font-variation-settings: 'FILL' 0;">trending_down</span>
                                </div>
                                <div class="text-xl font-display text-on-background z-10 font-bold">$@Model.ActiveTotalInversion.ToString("N2")</div>
                                <div class="text-[11px] text-on-surface-variant z-10 mt-2">@(Model.ActiveEgresosCount) Egresos</div>
                            </div>

                            <!-- Ganancia Bruta -->
                            <div class="bg-surface-container-high border border-outline-variant p-4 rounded-lg flex flex-col justify-between hover:border-primary-container transition-colors relative overflow-hidden group">
                                <div class="absolute top-0 right-0 w-24 h-24 bg-primary-container/5 rounded-full -mr-8 -mt-8 blur-lg group-hover:bg-primary-container/10 transition-all duration-500"></div>
                                <div class="flex justify-between items-center z-10 mb-2">
                                    <span class="font-label-caps text-[11px] text-on-surface-variant uppercase tracking-wider">Ganancia Bruta</span>
                                    <span class="material-symbols-outlined text-primary-container text-xl" style="font-variation-settings: 'FILL' 0;">trending_up</span>
                                </div>
                                <div class="text-xl font-display text-on-background z-10 font-bold">+$@Model.ActiveGananciaBruta.ToString("N2")</div>
                                <div class="text-[11px] text-on-surface-variant z-10 mt-2">@(Model.ActiveIngresosCount) Ingresos</div>
                            </div>

                            <!-- Balance Neto -->
                            @if (Model.ActiveBalanceNeto >= 0)
                            {
                                <div class="bg-surface-container-high border border-primary-container p-4 rounded-lg flex flex-col justify-between hover:border-primary-container transition-colors relative overflow-hidden group shadow-[0_0_10px_rgba(255,217,0,0.05)]">
                                    <div class="absolute top-0 right-0 w-24 h-24 bg-primary-container/10 rounded-full -mr-8 -mt-8 blur-lg group-hover:bg-primary-container/20 transition-all duration-500"></div>
                                    <div class="flex justify-between items-center z-10 mb-2">
                                        <span class="font-label-caps text-[11px] text-primary-container font-bold uppercase tracking-wider">Balance Neto (Profit)</span>
                                        <span class="material-symbols-outlined text-primary-container text-xl" style="font-variation-settings: 'FILL' 1;">account_balance_wallet</span>
                                    </div>
                                    <div class="text-xl font-display text-primary-container z-10 font-bold">$@Model.ActiveBalanceNeto.ToString("N2")</div>
                                </div>
                            }
                            else
                            {
                                <div class="bg-surface-container-high border border-error p-4 rounded-lg flex flex-col justify-between hover:border-error transition-colors relative overflow-hidden group shadow-[0_0_10px_rgba(255,180,171,0.05)]">
                                    <div class="absolute top-0 right-0 w-24 h-24 bg-error/10 rounded-full -mr-8 -mt-8 blur-lg group-hover:bg-error/20 transition-all duration-500"></div>
                                    <div class="flex justify-between items-center z-10 mb-2">
                                        <span class="font-label-caps text-[11px] text-error font-bold uppercase tracking-wider">Balance Neto (Pérdida)</span>
                                        <span class="material-symbols-outlined text-error text-xl" style="font-variation-settings: 'FILL' 1;">account_balance_wallet</span>
                                    </div>
                                    <div class="text-xl font-display text-error z-10 font-bold">-$@Math.Abs(Model.ActiveBalanceNeto).ToString("N2")</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Empty Active Analysis Card mimicking Finanzacion.cshtml -->
                        <div class="flex flex-col items-center text-center gap-4 py-4 px-2 bg-surface-container-high border border-outline-variant rounded-lg max-w-2xl mx-auto shadow-sm">
                            <span class="material-symbols-outlined text-[48px] text-primary-container animate-bounce mt-2">payments</span>
                            <h3 class="font-headline-lg text-on-surface text-base font-bold">Comenzar Nuevo Análisis Financiero</h3>
                            <p class="font-body-md text-on-surface-variant max-w-md text-xs">
                                Para registrar y llevar el control detallado de las inversiones realizadas y ganancias obtenidas en la temporada apícola actual, inicie un nuevo análisis ahora.
                            </p>
                            <a href="/Mas/Finanzacion" class="bg-primary-container text-on-primary font-label-caps text-label-caps px-5 py-2 rounded hover:bg-primary-fixed hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-2 mb-2 no-underline text-xs">
                                <span class="material-symbols-outlined text-[16px]">play_arrow</span>
                                Empezar Análisis Financiero
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Row 3 Right: Declaraciones del Ministerio -->
        <div class="lg:col-span-1">
            @{
                var hasDates = Model.FechaUltimaDeclaracion.HasValue && Model.FechaProximaDeclaracion.HasValue;
                var lastDateStr = hasDates ? Model.FechaUltimaDeclaracion!.Value.ToString("dd 'de' MMMM, yyyy", new System.Globalization.CultureInfo("es-ES")) : "No registrada";
                var nextDateStr = hasDates ? Model.FechaProximaDeclaracion!.Value.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES")).ToUpper() : "No registrada";
                var validUntilStr = hasDates ? $"Válida hasta 30/06/{Model.FechaProximaDeclaracion!.Value.Year}" : "Vigencia no definida";
                var remDays = hasDates ? (int)Math.Ceiling((Model.FechaProximaDeclaracion!.Value - DateTime.Today).TotalDays) : 0;
                var remDaysStr = !hasDates ? "-" : (remDays > 0 ? $"~{remDays} DÍAS" : "VENCIDA");
                var badgeColorClass = !hasDates ? "text-on-surface-variant bg-surface-container-high" : (remDays > 0 ? "text-primary-container bg-surface-container-high border-outline-variant" : "text-error bg-error-container/20 border-error/50");
            }
            <div class="bg-surface-container border border-outline-variant p-6 rounded-lg h-full flex flex-col justify-between">
                <div>
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-display text-headline-sm text-primary">Declaraciones (SINATPA)</h3>
                        <a href="/Informes" class="text-primary-container text-sm font-label-caps hover:underline">Ver sección</a>
                    </div>
                    
                    <div class="flex flex-col gap-4">
                        <!-- Última Presentada -->
                        <div class="bg-surface-container-high border border-outline-variant/30 p-4 rounded flex items-center justify-between">
                            <div>
                                <div class="text-[10px] font-label-caps text-on-surface-variant mb-1 tracking-wider">ÚLTIMA PRESENTADA</div>
                                <div class="font-display font-semibold text-on-surface text-sm">@lastDateStr</div>
                            </div>
                            <span class="material-symbols-outlined text-primary-container text-2xl">task_alt</span>
                        </div>
                        
                        <!-- Próxima a Presentar -->
                        <div class="bg-surface-container-high border border-outline-variant/30 p-4 rounded flex items-center justify-between relative overflow-hidden">
                            @if (hasDates && remDays > 0)
                            {
                                <div class="absolute right-0 top-0 bottom-0 w-1 bg-primary-container"></div>
                            }
                            else if (hasDates)
                            {
                                <div class="absolute right-0 top-0 bottom-0 w-1 bg-error"></div>
                            }
                            <div>
                                <div class="text-[10px] font-label-caps text-on-surface-variant mb-1 tracking-wider">PRÓXIMA A PRESENTAR</div>
                                <div class="font-display font-semibold text-on-surface text-sm">@nextDateStr</div>
                                <div class="text-[10px] text-on-surface-variant mt-1 flex items-center gap-1 font-body-sm">
                                    <span class="material-symbols-outlined text-[12px]">calendar_today</span> @validUntilStr
                                </div>
                            </div>
                            <div class="flex flex-col items-end gap-1 shrink-0">
                                <span class="material-symbols-outlined text-primary-container text-2xl">pending_actions</span>
                                @if (hasDates)
                                {
                                    <span class="font-label-caps text-[9px] px-1.5 py-0.5 rounded border @badgeColorClass">@remDaysStr</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    /* Utility for custom scrollbar in tight spaces */
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: var(--color-outline-variant, #E1E3DE);
        border-radius: 10px;
    }
</style>
