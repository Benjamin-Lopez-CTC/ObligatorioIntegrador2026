@model ObligatorioIntegrador2026.Models.Colmena

@{
    ViewData["Title"] = "Gestión de Tratamientos";
}

<main class="flex-grow w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 flex flex-col gap-8">
    <!-- Breadcrumb Context Bar -->
    <div class="w-full flex items-center gap-2 font-label-caps text-label-caps text-on-surface-variant mb-2">
        <a asp-action="Index" class="hover:text-primary-container transition-colors">Colmenas</a>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <a asp-action="Detalles" asp-route-id="@Model.Id" class="hover:text-primary-container transition-colors">Detalle de Colmena</a>
        <span class="material-symbols-outlined text-[14px]">chevron_right</span>
        <span class="text-on-surface">Gestión de Tratamientos</span>
    </div>

    <!-- Page Header -->
    <section class="flex flex-col md:flex-row md:items-end justify-between gap-6 pb-6 border-b border-surface-container-highest">
        <div>
            <h1 class="font-display text-display md:text-[40px] text-[32px] text-primary-container mb-2">Gestión de Tratamientos</h1>
            <div class="flex flex-wrap items-center gap-3">
                <span class="font-label-caps text-label-caps px-2 py-1 bg-surface-container-low border border-outline-variant rounded text-primary-container">ID: @(string.IsNullOrEmpty(Model.Identificador) ? Model.CodigoEscaneo : Model.Identificador)</span>
                <span class="font-label-caps text-label-caps px-2 py-1 bg-surface-container-low border border-outline-variant rounded text-on-surface-variant">Código Escaneo: @Model.CodigoEscaneo</span>
                @{
                    string statusHtml = "";
                    if (Model.Estado == "Óptimo")
                    {
                        statusHtml = "<span class=\"bg-surface-container-high border border-[#4CAF50] text-[#4CAF50] font-label-caps text-label-caps px-2 py-1 rounded-sm uppercase flex items-center gap-1\"><span class=\"material-symbols-outlined text-[14px]\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>Óptimo</span>";
                    }
                    else if (Model.Estado == "Alerta")
                    {
                        statusHtml = "<span class=\"bg-primary-container/10 border border-primary-container text-primary-container font-label-caps text-label-caps px-2 py-1 rounded-sm uppercase flex items-center gap-1\"><span class=\"material-symbols-outlined text-[14px]\" style=\"font-variation-settings: 'FILL' 1;\">info</span>Alerta</span>";
                    }
                    else if (Model.Estado == "Crítico")
                    {
                        statusHtml = "<span class=\"bg-error-container/5 border border-error text-error font-label-caps text-label-caps px-2 py-1 rounded-sm uppercase flex items-center gap-1\"><span class=\"material-symbols-outlined text-[14px]\" style=\"font-variation-settings: 'FILL' 1;\">warning</span>Crítico</span>";
                    }
                }
                @Html.Raw(statusHtml)
            </div>
        </div>
        <button id="btnOpenRegistrar" class="flex items-center gap-2 px-6 py-3 bg-primary-container text-on-primary-fixed hover:bg-primary-fixed transition-colors rounded-sm font-label-caps text-label-caps shadow-[0_0_15px_rgba(255,217,0,0.2)]">
            <span class="material-symbols-outlined text-[18px]">add</span>
            Registrar Nuevo Tratamiento
        </button>
    </section>

    <!-- Read-Only Status Panel -->
    <section class="bg-[#252525] border border-outline-variant rounded-lg p-6">
        <h2 class="font-headline-lg text-[20px] font-semibold text-on-surface mb-4">Estado de la Colmena</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Queen Status -->
            <div class="bg-surface-container border border-outline-variant rounded p-4 flex flex-col gap-1">
                <span class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-primary-container text-[18px]">emoji_nature</span>
                    Estado de la Reina
                </span>
                <span class="font-body-md text-on-surface font-semibold mt-1">@Model.EstadoReina</span>
            </div>
            <!-- General State -->
            <div class="bg-surface-container border border-outline-variant rounded p-4 flex flex-col gap-1">
                <span class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-primary-container text-[18px]">monitor_heart</span>
                    Estado General
                </span>
                <span class="font-body-md text-on-surface font-semibold mt-1">@Model.Estado</span>
            </div>
            <!-- Bee Quantity -->
            <div class="bg-surface-container border border-outline-variant rounded p-4 flex flex-col gap-1">
                <span class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-primary-container text-[18px]">groups</span>
                    Cantidad de Abejas
                </span>
                <span class="font-body-md text-on-surface font-semibold mt-1">@Model.CantidadAbejas.ToString("N0")</span>
            </div>
            <!-- Bee Behavior -->
            <div class="bg-surface-container border border-outline-variant rounded p-4 flex flex-col gap-1">
                <span class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-primary-container text-[18px]">psychology</span>
                    Comportamiento
                </span>
                <span class="font-body-md text-on-surface font-semibold mt-1">@Model.ComportamientoAbejas</span>
            </div>
        </div>
    </section>

    <!-- Filters Section -->
    <section class="bg-[#252525] border border-outline-variant rounded-lg p-6">
        <h2 class="font-headline-lg text-[20px] font-semibold text-on-surface mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary-container">filter_alt</span>
            Filtros de Tratamientos
        </h2>
        <div class="flex flex-col gap-4">
            <!-- Fila superior: únicamente el filtro de rango de fechas -->
            <div class="flex flex-col gap-1.5 w-full">
                <span class="font-label-caps text-label-caps text-on-surface-variant">Rango de Fechas</span>
                <div class="flex gap-4">
                    <input type="date" id="filterDesde" class="w-full bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                    <input type="date" id="filterHasta" class="w-full bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                </div>
            </div>
            
            <!-- Fila inferior: filtro por antigüedad (ya existente), filtro por tipo y filtro por equipamientos, todos en la misma fila -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Antigüedad -->
                <div class="flex flex-col gap-1.5">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">Antigüedad</span>
                    <select id="filterOrden" class="w-full bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                        <option value="newest">Tratamiento más nuevo</option>
                        <option value="oldest">Tratamiento más antiguo</option>
                    </select>
                </div>
                <!-- Por Tipo -->
                <div class="flex flex-col gap-1.5">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">Por Tipo</span>
                    <select id="filterTipo" class="w-full bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                        <option value="all">Todos</option>
                        <option value="Mantenimiento">Mantenimiento</option>
                        <option value="Medicinal">Medicinal</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
                <!-- Por Equipamiento -->
                <div class="flex flex-col gap-1.5">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">Por Equipamiento</span>
                    <select id="filterCantEquip" class="w-full bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                        <option value="all">Todos</option>
                        <option value="0">Sin equipamientos</option>
                        <option value="1">Con 1 equipamiento</option>
                        <option value="2+">Con 2 o más</option>
                    </select>
                </div>
            </div>
        </div>
    </section>

    <!-- Treatments History List -->
    <section>
        <h2 class="font-headline-lg text-[22px] text-on-surface mb-6 border-b border-surface-container-highest pb-2">Historial de Tratamientos</h2>
        <div class="space-y-4" id="tratamientosContainer">
            <!-- Populated via Javascript -->
        </div>
    </section>
</main>

<!-- Registrar Tratamiento Modal -->
<div id="registrarModal" class="fixed inset-0 z-50 flex modal-backdrop modal-hidden items-center justify-center bg-black/85 p-4">
    <div class="bg-surface-container border border-outline-variant rounded-lg w-full max-w-2xl shadow-2xl overflow-hidden modal-container">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-container">vaccines</span>
                Registrar Nuevo Tratamiento
            </h4>
            <button id="btnCancelRegistrarIcon" class="text-on-surface-variant hover:text-primary-container transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form id="registrarForm" class="p-6 space-y-4">
            <input type="hidden" id="colmenaIdInput" value="@Model.Id" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="tituloTratamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Título *</label>
                    <input type="text" id="tituloTratamiento" required class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded-sm text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" placeholder="Ej: Control de Varroa Otoñal" />
                </div>
                <div>
                    <label for="tipoTratamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Tipo *</label>
                    <select id="tipoTratamiento" required class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded-sm text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                        <option value="" disabled selected>Seleccione tipo...</option>
                        <option value="Mantenimiento">Mantenimiento</option>
                        <option value="Medicinal">Medicinal</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
            </div>

            <div>
                <label for="fechaTratamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Fecha de Registro</label>
                <input type="text" id="fechaTratamiento" readonly class="w-full bg-surface-container-high border border-outline-variant px-4 py-2.5 rounded-sm text-on-surface outline-none cursor-default" />
            </div>

            <div>
                <label for="notaTratamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Notas</label>
                <textarea id="notaTratamiento" rows="3" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded-sm text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" placeholder="Escriba notas libres sobre el tratamiento..."></textarea>
            </div>

            <div>
                <div class="flex justify-between items-center mb-2 border-b border-surface-container-highest pb-2">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">Equipamientos Utilizados</span>
                </div>
                
                <div id="equipamientosRowsContainer" class="space-y-3">
                    <!-- Dynamic rows will go here -->
                </div>
                
                <button type="button" id="btnAddEquipmentRow" class="mt-3 flex items-center gap-1 text-primary-container hover:text-primary-fixed transition-colors font-label-caps text-label-caps">
                    <span class="material-symbols-outlined text-[18px]">add</span>
                    + Agregar equipamiento
                </button>
            </div>

            <div class="pt-4 border-t border-surface-container-highest flex justify-end gap-3 mt-6">
                <button type="button" id="btnCancelRegistrar" class="border border-outline text-on-surface hover:bg-surface-container-high transition-colors px-5 py-2.5 rounded-sm font-label-caps text-label-caps">
                    Cancelar
                </button>
                <button type="submit" class="bg-primary-container text-on-primary-fixed hover:bg-primary-fixed transition-colors px-6 py-2.5 rounded-sm font-label-caps text-label-caps ">
                    Confirmar Registro
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Ver Detalles Modal -->
<div id="detallesModal" class="fixed inset-0 z-50 flex modal-backdrop modal-hidden items-center justify-center bg-black/85 p-4">
    <div class="bg-surface-container border border-outline-variant rounded-lg w-full max-w-lg shadow-2xl overflow-hidden modal-container">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-container">visibility</span>
                <span id="detailTitulo">Detalles del Tratamiento</span>
            </h4>
            <button id="btnCancelDetallesIcon" class="text-on-surface-variant hover:text-primary-container transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <span class="font-label-caps text-label-caps text-on-surface-variant block mb-1">Título</span>
                    <span id="detailTituloField" class="font-body-md text-on-surface font-semibold block"></span>
                </div>
                <div>
                    <span class="font-label-caps text-label-caps text-on-surface-variant block mb-1">Fecha</span>
                    <span id="detailFecha" class="font-body-md text-on-surface block"></span>
                </div>
            </div>
            <div>
                <span class="font-label-caps text-label-caps text-on-surface-variant block mb-1">Tipo</span>
                <span id="detailTipo" class="font-body-md text-on-surface block"></span>
            </div>
            <div>
                <span class="font-label-caps text-label-caps text-on-surface-variant block mb-1">Nota</span>
                <p id="detailNota" class="font-body-sm text-on-surface-variant bg-background p-3 border border-outline-variant rounded-sm min-h-[60px] whitespace-pre-wrap"></p>
            </div>
            <div>
                <span class="font-label-caps text-label-caps text-on-surface-variant block mb-2">Equipamientos Utilizados</span>
                <div id="detailEquipamientosContainer" class="bg-background border border-outline-variant rounded-sm p-4 text-sm font-body-sm text-on-surface-variant space-y-2">
                    <!-- List of equipments -->
                </div>
            </div>
            <div class="pt-4 border-t border-surface-container-highest flex justify-end">
                <button type="button" id="btnCerrarDetalles" class="bg-surface-container-high border border-outline text-on-surface hover:bg-surface-container-highest transition-colors px-6 py-2.5 rounded-sm font-label-caps text-label-caps">
                    Cerrar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const colmenaId = @Model.Id;
        let treatments = [];
        let availableEquipments = @Html.Raw(ViewBag.EquipmentsJson);
        let rowCounter = 0;

        // UI Initialization
        document.addEventListener('DOMContentLoaded', () => {
            loadTreatments();

            // Set up main buttons
            const btnOpenRegistrar = document.getElementById('btnOpenRegistrar');
            const registrarModal = document.getElementById('registrarModal');
            
            btnOpenRegistrar.addEventListener('click', () => {
                // Reset form first
                document.getElementById('registrarForm').reset();
                createInitialRow();
                
                // Preset current local date-time
                const now = new Date();
                const formatted = now.toLocaleDateString('es-ES', {
                    day: '2-digit', month: '2-digit', year: 'numeric'
                }) + ' ' + now.toLocaleTimeString('es-ES', {
                    hour: '2-digit', minute: '2-digit'
                });
                document.getElementById('fechaTratamiento').value = formatted;
                
                // Show modal
                registrarModal.classList.remove('modal-hidden');
            });

            // Close actions for Registrar
            document.getElementById('btnCancelRegistrar').addEventListener('click', () => {
                registrarModal.classList.add('modal-hidden');
            });
            document.getElementById('btnCancelRegistrarIcon').addEventListener('click', () => {
                registrarModal.classList.add('modal-hidden');
            });

            // Close actions for Detalles
            const detallesModal = document.getElementById('detallesModal');
            document.getElementById('btnCerrarDetalles').addEventListener('click', () => {
                detallesModal.classList.add('modal-hidden');
            });
            document.getElementById('btnCancelDetallesIcon').addEventListener('click', () => {
                detallesModal.classList.add('modal-hidden');
            });

            // Add equipment row button
            document.getElementById('btnAddEquipmentRow').addEventListener('click', () => {
                addEquipmentRow();
            });

            // Set up filters triggers
            document.getElementById('filterDesde').addEventListener('change', renderTreatments);
            document.getElementById('filterHasta').addEventListener('change', renderTreatments);
            document.getElementById('filterTipo').addEventListener('change', renderTreatments);
            document.getElementById('filterCantEquip').addEventListener('change', renderTreatments);
            document.getElementById('filterOrden').addEventListener('change', renderTreatments);
        });

        // Load treatments from server via AJAX
        async function loadTreatments() {
            try {
                const response = await fetch('/Colmenas/GetTratamientosList/' + colmenaId);
                const res = await response.json();
                if (res.success) {
                    treatments = res.data;
                    renderTreatments();
                }
            } catch (err) {
                console.error("Error cargando tratamientos:", err);
            }
        }

        // Fetch latest inventory details from server to keep stock counts up to date
        async function refreshEquipments() {
            try {
                const response = await fetch('/Mas/GetEquipments');
                const res = await response.json();
                if (res.success) {
                    availableEquipments = res.data;
                }
            } catch (err) {
                console.error("Error actualizando equipamiento:", err);
            }
        }

        // Render treatments list with filtering and sorting
        function renderTreatments() {
            const container = document.getElementById('tratamientosContainer');
            if (!container) return;

            const desdeVal = document.getElementById('filterDesde').value;
            const hastaVal = document.getElementById('filterHasta').value;
            const tipoVal = document.getElementById('filterTipo').value;
            const cantVal = document.getElementById('filterCantEquip').value;
            const ordenVal = document.getElementById('filterOrden').value;

            let filtered = [...treatments];

            // Filter date range
            if (desdeVal) {
                const desdeDate = new Date(desdeVal + 'T00:00:00');
                filtered = filtered.filter(t => new Date(t.fecha) >= desdeDate);
            }
            if (hastaVal) {
                const hastaDate = new Date(hastaVal + 'T23:59:59');
                filtered = filtered.filter(t => new Date(t.fecha) <= hastaDate);
            }

            // Filter type
            if (tipoVal !== 'all') {
                filtered = filtered.filter(t => t.tipo === tipoVal);
            }

            // Filter by equipment quantity
            if (cantVal !== 'all') {
                if (cantVal === '0') {
                    filtered = filtered.filter(t => t.equipamientos.length === 0);
                } else if (cantVal === '1') {
                    filtered = filtered.filter(t => t.equipamientos.length === 1);
                } else if (cantVal === '2+') {
                    filtered = filtered.filter(t => t.equipamientos.length >= 2);
                }
            }

            // Sort
            if (ordenVal === 'newest') {
                filtered.sort((a, b) => new Date(b.fecha) - new Date(a.fecha));
            } else {
                filtered.sort((a, b) => new Date(a.fecha) - new Date(b.fecha));
            }

            if (filtered.length === 0) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center py-12 text-center bg-[#252525] border border-outline-variant rounded-lg w-full">
                        <span class="material-symbols-outlined text-outline text-5xl mb-4 text-[#989077]">inventory_2</span>
                        <p class="font-body-md text-body-md text-on-surface mb-2 font-medium">No se encontraron tratamientos</p>
                        <p class="font-body-sm text-body-sm text-on-surface-variant max-w-sm">Prueba ajustando los filtros o registra un nuevo tratamiento para comenzar.</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = '';
            filtered.forEach(t => {
                // Choose badge style
                let badgeClass = '';
                let typeIcon = '';
                if (t.tipo === 'Medicinal') {
                    badgeClass = 'bg-[#4c1c24] border border-[#782836] text-[#ffb4ab]';
                    typeIcon = 'science';
                } else if (t.tipo === 'Mantenimiento') {
                    badgeClass = 'bg-[#1a2e1e] border border-[#2d5a36] text-[#4ade80]';
                    typeIcon = 'handyman';
                } else {
                    badgeClass = 'bg-[#292a2a] border border-[#4c4732] text-[#cfc6ab]';
                    typeIcon = 'more_horiz';
                }

                // Equipments summary
                let eqSummary = 'Sin equipamiento utilizado';
                if (t.equipamientos && t.equipamientos.length > 0) {
                    const visible = t.equipamientos.slice(0, 3).map(eq => `${eq.name} (${eq.cantidad}u)`).join(', ');
                    if (t.equipamientos.length > 3) {
                        eqSummary = `${visible} y ${t.equipamientos.length - 3} más`;
                    } else {
                        eqSummary = visible;
                    }
                }

                const itemDiv = document.createElement('div');
                itemDiv.className = 'bg-[#252525] border border-outline-variant rounded-lg p-5 flex flex-col md:flex-row gap-5 items-start md:items-center hover:border-primary-container/40 transition-colors group';
                
                itemDiv.innerHTML = `
                    <div class="bg-surface-container p-3 rounded-lg border border-outline-variant group-hover:border-primary-container/40 transition-colors flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary-container text-[24px]">${typeIcon}</span>
                    </div>
                    <div class="flex-1 space-y-1">
                        <div class="flex justify-between items-start">
                            <div class="flex items-center gap-3">
                                <h4 class="font-body-md font-semibold text-on-surface">${t.titulo || t.tipo}</h4>
                                <span class="font-label-caps text-[10px] px-2 py-0.5 rounded-sm uppercase ${badgeClass}">${t.tipo}</span>
                            </div>
                            <span class="font-label-caps text-label-caps text-on-surface-variant">${t.fechaDisplay}</span>
                        </div>
                        <p class="font-body-sm text-body-sm text-on-surface-variant">${t.nota || 'Sin notas descriptivas.'}</p>
                        <div class="flex items-center gap-1.5 pt-1 text-xs font-label-caps text-primary-container">
                            <span class="material-symbols-outlined text-[16px]">inventory_2</span>
                            <span>${eqSummary}</span>
                        </div>
                    </div>
                    <div class="flex gap-2 self-end md:self-center">
                        <button onclick="verDetalles(${t.id})" class="flex items-center justify-center p-2 border border-outline-variant hover:border-primary-container hover:text-primary-container text-on-surface-variant transition-colors rounded-sm" title="Ver Detalles">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                        </button>
                    </div>
                `;
                container.appendChild(itemDiv);
            });
        }

        // Create the default (first) equipment row inside the form
        function createInitialRow() {
            const container = document.getElementById('equipamientosRowsContainer');
            container.innerHTML = '';
            rowCounter = 1;

            const rowDiv = document.createElement('div');
            rowDiv.className = 'flex items-center gap-3 equipment-row';

            // Select Dropdown
            const select = document.createElement('select');
            select.className = 'w-2/3 bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors equipment-select';

            const defaultOpt = document.createElement('option');
            defaultOpt.value = '';
            defaultOpt.textContent = 'Seleccione equipamiento...';
            select.appendChild(defaultOpt);

            availableEquipments.forEach(eq => {
                const opt = document.createElement('option');
                opt.value = eq.id;
                opt.textContent = `${eq.name} (${eq.stock}u)`;
                opt.dataset.stock = eq.stock;
                select.appendChild(opt);
            });

            // Quantity Input
            const qtyInput = document.createElement('input');
            qtyInput.type = 'number';
            qtyInput.min = '1';
            qtyInput.placeholder = 'Cant.';
            qtyInput.className = 'w-1/3 bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors equipment-qty';

            // Align space
            const alignSpacer = document.createElement('div');
            alignSpacer.className = 'w-8 h-8 flex-shrink-0';

            rowDiv.appendChild(select);
            rowDiv.appendChild(qtyInput);
            rowDiv.appendChild(alignSpacer);

            container.appendChild(rowDiv);

            // Quantity limits dynamic bindings
            select.addEventListener('change', () => {
                const selectedOption = select.options[select.selectedIndex];
                const stock = parseInt(selectedOption.dataset.stock || '0');
                qtyInput.max = stock;
                if (stock === 0) {
                    qtyInput.value = '';
                    qtyInput.placeholder = 'Sin stock';
                    qtyInput.disabled = true;
                } else {
                    qtyInput.placeholder = 'Cant.';
                    qtyInput.disabled = false;
                }
                updateAvailableOptions();
            });
        }

        // Add additional dynamic equipment rows
        function addEquipmentRow() {
            rowCounter++;
            const rowId = `eq-row-${rowCounter}`;
            
            const container = document.getElementById('equipamientosRowsContainer');
            const rowDiv = document.createElement('div');
            rowDiv.id = rowId;
            rowDiv.className = 'flex items-center gap-3 equipment-row';

            // Select Dropdown
            const select = document.createElement('select');
            select.className = 'w-2/3 bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors equipment-select';
            select.required = true;

            const defaultOpt = document.createElement('option');
            defaultOpt.value = '';
            defaultOpt.textContent = 'Seleccione equipamiento...';
            select.appendChild(defaultOpt);

            availableEquipments.forEach(eq => {
                const opt = document.createElement('option');
                opt.value = eq.id;
                opt.textContent = `${eq.name} (${eq.stock}u)`;
                opt.dataset.stock = eq.stock;
                select.appendChild(opt);
            });

            // Quantity Input
            const qtyInput = document.createElement('input');
            qtyInput.type = 'number';
            qtyInput.min = '1';
            qtyInput.placeholder = 'Cant.';
            qtyInput.className = 'w-1/3 bg-background border border-outline-variant px-3 py-2 rounded-sm text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors equipment-qty';
            qtyInput.required = true;

            // Remove Button
            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'text-on-surface-variant hover:text-error transition-colors p-1 flex items-center justify-center flex-shrink-0';
            removeBtn.innerHTML = '<span class="material-symbols-outlined text-[20px]">delete</span>';
            removeBtn.title = 'Quitar';
            
            removeBtn.addEventListener('click', () => {
                rowDiv.remove();
                updateAvailableOptions();
            });

            rowDiv.appendChild(select);
            rowDiv.appendChild(qtyInput);
            rowDiv.appendChild(removeBtn);

            container.appendChild(rowDiv);

            // Quantity limits dynamic bindings
            select.addEventListener('change', () => {
                const selectedOption = select.options[select.selectedIndex];
                const stock = parseInt(selectedOption.dataset.stock || '0');
                qtyInput.max = stock;
                if (stock === 0) {
                    qtyInput.value = '';
                    qtyInput.placeholder = 'Sin stock';
                    qtyInput.disabled = true;
                } else {
                    qtyInput.placeholder = 'Cant.';
                    qtyInput.disabled = false;
                }
                updateAvailableOptions();
            });

            updateAvailableOptions();
        }

        // Dynamically disable selected options across other selects to prevent duplicates
        function updateAvailableOptions() {
            const selectedValues = Array.from(document.querySelectorAll('.equipment-select'))
                .map(sel => sel.value)
                .filter(val => val !== '');
                
            document.querySelectorAll('.equipment-select').forEach(currentSelect => {
                const currentValue = currentSelect.value;
                currentSelect.querySelectorAll('option').forEach(option => {
                    if (option.value !== '') {
                        if (selectedValues.includes(option.value) && option.value !== currentValue) {
                            option.disabled = true;
                        } else {
                            option.disabled = false;
                        }
                    }
                });
            });
        }

        // Save new treatment via AJAX
        const registrarForm = document.getElementById('registrarForm');
        registrarForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const titulo = document.getElementById('tituloTratamiento').value;
            const tipo = document.getElementById('tipoTratamiento').value;
            const nota = document.getElementById('notaTratamiento').value;
            
            if (!titulo) {
                showToast('El título del tratamiento es obligatorio.', 'error');
                return;
            }

            if (!tipo) {
                showToast('El tipo de tratamiento es obligatorio.', 'error');
                return;
            }
            
            const rows = document.querySelectorAll('.equipment-row');
            const equipamientos = [];
            const selectedIds = new Set();
            
            for (let i = 0; i < rows.length; i++) {
                const select = rows[i].querySelector('.equipment-select');
                const qtyInput = rows[i].querySelector('.equipment-qty');
                
                const eqId = select.value;
                const qtyVal = qtyInput.value;
                
                // Partially completed checks
                if ((eqId && !qtyVal) || (!eqId && qtyVal)) {
                    showToast('Si completa una fila de equipamiento, tanto el equipamiento como la cantidad son obligatorios.', 'error');
                    return;
                }
                
                if (eqId && qtyVal) {
                    const qty = parseInt(qtyVal);
                    const selectedOption = select.options[select.selectedIndex];
                    const stock = parseInt(selectedOption.dataset.stock || '0');
                    
                    if (qty <= 0) {
                        showToast('La cantidad debe ser mayor a cero.', 'error');
                        return;
                    }
                    if (stock === 0) {
                        showToast(`El equipamiento '${selectedOption.text}' no tiene stock disponible (0u).`, 'error');
                        return;
                    }
                    if (qty > stock) {
                        showToast(`La cantidad ingresada (${qty}u) supera el stock disponible (${stock}u) para ${selectedOption.text}.`, 'error');
                        return;
                    }
                    
                    if (selectedIds.has(eqId)) {
                        showToast('No puede seleccionar el mismo equipamiento más de una vez.', 'error');
                        return;
                    }
                    selectedIds.add(eqId);
                    
                    equipamientos.push({
                        equipmentId: parseInt(eqId),
                        cantidad: qty
                    });
                }
            }
            
            try {
                const response = await fetch('/Colmenas/RegistrarTratamiento', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        colmenaId: colmenaId,
                        titulo: titulo,
                        tipo: tipo,
                        nota: nota,
                        equipamientos: equipamientos
                    })
                });
                
                const res = await response.json();
                if (res.success) {
                    showToast(res.message, 'success');
                    
                    // Close modal
                    document.getElementById('registrarModal').classList.add('modal-hidden');
                    
                    await refreshEquipments();
                    await loadTreatments();
                } else {
                    showToast(res.errors ? res.errors.join('<br>') : 'Error al registrar el tratamiento.', 'error');
                }
            } catch (err) {
                showToast('Error de red al intentar registrar el tratamiento.', 'error');
                console.error(err);
            }
        });

        // View treatment details modal handler
        function verDetalles(id) {
            const t = treatments.find(x => x.id === id);
            if (!t) return;

            document.getElementById('detailTituloField').textContent = t.titulo || t.tipo;
            document.getElementById('detailFecha').textContent = t.fechaDisplay;
            document.getElementById('detailTipo').textContent = t.tipo;
            document.getElementById('detailNota').textContent = t.nota || 'Sin notas descriptivas.';

            const eqCont = document.getElementById('detailEquipamientosContainer');
            if (t.equipamientos && t.equipamientos.length > 0) {
                eqCont.innerHTML = t.equipamientos.map(eq => `
                    <div class="flex justify-between items-center bg-surface-container-high border border-outline-variant p-2.5 rounded-sm">
                        <span>${eq.name}</span>
                        <span class="font-label-caps text-primary-container font-semibold">${eq.cantidad}u</span>
                    </div>
                `).join('');
            } else {
                eqCont.innerHTML = '<div class="text-center py-2 text-on-surface-variant">Sin equipamientos utilizados.</div>';
            }

            document.getElementById('detallesModal').classList.remove('modal-hidden');
        }
    </script>
}
