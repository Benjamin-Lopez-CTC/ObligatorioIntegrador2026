@model ObligatorioIntegrador2026.Models.Colmena

@{
    ViewData["Title"] = "Detalle de Colmena";
    
    string statusHtml = "";
    string statusText = Model.Estado;
    if (Model.Estado == "Óptimo")
    {
        statusHtml = $"<span class=\"bg-surface-container-high border border-[#4CAF50] text-[#4CAF50] font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1\"><span class=\"material-symbols-outlined text-[14px]\" style=\"font-variation-settings: 'FILL' 1;\">check_circle</span>{statusText}</span>";
    }
    else if (Model.Estado == "Alerta")
    {
        statusHtml = $"<span class=\"bg-primary-container/10 border border-primary-container text-primary-container font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1\"><span class=\"material-symbols-outlined text-[14px]\" style=\"font-variation-settings: 'FILL' 1;\">info</span>{statusText}</span>";
    }
    else if (Model.Estado == "Crítico")
    {
        statusHtml = $"<span class=\"bg-error-container/5 border border-error text-error font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1\"><span class=\"material-symbols-outlined text-[14px]\" style=\"font-variation-settings: 'FILL' 1;\">warning</span>{statusText}</span>";
    }

    double precioPorKg = ObligatorioIntegrador2026.Models.GlobalSettings.PrecioMielActual;
    double valorTotal = Model.ProduccionMielKg * precioPorKg;

    double maxMielPorAlza = 22.0; // Cambiado a 22kg de acuerdo con la conversión aprobada
    double prodPercent = Math.Min(100, Math.Round((Model.ProduccionMielKg / maxMielPorAlza) * 100));

    var notasSorted = Model.NotasTecnicas?.OrderByDescending(n => n.Fecha).ToList() ?? new List<ObligatorioIntegrador2026.Models.NotaTecnica>();
    var ultimaNotaObj = notasSorted.FirstOrDefault();
    var notasRestantes = notasSorted.Skip(1).Take(2).ToList();

    string reinaLastSeen = ultimaNotaObj != null 
        ? $"Avistada hace {(int)(DateTime.Now - ultimaNotaObj.Fecha).TotalDays} días" 
        : "Sin datos recientes";
}

<main class="flex-grow w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 flex flex-col gap-10">
    <!-- Breadcrumb Context Bar -->
    <div class="w-full flex items-center gap-2 font-label-caps text-label-caps text-on-surface-variant mb-2">
        @if (ViewBag.FromApiarioId != null)
        {
            <a asp-controller="Apiarios" asp-action="Index" class="text-primary-container hover:text-primary-fixed transition-colors">Apiarios</a>
            <span class="text-primary-container font-bold">&gt;</span>
            <a asp-controller="Apiarios" asp-action="Detalles" asp-route-id="@ViewBag.FromApiarioId" class="text-primary-container hover:text-primary-fixed transition-colors">Detalle de Apiario</a>
            <span class="text-primary-container font-bold">&gt;</span>
        }
        else
        {
            <a asp-action="Index" class="text-primary-container hover:text-primary-fixed transition-colors">Colmenas</a>
            <span class="text-primary-container font-bold">&gt;</span>
        }
        <span class="text-on-surface">Detalle de Colmena</span>
    </div>

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-surface-container-highest pb-8">
        <div class="flex flex-col gap-4">
            <div class="flex items-center flex-wrap gap-4">
                <h1 class="font-display text-display md:text-[40px] text-[32px] text-primary-container break-words max-w-full">
                    @(string.IsNullOrEmpty(Model.Identificador) ? Model.CodigoEscaneo : Model.Identificador)
                </h1>
                @Html.Raw(statusHtml)
                @if (Model.EsPiloto)
                {
                    <span class="bg-surface-container-high border border-outline-variant text-on-surface font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">science</span>PILOTO</span>
                }
                @if (Model.EsNucleo)
                {
                    <span class="bg-surface-container-high border border-outline-variant text-on-surface font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">hive</span>NÚCLEO</span>
                }
            </div>
            <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl">
                Código de Escaneo: @Model.CodigoEscaneo <br/>
                @(Model.Estado == "Alerta" || Model.Estado == "Crítico" ? "Requiere inspección prioritaria debido a alertas activas." : "Inspección de rutina requerida según calendario.")
            </p>
        </div>
        <div class="flex flex-col sm:flex-row flex-wrap gap-4 w-full md:w-auto">

            <button id="btnOpenEdit" class="w-full sm:w-auto justify-center border border-primary-container text-primary-container font-label-caps text-label-caps px-6 py-3 rounded flex items-center gap-2 hover:bg-surface-container-high transition-colors whitespace-nowrap">
                <span class="material-symbols-outlined text-[18px]">edit</span>
                Editar Colmena
            </button>
            <button id="btnOpenRegistrar" class="w-full sm:w-auto justify-center flex items-center gap-2 px-6 py-3 bg-primary-container text-on-primary hover:bg-primary-fixed transition-colors rounded font-label-caps text-label-caps shadow-[0_0_15px_rgba(255,217,0,0.2)] whitespace-nowrap">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Registrar Nuevo Tratamiento
            </button>
            <button id="btnOpenNote" class="w-full sm:w-auto justify-center bg-primary-container text-on-primary font-label-caps text-label-caps px-6 py-3 rounded flex items-center gap-2 hover:bg-primary-fixed-dim transition-colors whitespace-nowrap">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Añadir Nota Técnica
            </button>
        </div>
    </div>

    <!-- Metrics Grid (Bento Style) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-unit">
        @if (Model.EsPiloto)
        {
            <!-- Temp -->
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-center text-primary-container">
                    <span class="material-symbols-outlined text-[24px]">thermostat</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">SENSOR T1</span>
                </div>
                <div>
                    <div class="font-display text-[32px] font-bold text-on-surface">@Model.TemperaturaInterna.ToString("0.0")°C</div>
                    <div class="font-body-sm text-body-sm @(Model.TemperaturaInterna < 30 || Model.TemperaturaInterna > 38 ? "text-error" : "text-on-surface-variant") mt-1">
                        @(Model.TemperaturaInterna < 30 || Model.TemperaturaInterna > 38 ? "Nivel Peligroso" : "Nivel estable")
                    </div>
                </div>
            </div>

            <!-- Humidity -->
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-center text-primary-container">
                    <span class="material-symbols-outlined text-[24px]">water_drop</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">SENSOR H1</span>
                </div>
                <div>
                    <div class="font-display text-[32px] font-bold text-on-surface">@Model.HumedadInterna.ToString("0.0")%</div>
                    <div class="font-body-sm text-body-sm @(Model.HumedadInterna < 40 || Model.HumedadInterna > 80 ? "text-error" : "text-on-surface-variant") mt-1">
                        @(Model.HumedadInterna < 40 || Model.HumedadInterna > 80 ? "Humedad Peligrosa" : "Humedad nominal")
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Población -->
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-center text-primary-container">
                    <span class="material-symbols-outlined text-[24px]">groups</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">POBLACIÓN</span>
                </div>
                <div>
                    <div class="font-display text-[32px] font-bold text-on-surface">@Model.CantidadAbejas.ToString("N0")</div>
                    <div class="font-body-sm text-body-sm text-on-surface-variant mt-1">Abejas aprox.</div>
                </div>
            </div>

            <!-- Peso Actual -->
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-center text-primary-container">
                    <span class="material-symbols-outlined text-[24px]">scale</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">PESO ACTUAL</span>
                </div>
                <div>
                    <div class="font-display text-[32px] font-bold text-on-surface">@Model.PesoKg.ToString("0.0") kg</div>
                    <div class="font-body-sm text-body-sm text-on-surface-variant mt-1">Peso total de la colmena</div>
                </div>
            </div>
        }

        <!-- Production -->
        <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group lg:col-span-1 md:col-span-2">
            <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
            <div class="flex justify-between items-center text-primary-container">
                <span class="material-symbols-outlined text-[24px]">hive</span>
                <span class="font-label-caps text-label-caps text-on-surface-variant">ESTIMACIÓN</span>
            </div>
            <div>
                <div class="font-display text-[32px] font-bold text-on-surface">@Model.ProduccionMielKg.ToString("0.0") kg</div>
                <div class="font-body-sm text-body-sm text-on-surface-variant mt-2 flex items-center gap-2">
                    <span class="">Alza completada al @prodPercent%</span>
                </div>
                <div class="w-full h-1 bg-[#333333] mt-3 rounded-full overflow-hidden">
                    <div class="h-full bg-primary-container" style="width: @prodPercent%"></div>
                </div>
            </div>
        </div>

        <!-- Queen Status -->
        <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
            <div class="flex justify-between items-center text-primary-container">
                <span class="material-symbols-outlined text-[24px]">workspace_premium</span>
                <span class="font-label-caps text-label-caps text-on-surface-variant">REINA</span>
            </div>
            <div>
                <div class="font-headline-lg text-headline-lg @(Model.EstadoReina == "Ausente" ? "text-error" : "text-on-surface")">@Model.EstadoReina</div>
                <div class="font-body-sm text-body-sm @(Model.EstadoReina == "Ausente" ? "text-error" : "text-on-surface-variant") mt-1">@reinaLastSeen</div>
            </div>
        </div>
    </div>

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-4">
        <!-- Left Column: Primary Info -->
        <div class="lg:col-span-1 flex flex-col gap-6">
            <h2 class="font-headline-lg text-[24px] text-on-surface border-b border-surface-container-highest pb-3">Información Principal</h2>
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-6">
                <div class="flex flex-col gap-1">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">UBICACIÓN</span>
                    <div class="flex items-center gap-2 text-on-surface">
                        <span class="material-symbols-outlined text-primary-container text-[20px]">location_on</span>
                        <span class="font-body-md text-body-md">@Model.Apiario.Nombre - @Model.UbicacionIntraApiario</span>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-surface-container-highest"></div>
                <div class="flex flex-col gap-1">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">POBLACIÓN ESTIMADA</span>
                    <div class="flex items-center gap-2 text-on-surface">
                        <span class="material-symbols-outlined text-primary-container text-[20px]">groups</span>
                        <span class="font-body-md text-body-md">~@Model.CantidadAbejas.ToString("N0") abejas</span>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-surface-container-highest"></div>
                <div class="flex flex-col gap-1">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">COMPORTAMIENTO</span>
                    <div class="flex items-center gap-2 text-on-surface">
                        <span class="material-symbols-outlined text-primary-container text-[20px]">psychology</span>
                        <span class="font-body-md text-body-md">@Model.ComportamientoAbejas</span>
                    </div>
                </div>
            </div>

            <div class="flex flex-col gap-6 mt-6">
                <h2 class="font-headline-lg text-[24px] text-on-surface border-b border-surface-container-highest pb-3">Valoración de Producción</h2>
                <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-6">
                    <div class="flex flex-col gap-1">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">PRECIO POR KILO</span>
                        <div class="flex items-center gap-2 text-on-surface">
                            <span class="material-symbols-outlined text-primary-container text-[20px]">payments</span>
                            <span class="font-body-md text-body-md">$@precioPorKg.ToString("0.00") / kg</span>
                        </div>
                    </div>
                    <div class="w-full h-[1px] bg-surface-container-highest"></div>
                    <div class="flex flex-col gap-1">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">VALOR TOTAL ESTIMADO</span>
                        <div class="flex items-center gap-2 text-on-surface">
                            <span class="material-symbols-outlined text-primary-container text-[20px]">account_balance_wallet</span>
                            <span class="font-body-md text-body-md font-bold">$@valorTotal.ToString("0.00")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Inspection History & Notes -->
        <div class="lg:col-span-2 flex flex-col gap-10">
            <!-- Tratamientos Recientes Section -->
            <div class="flex flex-col gap-6">
                <div class="flex justify-between items-end border-b border-surface-container-highest pb-3">
                    <h2 class="font-headline-lg text-[24px] text-on-surface">Tratamientos Recientes</h2>
                    <a asp-action="Tratamientos" asp-controller="Colmenas" asp-route-id="@Model.Id" asp-route-fromApiarioId="@ViewBag.FromApiarioId" class="font-label-caps text-label-caps text-primary-container hover:text-primary-fixed transition-colors uppercase">Ver historial completo</a>
                </div>
                <div class="flex flex-col gap-unit">
                    @if (ViewBag.Tratamientos != null)
                    {
                        var tratamientos = (IEnumerable<ObligatorioIntegrador2026.Models.Treatment>)ViewBag.Tratamientos;
                        if (tratamientos.Any())
                        {
                            foreach (var tratamiento in tratamientos)
                            {
                                <div class="bg-surface-container-low border border-outline-variant rounded p-5 flex flex-col md:flex-row gap-6 md:items-center hover:border-surface-container-high transition-colors">
                                    <div class="flex flex-col min-w-[120px]">
                                        <span class="font-label-caps text-label-caps text-on-surface uppercase">@tratamiento.Fecha.ToString("dd MMM yyyy")</span>
                                        <span class="font-body-sm text-body-sm text-on-surface-variant">@tratamiento.Fecha.ToString("HH:mm") hrs</span>
                                    </div>
                                    <div class="w-px h-12 bg-surface-container-highest hidden md:block"></div>
                                    <div class="flex-grow flex flex-col gap-2">
                                        <div class="flex items-center gap-3">
                                            <span class="font-body-md text-body-md font-semibold text-primary-container">@tratamiento.Titulo</span>
                                            <span class="bg-surface-container-high px-2 py-0.5 rounded text-[10px] font-label-caps text-on-surface-variant border border-outline-variant uppercase">@tratamiento.Tipo</span>
                                        </div>
                                        <p class="font-body-sm text-body-sm text-on-surface-variant">
                                            @(string.IsNullOrEmpty(tratamiento.Nota) ? "Sin observaciones adicionales." : tratamiento.Nota)
                                        </p>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-6 text-on-surface-variant font-body-sm">
                                No hay tratamientos recientes para esta colmena.
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Notas Tecnicas Section -->
            <div class="flex flex-col gap-6">
            <div class="flex justify-between items-end border-b border-surface-container-highest pb-3">
                <h2 class="font-headline-lg text-[24px] text-on-surface">Notas Técnicas</h2>
                <button id="btnOpenAllNotes" class="font-label-caps text-label-caps text-primary-container hover:text-primary-fixed transition-colors">VER TODAS LAS NOTAS</button>
            </div>
            
            
            @if (ultimaNotaObj != null)
            {
                <div class="bg-surface-container-low border-l-4 border-l-primary-container border border-outline-variant rounded p-5 flex flex-col md:flex-row gap-6 md:items-center hover:border-surface-container-high transition-colors">
                    <div class="flex flex-col min-w-[120px]">
                        <span class="font-label-caps text-label-caps text-on-surface">@ultimaNotaObj.Fecha.ToString("dd MMM yyyy").ToUpper()</span>
                        <span class="font-body-sm text-body-sm text-on-surface-variant">@ultimaNotaObj.Fecha.ToString("HH:mm") hrs</span>
                    </div>
                    <div class="w-px h-12 bg-surface-container-highest hidden md:block"></div>
                    <div class="flex-grow flex flex-col gap-2">
                        <div class="flex items-center gap-3">
                            <span class="font-body-md text-body-md font-semibold text-primary-container">Última Nota</span>
                            <span class="bg-primary-container/10 px-2 py-0.5 rounded text-[10px] font-label-caps text-primary-container border border-primary-container/30 uppercase">@ultimaNotaObj.EstadoColmena</span>
                        </div>
                        <p class="font-body-sm text-body-sm text-on-surface-variant">
                            @ultimaNotaObj.Detalles
                        </p>
                    </div>
                    <div class="flex flex-col items-end gap-1 text-on-surface-variant text-[10px] font-label-caps border-l border-surface-container-highest pl-4 hidden md:flex">
                        <span>Reina: @ultimaNotaObj.EstadoReina</span>
                        <span class="material-symbols-outlined text-[16px] text-primary-container mt-1">description</span>
                    </div>
                </div>

                @if (notasRestantes.Any())
                {
                    <div class="flex flex-col gap-unit mt-4">
                        @foreach (var nota in notasRestantes)
                        {
                            <div class="bg-surface-container-low border border-outline-variant rounded p-5 flex flex-col md:flex-row gap-6 md:items-center hover:border-surface-container-high transition-colors opacity-70">
                                <div class="flex flex-col min-w-[120px]">
                                    <span class="font-label-caps text-label-caps text-on-surface">@nota.Fecha.ToString("dd MMM yyyy").ToUpper()</span>
                                    <span class="font-body-sm text-body-sm text-on-surface-variant">@nota.Fecha.ToString("HH:mm") hrs</span>
                                </div>
                                <div class="w-px h-12 bg-surface-container-highest hidden md:block"></div>
                                <div class="flex-grow flex flex-col gap-2">
                                    <div class="flex items-center gap-3">
                                        <span class="font-body-md text-body-md font-semibold text-primary-container">Registro Histórico</span>
                                        <span class="bg-surface-container-high px-2 py-0.5 rounded text-[10px] font-label-caps text-on-surface-variant border border-outline-variant uppercase">@nota.EstadoColmena</span>
                                    </div>
                                    <p class="font-body-sm text-body-sm text-on-surface-variant line-clamp-2">
                                        @nota.Detalles
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="text-center py-6 text-on-surface-variant font-body-sm">
                    No hay notas técnicas registradas para esta colmena.
                </div>
            }
        </div>
    </div>
</div>

    <div class="w-full flex justify-center mt-8 pt-8 border-t border-surface-container-highest">
        <button onclick="openDeleteModal()" class="mx-auto w-fit border border-error text-error font-label-caps text-label-caps px-6 py-3 rounded flex items-center gap-2 hover:bg-error/10 transition-colors whitespace-nowrap">
            <span class="material-symbols-outlined text-[18px]">delete</span>
            Eliminar Colmena
        </button>
    </div>
</main>

<!-- Delete Modal -->
<div id="deleteModal" class="fixed inset-0 z-[60] flex items-center justify-center modal-backdrop bg-black/85 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-md modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-error flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">delete_forever</span> ¿Eliminar Colmena?
            </h4>
            <button type="button" id="btnCancelDeleteIcon" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar space-y-4 text-center">
            <p class="font-body-md text-body-md text-on-surface-variant">
                ¿Está seguro de que desea eliminar la colmena <span class="text-error font-semibold">@(string.IsNullOrEmpty(Model.Identificador) ? Model.CodigoEscaneo : Model.Identificador)</span>?
            </p>
            <p class="text-sm text-error/80 font-medium">
                Esta acción es irreversible y los datos se perderán.
            </p>
            <div class="pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-center gap-3 mt-4">
                <button type="button" id="btnCancelDelete" class="border border-outline text-on-surface hover:bg-surface-container-high transition-colors px-5 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                    Cancelar
                </button>
                <form asp-action="Eliminar" asp-controller="Colmenas" method="post" class="m-0 w-full sm:w-auto flex">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="bg-error-container/30 border border-error text-error hover:bg-error/20 transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full text-center justify-center flex">
                        Sí, eliminarla
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Add Note Modal -->
