@model ObligatorioIntegrador2026.Models.Colmena

@{
    ViewData["Title"] = "Detalle de Colmena";
    
    string apiarioNombre = Model.Apiario?.Nombre ?? "Sin Apiario";
    string statusHtml = $"<span class=\"bg-surface-container-high border border-outline-variant text-on-surface font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1\"><span class=\"material-symbols-outlined text-[14px]\">location_on</span>{apiarioNombre}</span>";

    double precioPorKg = ObligatorioIntegrador2026.Models.GlobalSettings.PrecioMielActual;
    double valorTotal = Model.ProduccionMielKg * precioPorKg;

    double maxMielTotal = (Model.Alzas * 22.0) + (Model.AlzasTresCuartos * 17.0) + (Model.MediasAlzas * 12.0);
    double prodPercent = maxMielTotal > 0 ? Math.Min(100, Math.Round((Model.ProduccionMielKg / maxMielTotal) * 100)) : 0;

    var notasSorted = Model.NotasTecnicas?.OrderByDescending(n => n.Fecha).ToList() ?? new List<ObligatorioIntegrador2026.Models.NotaTecnica>();
    var ultimaNotaObj = notasSorted.FirstOrDefault();
    var notasRestantes = notasSorted.Skip(1).Take(2).ToList();

    string reinaLastSeen = ultimaNotaObj != null 
        ? $"Avistada hace {(int)(DateTime.Now - ultimaNotaObj.Fecha).TotalDays} días" 
        : "Sin datos recientes";

    List<string> razonesEstado = new List<string>();
    if (Model.Estado == "Crítico")
    {
        var ultimaNotaCritica = Model.NotasTecnicas?.OrderByDescending(n => n.Fecha).FirstOrDefault(n => n.EstadoColmena == "Crítico");
        if (ultimaNotaCritica != null)
        {
            razonesEstado.Add($"Definido manualmente como Crítico en la inspección del {ultimaNotaCritica.Fecha:dd/MM/yyyy}: \"{ultimaNotaCritica.Detalles}\"");
        }
        else
        {
            razonesEstado.Add("El estado fue definido como Crítico en la última inspección técnica.");
        }
    }
    else if (Model.Estado == "Alerta")
    {
        if (Model.EsPiloto && (Model.TemperaturaInterna < 30 || Model.TemperaturaInterna > 38))
        {
            razonesEstado.Add($"Temperatura fuera de rango óptimo (30°C - 38°C). Valor actual: {Model.TemperaturaInterna:0.0}°C.");
        }
        if (Model.EsPiloto && (Model.HumedadInterna < 40 || Model.HumedadInterna > 80))
        {
            razonesEstado.Add($"Humedad fuera de rango óptimo (40% - 80%). Valor actual: {Model.HumedadInterna:0.0}%.");
        }
        if (Model.EstadoReina == "Ausente")
        {
            razonesEstado.Add("La reina está ausente en la colmena.");
        }
        if (Model.NotasTecnicas == null || !Model.NotasTecnicas.Any())
        {
            razonesEstado.Add("No se han registrado inspecciones técnicas aún en el sistema.");
        }
        else
        {
            var ultimaNota = Model.NotasTecnicas.OrderByDescending(n => n.Fecha).First();
            if ((DateTime.Now - ultimaNota.Fecha).TotalDays > 30)
            {
                razonesEstado.Add($"Han transcurrido {(int)(DateTime.Now - ultimaNota.Fecha).TotalDays} días desde la última inspección (límite máximo: 30 días).");
            }
        }
        
        if (!razonesEstado.Any())
        {
            var ultimaNotaAlerta = Model.NotasTecnicas?.OrderByDescending(n => n.Fecha).FirstOrDefault(n => n.EstadoColmena == "Alerta");
            if (ultimaNotaAlerta != null)
            {
                razonesEstado.Add($"Definido manualmente como Alerta en la inspección del {ultimaNotaAlerta.Fecha:dd/MM/yyyy}: \"{ultimaNotaAlerta.Detalles}\"");
            }
            else
            {
                razonesEstado.Add("El estado fue definido como Alerta en la última inspección técnica.");
            }
        }
    }
    else
    {
        razonesEstado.Add("Todos los indicadores están en niveles adecuados: reina presente, inspecciones periódicas al día y sensores dentro de los límites establecidos.");
    }
}

<main class="flex-grow w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 flex flex-col gap-10">
    <!-- Breadcrumb Context Bar -->
    <div class="w-full flex items-center gap-2 font-label-caps text-label-caps text-on-surface-variant mb-2">
        @if (ViewBag.FromApiarioId != null)
        {
            <a asp-controller="Apiarios" asp-action="Index" class="text-primary-container hover:text-primary-fixed transition-colors">Apiarios</a>
            <span class="text-primary-container font-bold">&gt;</span>
            <a asp-controller="Apiarios" asp-action="Detalles" asp-route-id="@ViewBag.FromApiarioId" class="text-primary-container hover:text-primary-fixed transition-colors">Detalle de Apiario</a>
            <span class="text-primary-container font-bold">&gt;</span>
        }
        else
        {
            <a asp-action="Index" class="text-primary-container hover:text-primary-fixed transition-colors">Colmenas</a>
            <span class="text-primary-container font-bold">&gt;</span>
        }
        <span class="text-on-surface">Detalle de Colmena</span>
    </div>

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 border-b border-surface-container-highest pb-8">
        <div class="flex flex-col gap-2">
            <div class="flex items-center flex-wrap gap-4">
                <h1 class="font-display text-display md:text-[40px] text-[32px] text-primary-container break-words max-w-full">
                    @(string.IsNullOrEmpty(Model.Identificador) ? Model.CodigoEscaneo : Model.Identificador)
                </h1>
                @Html.Raw(statusHtml)
                @if (Model.EsPiloto)
                {
                    <span class="bg-surface-container-high border border-outline-variant text-on-surface font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">science</span>PILOTO</span>
                }
                @if (Model.EsNucleo)
                {
                    <span class="bg-surface-container-high border border-outline-variant text-on-surface font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">hive</span>NÚCLEO</span>
                }
                @if (ViewBag.EsTemporal == true)
                {
                    <span class="bg-primary-container/20 border border-primary-container text-on-surface font-label-caps text-label-caps px-2 py-1 rounded uppercase flex items-center gap-1" title="Pertenece al apiario de origen: @ViewBag.ApiarioOrigenNombre"><span class="material-symbols-outlined text-[14px]">local_shipping</span>TEMPORAL</span>
                }
            </div>
            <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl">
                Código de Escaneo: @Model.CodigoEscaneo
            </p>
        </div>
        <div class="flex flex-col sm:flex-row flex-wrap gap-4 w-full md:w-auto">
            <button id="btnOpenEdit" class="w-full sm:w-auto justify-center border border-primary-container text-primary-container font-label-caps text-label-caps px-6 py-3 rounded flex items-center gap-2 hover:bg-surface-container-high transition-colors whitespace-nowrap">
                <span class="material-symbols-outlined text-[18px]">edit</span>
                Editar Colmena
            </button>
            <button id="btnOpenRegistrar" class="w-full sm:w-auto justify-center flex items-center gap-2 px-6 py-3 bg-primary-container text-on-primary hover:bg-primary-fixed transition-colors rounded font-label-caps text-label-caps shadow-[0_0_15px_rgba(255,217,0,0.2)] whitespace-nowrap">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Registrar Nuevo Tratamiento
            </button>
            <button id="btnOpenNote" class="w-full sm:w-auto justify-center bg-primary-container text-on-primary font-label-caps text-label-caps px-6 py-3 rounded flex items-center gap-2 hover:bg-primary-fixed-dim transition-colors whitespace-nowrap">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Añadir Nota Técnica
            </button>
        </div>
    </div>

    <!-- Diagnóstico de Estado -->
    <div class="p-4 rounded border flex items-start gap-3 w-full text-left @(Model.Estado == "Óptimo" ? "bg-[#4CAF50]/10 border-[#4CAF50]/30 text-[#4CAF50]" : Model.Estado == "Alerta" ? "bg-primary-container/10 border-primary-container/30 text-on-surface" : "bg-error-container/10 border-error/30 text-error") font-body-sm text-body-sm">
        <span class="material-symbols-outlined shrink-0 @(Model.Estado == "Óptimo" ? "text-[#4CAF50]" : Model.Estado == "Alerta" ? "text-primary-container" : "text-error") text-[20px]">
            @(Model.Estado == "Óptimo" ? "check_circle" : Model.Estado == "Alerta" ? "info" : "warning")
        </span>
        <div>
            <h4 class="font-label-caps text-label-caps font-bold mb-1">Diagnóstico de Estado: @Model.Estado</h4>
            <ul class="list-disc pl-4 space-y-1">
                @foreach (var razon in razonesEstado)
                {
                    <li>@razon</li>
                }
            </ul>
        </div>
    </div>

    @if (ViewBag.EsTemporal == true)
    {
        <div class="p-4 rounded border flex items-start gap-3 w-full text-left bg-primary-container/10 border-primary-container/30 text-on-surface font-body-sm text-body-sm">
            <span class="material-symbols-outlined shrink-0 text-primary-container text-[20px]">
                local_shipping
            </span>
            <div>
                <h4 class="font-label-caps text-label-caps font-bold mb-1">Traslado Temporal Activo</h4>
                <p>Esta colmena está temporalmente en el apiario <strong>@Model.Apiario?.Nombre</strong> por motivo de un movimiento. Su apiario de origen es <strong>@ViewBag.ApiarioOrigenNombre</strong>. Debe retornar una vez finalizado el movimiento.</p>
            </div>
        </div>
    }
       <!-- Metrics Grid (Bento Style) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-unit">
        @if (Model.EsPiloto)
        {
            <!-- Temp -->
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-center text-primary-container">
                    <span class="material-symbols-outlined text-[24px]">thermostat</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">SENSOR T1</span>
                </div>
                <div>
                    <div class="font-display text-[32px] font-bold text-on-surface">@Model.TemperaturaInterna.ToString("0.0")°C</div>
                    <div class="font-body-sm text-body-sm @(Model.TemperaturaInterna < 30 || Model.TemperaturaInterna > 38 ? "text-error" : "text-on-surface-variant") mt-1">
                        @(Model.TemperaturaInterna < 30 || Model.TemperaturaInterna > 38 ? "Nivel Peligroso" : "Nivel estable")
                    </div>
                </div>
            </div>

            <!-- Humidity -->
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-center text-primary-container">
                    <span class="material-symbols-outlined text-[24px]">water_drop</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">SENSOR H1</span>
                </div>
                <div>
                    <div class="font-display text-[32px] font-bold text-on-surface">@Model.HumedadInterna.ToString("0.0")%</div>
                    <div class="font-body-sm text-body-sm @(Model.HumedadInterna < 40 || Model.HumedadInterna > 80 ? "text-error" : "text-on-surface-variant") mt-1">
                        @(Model.HumedadInterna < 40 || Model.HumedadInterna > 80 ? "Humedad Peligrosa" : "Humedad nominal")
                    </div>
                </div>
            </div>
        }

        @if (!Model.EsPiloto)
        {
            <!-- Población -->
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-center text-primary-container">
                    <span class="material-symbols-outlined text-[24px]">groups</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">POBLACIÓN</span>
                </div>
                <div>
                    <div class="font-display text-[32px] font-bold text-on-surface">@Model.CantidadAbejas.ToString("N0")</div>
                    <div class="font-body-sm text-body-sm text-on-surface-variant mt-1">Abejas aprox.</div>
                </div>
            </div>

            <!-- Peso Actual -->
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-center text-primary-container">
                    <span class="material-symbols-outlined text-[24px]">scale</span>
                    <span class="font-label-caps text-label-caps text-on-surface-variant">PESO ACTUAL</span>
                </div>
                <div>
                    <div class="font-display text-[32px] font-bold text-on-surface">@Model.PesoKg.ToString("0.0") kg</div>
                    <div class="font-body-sm text-body-sm text-on-surface-variant mt-1">Peso total de la colmena</div>
                </div>
            </div>
        }

        <!-- Current Honey / Miel Actual -->
        <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
            <div class="flex justify-between items-center text-primary-container">
                <span class="material-symbols-outlined text-[24px]">hive</span>
                <span class="font-label-caps text-label-caps text-on-surface-variant">MIEL ACTUAL</span>
            </div>
            <div>
                <div class="font-display text-[32px] font-bold text-on-surface">@Model.ProduccionMielKg.ToString("0.0") kg</div>
                <div class="font-body-sm text-body-sm text-on-surface-variant mt-2 flex items-center gap-2">
                    <span class="">Capacidad completada al @prodPercent%</span>
                </div>
                <div class="w-full h-1 bg-[#333333] mt-3 rounded-full overflow-hidden">
                    <div class="h-full bg-primary-container" style="width: @prodPercent%"></div>
                </div>
            </div>
        </div>

        <!-- Total Honey Produced / Miel Producida -->
        <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
            <div class="flex justify-between items-center text-primary-container">
                <span class="material-symbols-outlined text-[24px]">history</span>
                <span class="font-label-caps text-label-caps text-on-surface-variant">MIEL PRODUCIDA</span>
            </div>
            <div>
                <div class="font-display text-[32px] font-bold text-on-surface">@(Model.NotasTecnicas?.Sum(n => n.KilosCosechados).ToString("0.0") ?? "0.0") kg</div>
                <div class="font-body-sm text-body-sm text-on-surface-variant mt-1">Total cosechado históricamente</div>
            </div>
        </div>

        <!-- Queen Status -->
        <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-4 hover:border-primary-container transition-colors relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-1 h-full bg-surface-container-high group-hover:bg-primary-container transition-colors"></div>
            <div class="flex justify-between items-center text-primary-container">
                <span class="material-symbols-outlined text-[24px]">workspace_premium</span>
                <span class="font-label-caps text-label-caps text-on-surface-variant">REINA</span>
            </div>
            <div>
                <div class="font-headline-lg text-headline-lg @(Model.EstadoReina == "Ausente" ? "text-error" : "text-on-surface")">@Model.EstadoReina</div>
                <div class="font-body-sm text-body-sm @(Model.EstadoReina == "Ausente" ? "text-error" : "text-on-surface-variant") mt-1">@reinaLastSeen</div>
            </div>
        </div>
    </div>

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-4">
        <!-- Left Column: Primary Info -->
        <div class="lg:col-span-1 flex flex-col gap-6">
            <h2 class="font-headline-lg text-[24px] text-on-surface border-b border-surface-container-highest pb-3">Información Principal</h2>
            <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-6">
                <div class="flex flex-col gap-1">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">UBICACIÓN</span>
                    <div class="flex items-center gap-2 text-on-surface">
                        <span class="material-symbols-outlined text-primary-container text-[20px]">location_on</span>
                        <span class="font-body-md text-body-md">@Model.Apiario?.Nombre - @Model.UbicacionIntraApiario</span>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-surface-container-highest"></div>
                <div class="flex flex-col gap-1">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">POBLACIÓN ESTIMADA</span>
                    <div class="flex items-center gap-2 text-on-surface">
                        <span class="material-symbols-outlined text-primary-container text-[20px]">groups</span>
                        <span class="font-body-md text-body-md">~@Model.CantidadAbejas.ToString("N0") abejas</span>
                    </div>
                </div>
                @if (Model.EsPiloto)
                {
                    <div class="w-full h-[1px] bg-surface-container-highest"></div>
                    <div class="flex flex-col gap-1">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">PESO ACTUAL</span>
                        <div class="flex items-center gap-2 text-on-surface">
                            <span class="material-symbols-outlined text-primary-container text-[20px]">scale</span>
                            <span class="font-body-md text-body-md">@Model.PesoKg.ToString("0.0") kg</span>
                        </div>
                    </div>
                }
                <div class="w-full h-[1px] bg-surface-container-highest"></div>
                <div class="flex flex-col gap-1">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">COMPORTAMIENTO</span>
                    <div class="flex items-center gap-2 text-on-surface">
                        <span class="material-symbols-outlined text-primary-container text-[20px]">psychology</span>
                        <span class="font-body-md text-body-md">@Model.ComportamientoAbejas</span>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-surface-container-highest"></div>
                <div class="flex flex-col gap-1">
                    <span class="font-label-caps text-label-caps text-on-surface-variant">ALZAS INSTALADAS</span>
                    @if (!Model.EsNucleo)
                    {
                        <div class="flex flex-col gap-1.5 font-body-sm text-body-sm text-on-surface">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary-container text-[18px]">layers</span>
                                <span>Alzas Enteras: <strong>@Model.Alzas</strong></span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary-container text-[18px]">layers</span>
                                <span>Alzas 3/4: <strong>@Model.AlzasTresCuartos</strong></span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary-container text-[18px]">layers</span>
                                <span>Medias Alzas: <strong>@Model.MediasAlzas</strong></span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="flex items-center gap-2 text-on-surface-variant/70">
                            <span class="material-symbols-outlined text-[18px]">layers_clear</span>
                            <span class="font-body-sm text-body-sm">No permitido (Colmena Núcleo)</span>
                        </div>
                    }
                </div>
            </div>

            <div class="flex flex-col gap-6 mt-6">
                <h2 class="font-headline-lg text-[24px] text-on-surface border-b border-surface-container-highest pb-3">Valoración de Producción</h2>
                <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col gap-6">
                    <div class="flex flex-col gap-1">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">PRECIO POR KILO</span>
                        <div class="flex items-center gap-2 text-on-surface">
                            <span class="material-symbols-outlined text-primary-container text-[20px]">payments</span>
                            <span class="font-body-md text-body-md">$@precioPorKg.ToString("0.00") / kg</span>
                        </div>
                    </div>
                    <div class="w-full h-[1px] bg-surface-container-highest"></div>
                    <div class="flex flex-col gap-1">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">VALOR TOTAL ESTIMADO</span>
                        <div class="flex items-center gap-2 text-on-surface">
                            <span class="material-symbols-outlined text-primary-container text-[20px]">account_balance_wallet</span>
                            <span class="font-body-md text-body-md font-bold">$@valorTotal.ToString("0.00")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Inspection History & Notes -->
        <div class="lg:col-span-2 flex flex-col gap-10">
            <!-- Tratamientos Recientes Section -->
            <div class="flex flex-col gap-6">
                <div class="flex justify-between items-end border-b border-surface-container-highest pb-3">
                    <h2 class="font-headline-lg text-[24px] text-on-surface">Tratamientos Recientes</h2>
                    <a asp-action="Tratamientos" asp-controller="Colmenas" asp-route-id="@Model.Id" asp-route-fromApiarioId="@ViewBag.FromApiarioId" class="font-label-caps text-label-caps text-primary-container hover:text-primary-fixed transition-colors uppercase">Ver historial completo</a>
                </div>
                <div class="flex flex-col gap-unit">
                    @if (ViewBag.Tratamientos != null)
                    {
                        var tratamientos = (IEnumerable<ObligatorioIntegrador2026.Models.Treatment>)ViewBag.Tratamientos;
                        if (tratamientos.Any())
                        {
                            foreach (var tratamiento in tratamientos)
                            {
                                <div class="bg-surface-container-low border border-outline-variant rounded p-5 flex flex-col md:flex-row gap-6 md:items-center hover:border-surface-container-high transition-colors">
                                    <div class="flex flex-col min-w-[120px]">
                                        <span class="font-label-caps text-label-caps text-on-surface uppercase">@tratamiento.Fecha.ToString("dd MMM yyyy")</span>
                                        <span class="font-body-sm text-body-sm text-on-surface-variant">@tratamiento.Fecha.ToString("HH:mm") hrs</span>
                                    </div>
                                    <div class="w-px h-12 bg-surface-container-highest hidden md:block"></div>
                                    <div class="flex-grow flex flex-col gap-2">
                                        <div class="flex items-center gap-3">
                                            <span class="font-body-md text-body-md font-semibold text-primary-container">@tratamiento.Titulo</span>
                                            <span class="bg-surface-container-high px-2 py-0.5 rounded text-[10px] font-label-caps text-on-surface-variant border border-outline-variant uppercase">@tratamiento.Tipo</span>
                                        </div>
                                        <p class="font-body-sm text-body-sm text-on-surface-variant">
                                            @(string.IsNullOrEmpty(tratamiento.Nota) ? "Sin observaciones adicionales." : tratamiento.Nota)
                                        </p>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-6 text-on-surface-variant font-body-sm">
                                No hay tratamientos recientes para esta colmena.
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Notas Tecnicas Section -->
            <div class="flex flex-col gap-6">
            <div class="flex justify-between items-end border-b border-surface-container-highest pb-3">
                <h2 class="font-headline-lg text-[24px] text-on-surface">Notas Técnicas</h2>
                <button id="btnOpenAllNotes" class="font-label-caps text-label-caps text-primary-container hover:text-primary-fixed transition-colors">VER TODAS LAS NOTAS</button>
            </div>
            
            
            @if (ultimaNotaObj != null)
            {
                <div class="bg-surface-container-low border-l-4 border-l-primary-container border border-outline-variant rounded p-5 flex flex-col md:flex-row gap-6 md:items-center hover:border-surface-container-high transition-colors">
                    <div class="flex flex-col min-w-[120px]">
                        <span class="font-label-caps text-label-caps text-on-surface">@ultimaNotaObj.Fecha.ToString("dd MMM yyyy").ToUpper()</span>
                        <span class="font-body-sm text-body-sm text-on-surface-variant">@ultimaNotaObj.Fecha.ToString("HH:mm") hrs</span>
                    </div>
                    <div class="w-px h-12 bg-surface-container-highest hidden md:block"></div>
                    <div class="flex-grow flex flex-col gap-2">
                        <div class="flex items-center gap-3">
                            <span class="font-body-md text-body-md font-semibold text-primary-container">@(ultimaNotaObj.KilosCosechados > 0 ? "Última Cosecha / Extracción" : "Última Nota")</span>
                        </div>
                        @if (ultimaNotaObj.KilosCosechados > 0)
                        {
                            <div class="flex items-center gap-1 text-[11px] font-bold text-primary-container bg-primary-container/10 px-2 py-0.5 border border-primary-container/30 rounded w-fit mt-1">
                                <span class="material-symbols-outlined text-[14px]">shopping_bag</span>
                                Miel cosechada: @ultimaNotaObj.KilosCosechados.ToString("0.0") kg (Enteras: @ultimaNotaObj.AlzasCosechadas, 3/4: @ultimaNotaObj.AlzasTresCuartosCosechadas, Medias: @ultimaNotaObj.MediasAlzasCosechadas)
                            </div>
                        }
                        <p class="font-body-sm text-body-sm text-on-surface-variant">
                            @ultimaNotaObj.Detalles
                        </p>
                    </div>
                    <div class="flex flex-col items-end gap-1 text-on-surface-variant text-[10px] font-label-caps border-l border-surface-container-highest pl-4 hidden md:flex min-w-[120px]">
                        <span>Reina: @ultimaNotaObj.EstadoReina</span>
                        @if (ultimaNotaObj.Temperatura.HasValue) { <span>Temp: @ultimaNotaObj.Temperatura.Value.ToString("0.0")°C</span> }
                        @if (ultimaNotaObj.Humedad.HasValue) { <span>Hum: @ultimaNotaObj.Humedad.Value.ToString("0.0")%</span> }
                        @if (ultimaNotaObj.KilosCosechados > 0) { <span class="text-primary-container font-semibold">Cosechó @ultimaNotaObj.KilosCosechados.ToString("0.0") kg</span> }
                    </div>
                </div>

                @if (notasRestantes.Any())
                {
                    <div class="flex flex-col gap-unit mt-4">
                        @foreach (var nota in notasRestantes)
                        {
                            <div class="bg-surface-container-low border border-outline-variant rounded p-5 flex flex-col md:flex-row gap-6 md:items-center hover:border-surface-container-high transition-colors opacity-70">
                                <div class="flex flex-col min-w-[120px]">
                                    <span class="font-label-caps text-label-caps text-on-surface">@nota.Fecha.ToString("dd MMM yyyy").ToUpper()</span>
                                    <span class="font-body-sm text-body-sm text-on-surface-variant">@nota.Fecha.ToString("HH:mm") hrs</span>
                                </div>
                                <div class="w-px h-12 bg-surface-container-highest hidden md:block"></div>
                                <div class="flex-grow flex flex-col gap-2">
                                    <div class="flex items-center gap-3">
                                        <span class="font-body-md text-body-md font-semibold text-primary-container">@(nota.KilosCosechados > 0 ? "Registro de Cosecha / Extracción" : "Registro Histórico")</span>
                                    </div>
                                    @if (nota.KilosCosechados > 0)
                                    {
                                        <div class="flex items-center gap-1 text-[11px] font-bold text-primary-container bg-primary-container/10 px-2 py-0.5 border border-primary-container/30 rounded w-fit mt-1">
                                            <span class="material-symbols-outlined text-[14px]">shopping_bag</span>
                                            Miel cosechada: @nota.KilosCosechados.ToString("0.0") kg (Enteras: @nota.AlzasCosechadas, 3/4: @nota.AlzasTresCuartosCosechadas, Medias: @nota.MediasAlzasCosechadas)
                                        </div>
                                    }
                                    <p class="font-body-sm text-body-sm text-on-surface-variant line-clamp-2">
                                        @nota.Detalles
                                    </p>
                                </div>
                                <div class="flex flex-col items-end gap-1 text-on-surface-variant text-[10px] font-label-caps border-l border-surface-container-highest pl-4 hidden md:flex min-w-[120px]">
                                    <span>Reina: @nota.EstadoReina</span>
                                    @if (nota.Temperatura.HasValue) { <span>Temp: @nota.Temperatura.Value.ToString("0.0")°C</span> }
                                    @if (nota.Humedad.HasValue) { <span>Hum: @nota.Humedad.Value.ToString("0.0")%</span> }
                                    @if (nota.KilosCosechados > 0) { <span class="text-primary-container font-semibold">Cosechó @nota.KilosCosechados.ToString("0.0") kg</span> }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="text-center py-6 text-on-surface-variant font-body-sm">
                    No hay notas técnicas registradas para esta colmena.
                </div>
            }
        </div>
    </div>
</div>

    <div class="w-full flex justify-center mt-8 pt-8 border-t border-surface-container-highest">
        <button onclick="openDeleteModal()" class="mx-auto w-fit border border-error text-error font-label-caps text-label-caps px-6 py-3 rounded flex items-center gap-2 hover:bg-error/10 transition-colors whitespace-nowrap">
            <span class="material-symbols-outlined text-[18px]">delete</span>
            Eliminar Colmena
        </button>
    </div>
</main>

<!-- Delete Modal -->
<div id="deleteModal" class="fixed inset-0 z-[60] flex items-center justify-center modal-backdrop bg-black/85 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-md modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-error flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">delete_forever</span> ¿Eliminar Colmena?
            </h4>
            <button type="button" id="btnCancelDeleteIcon" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar space-y-4 text-center">
            <p class="font-body-md text-body-md text-on-surface-variant">
                ¿Está seguro de que desea eliminar la colmena <span class="text-error font-semibold">@(string.IsNullOrEmpty(Model.Identificador) ? Model.CodigoEscaneo : Model.Identificador)</span>?
            </p>
            <p class="text-sm text-error/80 font-medium">
                Esta acción es irreversible y los datos se perderán.
            </p>
            <div class="pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-center gap-3 mt-4">
                <button type="button" id="btnCancelDelete" class="border border-outline text-on-surface hover:bg-surface-container-high transition-colors px-5 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                    Cancelar
                </button>
                <form asp-action="Eliminar" asp-controller="Colmenas" method="post" class="m-0 w-full sm:w-auto flex">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="bg-error-container/30 border border-error text-error hover:bg-error/20 transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full text-center justify-center flex">
                        Sí, eliminarla
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Add Note Modal -->
<div id="noteModal" class="fixed inset-0 z-50 flex items-center justify-center modal-backdrop bg-black/85 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-2xl modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface">Añadir Nota Técnica</h4>
            <button type="button" id="btnCancelNoteIcon" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar">
            <form asp-action="AñadirNotaTecnica" method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                
                <div>
                    <label for="detalles" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Detalles de la Nota</label>
                    <textarea id="detalles" name="detalles" rows="4" required class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors resize-none" placeholder="Observaciones generales..."></textarea>
                </div>
                @if (Model.EsPiloto)
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label for="temperatura" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Temperatura (°C)</label>
                            <input type="number" step="0.1" id="temperatura" name="temperatura" value="@Model.TemperaturaInterna.ToString(System.Globalization.CultureInfo.InvariantCulture)" required class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                        </div>
                        <div>
                            <label for="humedad" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Humedad (%)</label>
                            <input type="number" step="0.1" id="humedad" name="humedad" value="@Model.HumedadInterna.ToString(System.Globalization.CultureInfo.InvariantCulture)" required class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                        </div>
                    </div>
                }

                <div class="bg-surface-container-low border border-outline-variant rounded p-4">
                    <h5 class="font-label-caps text-label-caps text-on-surface-variant mb-3">Registro de Cosecha (Opcional)</h5>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
                        <div>
                            <label for="alzasCosechadas" class="font-label-caps text-[10px] text-on-surface-variant mb-1 block truncate">Alzas Enteras</label>
                            <input type="number" id="alzasCosechadas" name="alzasCosechadas" value="0" min="0" max="@Model.Alzas" class="w-full bg-background border border-outline-variant px-2 py-1.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                        </div>
                        <div>
                            <label for="alzasTresCuartosCosechadas" class="font-label-caps text-[10px] text-on-surface-variant mb-1 block truncate">Alzas 3/4</label>
                            <input type="number" id="alzasTresCuartosCosechadas" name="alzasTresCuartosCosechadas" value="0" min="0" max="@Model.AlzasTresCuartos" class="w-full bg-background border border-outline-variant px-2 py-1.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                        </div>
                        <div>
                            <label for="mediasAlzasCosechadas" class="font-label-caps text-[10px] text-on-surface-variant mb-1 block truncate">Medias Alzas</label>
                            <input type="number" id="mediasAlzasCosechadas" name="mediasAlzasCosechadas" value="0" min="0" max="@Model.MediasAlzas" class="w-full bg-background border border-outline-variant px-2 py-1.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label for="estadoReina" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Estado de la Reina</label>
                        <select id="estadoReina" name="estadoReina" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                            <option value="Presente" selected="@(Model.EstadoReina == "Presente")">Presente</option>
                            <option value="Ausente" selected="@(Model.EstadoReina == "Ausente")">Ausente</option>
                        </select>
                    </div>
                    <div>
                        <label for="estadoColmena" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Estado General de la Colmena</label>
                        <select id="estadoColmena" name="estadoColmena" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                            <option value="Óptimo" selected="@(Model.Estado == "Óptimo")">Óptimo</option>
                            <option value="Alerta" selected="@(Model.Estado == "Alerta")">Alerta</option>
                            <option value="Crítico" selected="@(Model.Estado == "Crítico")">Crítico</option>
                        </select>
                    </div>
                </div>

                <div class="pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-end gap-3 mt-6">
                    <button type="button" id="btnCancelNote" class="border border-outline text-on-surface hover:bg-surface-container-high transition-colors px-5 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                        Cancelar
                    </button>
                    <button type="submit" class="bg-primary-container text-on-primary hover:bg-primary-fixed transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                        Guardar Nota
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Colmena Modal -->
<div id="editModal" class="fixed inset-0 z-50 flex items-center justify-center modal-backdrop bg-black/85 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-4xl modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-container">edit</span>
                Editar Parámetros de Colmena
            </h4>
            <button type="button" id="btnCancelEditIcon" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar">
            <form asp-action="EditarColmena" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                
                <!-- Left Column: Primary parameters & Sensors -->
                <div class="space-y-4">
                    <!-- Physical Parameters and Behavior Card -->
                    <div class="bg-surface-container-low border border-outline-variant rounded p-5 space-y-4">
                        <h5 class="font-label-caps text-label-caps text-primary-container font-bold border-b border-surface-container-highest pb-2 mb-2">Datos Físicos y Comportamiento</h5>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="peso" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Peso (Kg)</label>
                                <input type="number" step="0.1" id="peso" name="peso" value="@Model.PesoKg.ToString(System.Globalization.CultureInfo.InvariantCulture)" required min="0" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                            </div>
                            <div>
                                <label for="produccion" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Producción Miel (Kg)</label>
                                <input type="number" step="0.1" id="produccion" name="produccion" value="@Model.ProduccionMielKg.ToString(System.Globalization.CultureInfo.InvariantCulture)" required min="0" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="comportamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Comportamiento</label>
                                <select id="comportamiento" name="comportamiento" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                                    <option value="Dócil" selected="@(Model.ComportamientoAbejas == "Dócil")">Dócil</option>
                                    <option value="Defensivo" selected="@(Model.ComportamientoAbejas == "Defensivo")">Defensivo</option>
                                    <option value="Agresivo" selected="@(Model.ComportamientoAbejas == "Agresivo")">Agresivo</option>
                                </select>
                            </div>

                            <div>
                                <label for="tipoColmenaEdit" class="font-label-caps text-label-caps text-on-surface-variant block mb-2">Tipo de Colmena</label>
                                <select id="tipoColmenaEdit" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                                    @if (Model.EsNucleo)
                                    {
                                        <option value="Nucleo" selected>Núcleo</option>
                                        <option value="Normal">Normal</option>
                                    }
                                    else if (Model.EsPiloto)
                                    {
                                        <option value="Piloto" selected>Piloto</option>
                                        <option value="Normal">Normal</option>
                                    }
                                    else
                                    {
                                        <option value="Normal" selected>Normal</option>
                                        <option value="Piloto">Piloto</option>
                                    }
                                </select>
                                <input type="hidden" id="esPilotoEdit" name="esPiloto" value="@(Model.EsPiloto ? "true" : "false")" />
                                <input type="hidden" id="esNucleoEdit" name="esNucleo" value="@(Model.EsNucleo ? "true" : "false")" />
                            </div>
                        </div>
                    </div>

                    <!-- Sensor Monitoring Card (dynamically toggled) -->
                    <div id="sensorFieldsContainerEdit" class="bg-surface-container-low border border-outline-variant rounded p-5 space-y-4">
                        <h5 class="font-label-caps text-label-caps text-primary-container font-bold border-b border-surface-container-highest pb-2 mb-2">Sensores de Monitoreo</h5>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="temperaturaEdit" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Temperatura (°C)</label>
                                <input type="number" step="0.1" id="temperaturaEdit" name="temperatura" value="@Model.TemperaturaInterna.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                            </div>
                            <div>
                                <label for="humedadEdit" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Humedad (%)</label>
                                <input type="number" step="0.1" id="humedadEdit" name="humedad" value="@Model.HumedadInterna.ToString(System.Globalization.CultureInfo.InvariantCulture)" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Alzas current status & Inventory transactions -->
                <div class="space-y-4">
                    <!-- Current Alzas Configuration (ReadOnly) -->
                    <div id="alzasConfigContainerEdit" class="bg-surface-container-low border border-outline-variant rounded p-5 space-y-4">
                        <h5 class="font-label-caps text-label-caps text-primary-container font-bold border-b border-surface-container-highest pb-2 mb-2">Configuración Actual (Solo Lectura)</h5>
                        <div class="grid grid-cols-3 gap-4">
                            <div>
                                <label for="alzasEdit" class="font-label-caps text-[10px] text-on-surface-variant mb-2 block text-center">Alzas Enteras</label>
                                <input type="number" id="alzasEdit" name="alzas" value="@Model.Alzas.ToString(System.Globalization.CultureInfo.InvariantCulture)" readonly class="alza-input-edit w-full bg-surface-container-high border border-outline-variant px-3 py-2 rounded text-on-surface text-center font-bold outline-none cursor-not-allowed opacity-75" />
                            </div>
                            <div>
                                <label for="alzasTresCuartosEdit" class="font-label-caps text-[10px] text-on-surface-variant mb-2 block text-center">Alzas 3/4</label>
                                <input type="number" id="alzasTresCuartosEdit" name="alzasTresCuartos" value="@Model.AlzasTresCuartos.ToString(System.Globalization.CultureInfo.InvariantCulture)" readonly class="alza-input-edit w-full bg-surface-container-high border border-outline-variant px-3 py-2 rounded text-on-surface text-center font-bold outline-none cursor-not-allowed opacity-75" />
                            </div>
                            <div>
                                <label for="mediasAlzasEdit" class="font-label-caps text-[10px] text-on-surface-variant mb-2 block text-center">Medias Alzas</label>
                                <input type="number" id="mediasAlzasEdit" name="mediasAlzas" value="@Model.MediasAlzas.ToString(System.Globalization.CultureInfo.InvariantCulture)" readonly class="alza-input-edit w-full bg-surface-container-high border border-outline-variant px-3 py-2 rounded text-on-surface text-center font-bold outline-none cursor-not-allowed opacity-75" />
                            </div>
                        </div>
                    </div>

                    <!-- Alzas Transaction Panel -->
                    <div id="alzasInventoryTransactionPanel" class="bg-surface-container-low border border-outline-variant rounded p-5 space-y-4">
                        <h5 class="font-label-caps text-label-caps text-primary-container font-bold border-b border-surface-container-highest pb-2 mb-2">Manejo de Alzas (Colmena)</h5>
                        
                        <!-- Inputs in a single horizontal row -->
                        <div class="grid grid-cols-5 gap-3">
                            <div class="col-span-2">
                                <label for="alzaTransaccion" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Acción</label>
                                <select id="alzaTransaccion" name="alzaTransaccion" class="w-full bg-background border border-outline-variant px-3 py-2 rounded text-on-surface focus:border-primary-container outline-none transition-colors">
                                    <option value="Ninguna" selected>Ninguna (No modificar)</option>
                                    <option value="Agregar">Agregar a Colmena</option>
                                    <option value="Quitar">Quitar de Colmena</option>
                                </select>
                            </div>
                            
                            <div class="col-span-2">
                                <label for="tipoAlzaTransaccion" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Tipo de Alza</label>
                                <select id="tipoAlzaTransaccion" name="tipoAlzaTransaccion" class="w-full bg-background border border-outline-variant px-3 py-2 rounded text-on-surface focus:border-primary-container outline-none transition-colors">
                                    <option value="Enteras">Alzas Enteras</option>
                                    <option value="TresCuartos">Alzas 3/4</option>
                                    <option value="Medias">Medias Alzas</option>
                                </select>
                            </div>
                            
                            <div class="col-span-1">
                                <label for="cantidadTransaccion" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block text-center">Cantidad</label>
                                <input type="number" id="cantidadTransaccion" name="cantidadTransaccion" value="1" min="1" class="w-full bg-background border border-outline-variant px-3 py-2 rounded text-on-surface focus:border-primary-container outline-none transition-colors text-center font-bold" />
                            </div>
                        </div>

                        <input type="hidden" name="alzas" value="@Model.Alzas" />
                        <input type="hidden" name="mediasAlzas" value="@Model.MediasAlzas" />
                        <input type="hidden" name="alzasTresCuartos" value="@Model.AlzasTresCuartos" />

                        <!-- Dynamic transaction explanation card -->
                        <div id="transaccionExplicacion" class="p-3 rounded font-body-sm border transition-all duration-200 space-y-1.5 bg-surface-container-high border-outline-variant text-on-surface-variant">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-on-surface-variant">info</span>
                                <span>Selecciona una acción (Agregar o Quitar) para modificar las alzas de la colmena.</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Action Buttons (Spans full width) -->
                <div class="md:col-span-2 pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-end gap-3 mt-4">
                    <button type="button" id="btnCancelEdit" class="border border-outline text-on-surface hover:bg-surface-container-high transition-colors px-5 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                        Cancelar
                    </button>
                    <button type="submit" class="bg-primary-container text-on-primary hover:bg-primary-fixed transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                        Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Registrar Tratamiento Modal -->
<div id="registrarModal" class="fixed inset-0 z-50 flex items-center justify-center modal-backdrop bg-black/85 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-2xl modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-container">vaccines</span>
                Registrar Nuevo Tratamiento
            </h4>
            <button type="button" id="btnCancelRegistrarIcon" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar">
            <form id="registrarForm" class="space-y-4">
                <input type="hidden" id="colmenaIdInput" value="@Model.Id" />
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="tituloTratamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Título *</label>
                        <input type="text" id="tituloTratamiento" required class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors" placeholder="Ej: Control de Varroa Otoñal" />
                    </div>
                    <div>
                        <label for="tipoTratamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Tipo *</label>
                        <select id="tipoTratamiento" required class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors">
                            <option value="" disabled selected>Seleccione tipo...</option>
                            <option value="Mantenimiento">Mantenimiento</option>
                            <option value="Medicinal">Medicinal</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label for="fechaTratamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Fecha de Registro</label>
                    <input type="text" id="fechaTratamiento" readonly class="w-full bg-surface-container-high border border-outline-variant px-4 py-2.5 rounded text-on-surface outline-none cursor-default" />
                </div>

                <div>
                    <label for="notaTratamiento" class="font-label-caps text-label-caps text-on-surface-variant mb-2 block">Notas</label>
                    <textarea id="notaTratamiento" rows="3" class="w-full bg-background border border-outline-variant px-4 py-2.5 rounded text-on-surface focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors resize-none" placeholder="Escriba notas libres sobre el tratamiento..."></textarea>
                </div>

                <div>
                    <div class="flex justify-between items-center mb-2 border-b border-surface-container-highest pb-2">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">Equipamientos Utilizados</span>
                    </div>
                    
                    <div id="equipamientosRowsContainer" class="space-y-3">
                        <!-- Dynamic rows will go here -->
                    </div>
                    
                    <button type="button" id="btnAddEquipmentRow" class="mt-3 flex items-center gap-1 text-primary-container hover:text-primary-fixed transition-colors font-label-caps text-label-caps">
                        <span class="material-symbols-outlined text-[18px]">add</span>
                        + Agregar equipamiento
                    </button>
                </div>

                <div class="pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-end gap-3 mt-6">
                    <button type="button" id="btnCancelRegistrar" class="border border-outline text-on-surface hover:bg-surface-container-high transition-colors px-5 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                        Cancelar
                    </button>
                    <button type="submit" class="bg-primary-container text-on-primary hover:bg-primary-fixed transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                        Confirmar Registro
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- All Notes Modal -->
<div id="allNotesModal" class="fixed inset-0 z-50 flex items-center justify-center modal-backdrop bg-black/85 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-4xl modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-container">history</span>
                Historial Completo de Notas
            </h4>
            <button type="button" id="btnCancelAllNotesIcon" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto space-y-4 grow custom-scrollbar">
            @if (Model.NotasTecnicas != null && Model.NotasTecnicas.Any())
            {
                foreach (var nota in Model.NotasTecnicas.OrderByDescending(n => n.Fecha))
                {
                    <div class="bg-surface-container-low border border-outline-variant rounded p-5 flex flex-col md:flex-row gap-6 md:items-center hover:border-surface-container-high transition-colors">
                        <div class="flex flex-col min-w-[120px]">
                            <span class="font-label-caps text-label-caps text-on-surface">@nota.Fecha.ToString("dd MMM yyyy").ToUpper()</span>
                            <span class="font-body-sm text-body-sm text-on-surface-variant">@nota.Fecha.ToString("HH:mm") hrs</span>
                        </div>
                        <div class="w-px h-12 bg-surface-container-highest hidden md:block"></div>
                        <div class="flex-grow flex flex-col gap-2">
                            <div class="flex items-center gap-3">
                                <span class="font-body-md text-body-md font-semibold text-primary-container">@(nota.KilosCosechados > 0 ? "Nota de Extracción / Cosecha" : "Nota de Evaluación")</span>
                            </div>
                            @if (nota.KilosCosechados > 0)
                            {
                                <div class="flex items-center gap-1 text-[11px] font-bold text-primary-container bg-primary-container/10 px-2 py-0.5 border border-primary-container/30 rounded w-fit mt-1">
                                    <span class="material-symbols-outlined text-[14px]">shopping_bag</span>
                                    Miel cosechada: @nota.KilosCosechados.ToString("0.0") kg (Enteras: @nota.AlzasCosechadas, 3/4: @nota.AlzasTresCuartosCosechadas, Medias: @nota.MediasAlzasCosechadas)
                                </div>
                            }
                            <p class="font-body-sm text-body-sm text-on-surface-variant">
                                @nota.Detalles
                            </p>
                        </div>
                        <div class="flex flex-col items-end gap-1 text-on-surface-variant text-[10px] font-label-caps border-l border-surface-container-highest pl-4 shrink-0 mt-4 md:mt-0 min-w-[120px]">
                            <span class="whitespace-nowrap">Reina: @nota.EstadoReina</span>
                            @if (nota.Temperatura.HasValue) { <span>Temp: @nota.Temperatura.Value.ToString("0.0")°C</span> }
                            @if (nota.Humedad.HasValue) { <span>Hum: @nota.Humedad.Value.ToString("0.0")%</span> }
                            @if (nota.KilosCosechados > 0) { <span class="text-primary-container font-semibold">Cosechó @nota.KilosCosechados.ToString("0.0") kg</span> }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-10 text-on-surface-variant font-body-sm">
                    No hay notas técnicas registradas.
                </div>
            }
        </div>
        <div class="pt-4 pb-4 px-6 border-t border-surface-container-highest flex justify-end shrink-0">
            <button type="button" id="btnCancelAllNotes" class="bg-surface-container-high border border-outline text-on-surface hover:bg-surface-container-highest transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto">
                Cerrar Historial
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Modal Logic Helper
        function setupModal(openBtnId, modalId, cancelBtnIds) {
            const modal = document.getElementById(modalId);
            const openBtn = document.getElementById(openBtnId);
            if (openBtn) {
                openBtn.addEventListener('click', () => modal.classList.remove('modal-hidden'));
            }
            cancelBtnIds.forEach(id => {
                const btn = document.getElementById(id);
                if (btn) {
                    btn.addEventListener('click', () => modal.classList.add('modal-hidden'));
                }
            });
        }

        // Setup Edit Modal
        const editModal = document.getElementById('editModal');
        const btnOpenEdit = document.getElementById('btnOpenEdit');
        if (btnOpenEdit && editModal) {
            btnOpenEdit.addEventListener('click', () => {
                const form = editModal.querySelector('form');
                if (form) {
                    form.reset();
                }
                if (typeof updateEditFormConstraints === 'function') {
                    updateEditFormConstraints();
                }
                editModal.classList.remove('modal-hidden');
            });
        }
        ['btnCancelEdit', 'btnCancelEditIcon'].forEach(id => {
            const btn = document.getElementById(id);
            if (btn) {
                btn.addEventListener('click', () => editModal.classList.add('modal-hidden'));
            }
        });

        // Toggle logic for editing a hive in the edit modal
        const tipoColmenaEditSelect = document.getElementById('tipoColmenaEdit');
        const esPilotoEditHidden = document.getElementById('esPilotoEdit');
        const esNucleoEditHidden = document.getElementById('esNucleoEdit');
        const sensorFieldsContainerEdit = document.getElementById('sensorFieldsContainerEdit');
        const alzasConfigContainerEdit = document.getElementById('alzasConfigContainerEdit');
        const alzasInventoryTransactionPanel = document.getElementById('alzasInventoryTransactionPanel');
        const tempInputEdit = document.getElementById('temperaturaEdit');
        const humInputEdit = document.getElementById('humedadEdit');
        const inputsAlzasEdit = document.querySelectorAll('.alza-input-edit');

        // Dynamic required variables for transaction
        const alzaTransaccionSelect = document.getElementById('alzaTransaccion');
        const tipoAlzaTransaccionSelect = document.getElementById('tipoAlzaTransaccion');
        const cantidadTransaccionInput = document.getElementById('cantidadTransaccion');
        const transaccionExplicacion = document.getElementById('transaccionExplicacion');

        const currentAlzasCounts = {
            'Enteras': parseInt('@Model.Alzas') || 0,
            'TresCuartos': parseInt('@Model.AlzasTresCuartos') || 0,
            'Medias': parseInt('@Model.MediasAlzas') || 0
        };

        function updateTransactionVisualState() {
            if (!alzaTransaccionSelect) return;
            const accion = alzaTransaccionSelect.value;
            const tipoAlza = tipoAlzaTransaccionSelect.value;
            const currentCount = currentAlzasCounts[tipoAlza];
            const maxLimit = 5;

            // Reset classes on the explanation box
            transaccionExplicacion.className = "p-3 rounded font-body-sm border transition-all duration-200 space-y-1.5";

            if (accion === 'Ninguna') {
                cantidadTransaccionInput.required = false;
                cantidadTransaccionInput.disabled = true;
                cantidadTransaccionInput.value = 0;
                cantidadTransaccionInput.max = 0;

                // Show default explanation
                transaccionExplicacion.classList.add('bg-surface-container-high', 'border-outline-variant', 'text-on-surface-variant');
                transaccionExplicacion.innerHTML = `
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] text-on-surface-variant">info</span>
                        <span>Selecciona una acción (Agregar o Quitar) para modificar las alzas de la colmena.</span>
                    </div>
                `;
            } else if (accion === 'Agregar') {
                const availableSlots = maxLimit - currentCount;

                if (availableSlots <= 0) {
                    cantidadTransaccionInput.disabled = true;
                    cantidadTransaccionInput.required = false;
                    cantidadTransaccionInput.value = 0;
                    cantidadTransaccionInput.max = 0;

                    transaccionExplicacion.classList.add('bg-error-container/10', 'border-error-container/30', 'text-on-surface');
                    transaccionExplicacion.innerHTML = `
                        <div class="flex items-center gap-2 text-error font-semibold">
                            <span class="material-symbols-outlined text-[18px]">warning</span>
                            <span>Límite Alcanzado: Esta colmena ya tiene las 5 alzas de este tipo.</span>
                        </div>
                    `;
                } else {
                    cantidadTransaccionInput.disabled = false;
                    cantidadTransaccionInput.required = true;
                    cantidadTransaccionInput.min = 1;
                    cantidadTransaccionInput.max = availableSlots;
                    if (parseInt(cantidadTransaccionInput.value) > availableSlots || parseInt(cantidadTransaccionInput.value) <= 0) {
                        cantidadTransaccionInput.value = 1;
                    }

                    transaccionExplicacion.classList.add('bg-primary-container/10', 'border-primary-container/30', 'text-on-surface');
                    transaccionExplicacion.innerHTML = `
                        <div class="flex items-center gap-1.5 text-primary-container font-semibold">
                            <span class="material-symbols-outlined text-[18px]">add_circle</span>
                            <span>Agregar alzas (Instaladas: ${currentCount} / 5 | Disponibles: ${availableSlots})</span>
                        </div>
                    `;
                }
            } else if (accion === 'Quitar') {
                if (currentCount <= 0) {
                    cantidadTransaccionInput.disabled = true;
                    cantidadTransaccionInput.required = false;
                    cantidadTransaccionInput.value = 0;
                    cantidadTransaccionInput.max = 0;

                    transaccionExplicacion.classList.add('bg-error-container/10', 'border-error-container/30', 'text-on-surface');
                    transaccionExplicacion.innerHTML = `
                        <div class="flex items-center gap-2 text-error font-semibold">
                            <span class="material-symbols-outlined text-[18px]">warning</span>
                            <span>Sin Alzas: No hay alzas de este tipo instaladas para retirar.</span>
                        </div>
                    `;
                } else {
                    cantidadTransaccionInput.disabled = false;
                    cantidadTransaccionInput.required = true;
                    cantidadTransaccionInput.min = 1;
                    cantidadTransaccionInput.max = currentCount;
                    if (parseInt(cantidadTransaccionInput.value) > currentCount || parseInt(cantidadTransaccionInput.value) <= 0) {
                        cantidadTransaccionInput.value = 1;
                    }

                    transaccionExplicacion.classList.add('bg-error-container/10', 'border-error-container/30', 'text-on-surface');
                    transaccionExplicacion.innerHTML = `
                        <div class="flex items-center gap-1.5 text-error font-semibold">
                            <span class="material-symbols-outlined text-[18px]">remove_circle</span>
                            <span>Retirar alzas (Instaladas: ${currentCount} | Máx. a retirar: ${currentCount})</span>
                        </div>
                    `;
                }
            }
        }

        if (alzaTransaccionSelect) {
            alzaTransaccionSelect.addEventListener('change', updateTransactionVisualState);
            tipoAlzaTransaccionSelect.addEventListener('change', updateTransactionVisualState);
            updateTransactionVisualState();
        }

        const editForm = document.querySelector('#editModal form');
        if (editForm) {
            editForm.addEventListener('submit', function(event) {
                if (!alzaTransaccionSelect) return;
                const accion = alzaTransaccionSelect.value;
                if (accion === 'Ninguna') return;

                const tipoAlza = tipoAlzaTransaccionSelect.value;
                const cantidad = parseInt(cantidadTransaccionInput.value) || 0;
                const currentCount = currentAlzasCounts[tipoAlza];

                if (accion === 'Agregar') {
                    if (currentCount + cantidad > 5) {
                        alert(`No se pueden agregar ${cantidad} alzas. El total superaría el límite máximo de 5 de este tipo.`);
                        event.preventDefault();
                        return;
                    }
                } else if (accion === 'Quitar') {
                    if (currentCount < cantidad) {
                        alert(`Cantidad inválida. La colmena solo tiene ${currentCount} alzas instaladas de este tipo.`);
                        event.preventDefault();
                        return;
                    }
                }
            });
        }

        function updateEditFormConstraints() {
            const val = tipoColmenaEditSelect.value;
            if (val === 'Nucleo') {
                esNucleoEditHidden.value = 'true';
                esPilotoEditHidden.value = 'false';

                // Nucleo: hide alzas, transaction panel and hide sensors
                alzasConfigContainerEdit.classList.add('hidden');
                if (alzasInventoryTransactionPanel) alzasInventoryTransactionPanel.classList.add('hidden');
                sensorFieldsContainerEdit.classList.add('hidden');
                
                tempInputEdit.required = false;
                humInputEdit.required = false;
                tempInputEdit.value = '';
                humInputEdit.value = '';

                // Reset and calculate
                inputsAlzasEdit.forEach(input => {
                    input.value = 0;
                });
            } else if (val === 'Piloto') {
                esNucleoEditHidden.value = 'false';
                esPilotoEditHidden.value = 'true';

                // Piloto: show alzas, transaction panel and show sensors
                alzasConfigContainerEdit.classList.remove('hidden');
                if (alzasInventoryTransactionPanel) alzasInventoryTransactionPanel.classList.remove('hidden');
                sensorFieldsContainerEdit.classList.remove('hidden');

                tempInputEdit.required = false;
                humInputEdit.required = false;
            } else {
                // Normal: show alzas, transaction panel and hide sensors
                esNucleoEditHidden.value = 'false';
                esPilotoEditHidden.value = 'false';

                alzasConfigContainerEdit.classList.remove('hidden');
                if (alzasInventoryTransactionPanel) alzasInventoryTransactionPanel.classList.remove('hidden');
                sensorFieldsContainerEdit.classList.add('hidden');

                tempInputEdit.required = false;
                humInputEdit.required = false;
                tempInputEdit.value = '';
                humInputEdit.value = '';
            }

            updateProduccionMax();
        }

        function updateProduccionMax() {
            const val = tipoColmenaEditSelect.value;
            const produccionInput = document.getElementById('produccion');
            if (!produccionInput) return;

            if (val === 'Nucleo') {
                produccionInput.max = 0;
                if (parseFloat(produccionInput.value) > 0) {
                    produccionInput.value = 0;
                    produccionInput.dispatchEvent(new Event('input'));
                }
            } else {
                const alzas = parseInt(document.getElementById('alzasEdit').value) || 0;
                const alzas34 = parseInt(document.getElementById('alzasTresCuartosEdit').value) || 0;
                const medias = parseInt(document.getElementById('mediasAlzasEdit').value) || 0;
                const maxMiel = (alzas * 22) + (alzas34 * 17) + (medias * 12);
                produccionInput.max = maxMiel;
                
                if (parseFloat(produccionInput.value) > maxMiel) {
                    produccionInput.value = maxMiel;
                    produccionInput.dispatchEvent(new Event('input'));
                }
            }
        }

        if (tipoColmenaEditSelect) {
            tipoColmenaEditSelect.addEventListener('change', updateEditFormConstraints);
            // Run initially to set correct state
            updateEditFormConstraints();
        }

        // Dynamic Hive Weight delta recalculation on edit
        const pesoInput = document.getElementById('peso');
        const produccionInput = document.getElementById('produccion');
        if (pesoInput && produccionInput) {
            let lastMiel = parseFloat(produccionInput.value) || 0;

            produccionInput.addEventListener('input', () => {
                const currentMiel = parseFloat(produccionInput.value) || 0;
                const currentPeso = parseFloat(pesoInput.value) || 0;
                const diff = currentMiel - lastMiel;
                pesoInput.value = (currentPeso + diff).toFixed(1);
                lastMiel = currentMiel;
            });

            pesoInput.addEventListener('change', () => {
                lastMiel = parseFloat(produccionInput.value) || 0;
            });
        }
        
        // Setup Note Modal
        setupModal('btnOpenNote', 'noteModal', ['btnCancelNote', 'btnCancelNoteIcon']);
        
        // Setup All Notes Modal
        setupModal('btnOpenAllNotes', 'allNotesModal', ['btnCancelAllNotes', 'btnCancelAllNotesIcon']);

        // Setup Delete Modal (global function for inline onclick)
        const deleteModal = document.getElementById('deleteModal');
        window.openDeleteModal = function() {
            deleteModal.classList.remove('modal-hidden');
        }
        document.getElementById('btnCancelDelete').addEventListener('click', () => {
            deleteModal.classList.add('modal-hidden');
        });

        // Registrar Tratamiento Logic
        const colmenaId = @Model.Id;
        let availableEquipments = @Html.Raw(ViewBag.EquipmentsJson);
        let rowCounter = 0;

        document.addEventListener('DOMContentLoaded', () => {
            const btnOpenRegistrar = document.getElementById('btnOpenRegistrar');
            const registrarModal = document.getElementById('registrarModal');
            
            if (btnOpenRegistrar) {
                btnOpenRegistrar.addEventListener('click', () => {
                    // Reset form first
                    document.getElementById('registrarForm').reset();
                    createInitialRow();
                    
                    // Preset current local date-time
                    const now = new Date();
                    const formatted = now.toLocaleDateString('es-ES', {
                        day: '2-digit', month: '2-digit', year: 'numeric'
                    }) + ' ' + now.toLocaleTimeString('es-ES', {
                        hour: '2-digit', minute: '2-digit'
                    });
                    document.getElementById('fechaTratamiento').value = formatted;
                    
                    // Show modal
                    registrarModal.classList.remove('modal-hidden');
                });
            }

            // Close actions for Registrar
            document.getElementById('btnCancelRegistrar').addEventListener('click', () => {
                registrarModal.classList.add('modal-hidden');
            });
            document.getElementById('btnCancelRegistrarIcon').addEventListener('click', () => {
                registrarModal.classList.add('modal-hidden');
            });

            // Add equipment row button
            document.getElementById('btnAddEquipmentRow').addEventListener('click', () => {
                addEquipmentRow();
            });

            // Save new treatment via AJAX
            const registrarForm = document.getElementById('registrarForm');
            registrarForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const titulo = document.getElementById('tituloTratamiento').value;
                const tipo = document.getElementById('tipoTratamiento').value;
                const nota = document.getElementById('notaTratamiento').value;
                
                if (!titulo) {
                    showToast('El título del tratamiento es obligatorio.', 'error');
                    return;
                }

                if (!tipo) {
                    showToast('El tipo de tratamiento es obligatorio.', 'error');
                    return;
                }
                
                const rows = document.querySelectorAll('.equipment-row');
                const equipamientos = [];
                const selectedIds = new Set();
                
                for (let i = 0; i < rows.length; i++) {
                    const select = rows[i].querySelector('.equipment-select');
                    const qtyInput = rows[i].querySelector('.equipment-qty');
                    
                    const eqId = select.value;
                    const qtyVal = qtyInput.value;
                    
                    // Partially completed checks
                    if ((eqId && !qtyVal) || (!eqId && qtyVal)) {
                        showToast('Si completa una fila de equipamiento, tanto el equipamiento como la cantidad son obligatorios.', 'error');
                        return;
                    }
                    
                    if (eqId && qtyVal) {
                        const qty = parseInt(qtyVal);
                        const selectedOption = select.options[select.selectedIndex];
                        const stock = parseInt(selectedOption.dataset.stock || '0');
                        
                        if (qty <= 0) {
                            showToast('La cantidad debe ser mayor a cero.', 'error');
                            return;
                        }
                        if (stock === 0) {
                            showToast(`El equipamiento '${selectedOption.text}' no tiene stock disponible (0u).`, 'error');
                            return;
                        }
                        if (qty > stock) {
                            showToast(`La cantidad ingresada (${qty}u) supera el stock disponible (${stock}u) para ${selectedOption.text}.`, 'error');
                            return;
                        }
                        
                        if (selectedIds.has(eqId)) {
                            showToast('No puede seleccionar el mismo equipamiento más de una vez.', 'error');
                            return;
                        }
                        selectedIds.add(eqId);
                        
                        equipamientos.push({
                            equipmentId: parseInt(eqId),
                            cantidad: qty
                        });
                    }
                }
                
                try {
                    const response = await fetch('/Colmenas/RegistrarTratamiento', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            colmenaId: colmenaId,
                            titulo: titulo,
                            tipo: tipo,
                            nota: nota,
                            equipamientos: equipamientos
                        })
                    });
                    
                    const res = await response.json();
                    if (res.success) {
                        showToast(res.message, 'success');
                        
                        // Close modal
                        document.getElementById('registrarModal').classList.add('modal-hidden');
                        
                        // Reload page to reflect changes
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500);
                    } else {
                        showToast(res.errors ? res.errors.join('<br>') : 'Error al registrar el tratamiento.', 'error');
                    }
                } catch (err) {
                    showToast('Error de red al intentar registrar el tratamiento.', 'error');
                    console.error(err);
                }
            });
        });

        // Create the default (first) equipment row inside the form
        function createInitialRow() {
            const container = document.getElementById('equipamientosRowsContainer');
            container.innerHTML = '';
            rowCounter = 1;

            const rowDiv = document.createElement('div');
            rowDiv.className = 'flex items-center gap-3 equipment-row';

            // Select Dropdown
            const select = document.createElement('select');
            select.className = 'w-2/3 bg-background border border-outline-variant px-3 py-2 rounded text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors equipment-select';

            const defaultOpt = document.createElement('option');
            defaultOpt.value = '';
            defaultOpt.textContent = 'Seleccione equipamiento...';
            select.appendChild(defaultOpt);

            availableEquipments.forEach(eq => {
                const opt = document.createElement('option');
                opt.value = eq.id;
                opt.textContent = `${eq.name} (${eq.stock}u)`;
                opt.dataset.stock = eq.stock;
                select.appendChild(opt);
            });

            // Quantity Input
            const qtyInput = document.createElement('input');
            qtyInput.type = 'number';
            qtyInput.min = '1';
            qtyInput.placeholder = 'Cant.';
            qtyInput.className = 'w-1/3 bg-background border border-outline-variant px-3 py-2 rounded text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors equipment-qty';

            // Align space
            const alignSpacer = document.createElement('div');
            alignSpacer.className = 'w-8 h-8 flex-shrink-0';

            rowDiv.appendChild(select);
            rowDiv.appendChild(qtyInput);
            rowDiv.appendChild(alignSpacer);

            container.appendChild(rowDiv);

            // Quantity limits dynamic bindings
            select.addEventListener('change', () => {
                const selectedOption = select.options[select.selectedIndex];
                const stock = parseInt(selectedOption.dataset.stock || '0');
                qtyInput.max = stock;
                if (stock === 0) {
                    qtyInput.value = '';
                    qtyInput.placeholder = 'Sin stock';
                    qtyInput.disabled = true;
                } else {
                    qtyInput.placeholder = 'Cant.';
                    qtyInput.disabled = false;
                }
                updateAvailableOptions();
            });
        }

        // Add additional dynamic equipment rows
        function addEquipmentRow() {
            rowCounter++;
            const rowId = `eq-row-${rowCounter}`;
            
            const container = document.getElementById('equipamientosRowsContainer');
            const rowDiv = document.createElement('div');
            rowDiv.id = rowId;
            rowDiv.className = 'flex items-center gap-3 equipment-row';

            // Select Dropdown
            const select = document.createElement('select');
            select.className = 'w-2/3 bg-background border border-outline-variant px-3 py-2 rounded text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors equipment-select';
            select.required = true;

            const defaultOpt = document.createElement('option');
            defaultOpt.value = '';
            defaultOpt.textContent = 'Seleccione equipamiento...';
            select.appendChild(defaultOpt);

            availableEquipments.forEach(eq => {
                const opt = document.createElement('option');
                opt.value = eq.id;
                opt.textContent = `${eq.name} (${eq.stock}u)`;
                opt.dataset.stock = eq.stock;
                select.appendChild(opt);
            });

            // Quantity Input
            const qtyInput = document.createElement('input');
            qtyInput.type = 'number';
            qtyInput.min = '1';
            qtyInput.placeholder = 'Cant.';
            qtyInput.className = 'w-1/3 bg-background border border-outline-variant px-3 py-2 rounded text-on-surface text-sm focus:border-primary-container focus:ring-1 focus:ring-primary-container outline-none transition-colors equipment-qty';
            qtyInput.required = true;

            // Remove Button
            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'text-on-surface-variant hover:text-error transition-colors p-1 flex items-center justify-center flex-shrink-0';
            removeBtn.innerHTML = '<span class="material-symbols-outlined text-[20px]">delete</span>';
            removeBtn.title = 'Quitar';
            
            removeBtn.addEventListener('click', () => {
                rowDiv.remove();
                updateAvailableOptions();
            });

            rowDiv.appendChild(select);
            rowDiv.appendChild(qtyInput);
            rowDiv.appendChild(removeBtn);

            container.appendChild(rowDiv);

            // Quantity limits dynamic bindings
            select.addEventListener('change', () => {
                const selectedOption = select.options[select.selectedIndex];
                const stock = parseInt(selectedOption.dataset.stock || '0');
                qtyInput.max = stock;
                if (stock === 0) {
                    qtyInput.value = '';
                    qtyInput.placeholder = 'Sin stock';
                    qtyInput.disabled = true;
                } else {
                    qtyInput.placeholder = 'Cant.';
                    qtyInput.disabled = false;
                }
                updateAvailableOptions();
            });

            updateAvailableOptions();
        }

        // Dynamically disable selected options across other selects to prevent duplicates
        function updateAvailableOptions() {
            const selectedValues = Array.from(document.querySelectorAll('.equipment-select'))
                .map(sel => sel.value)
                .filter(val => val !== '');
                
            document.querySelectorAll('.equipment-select').forEach(currentSelect => {
                const currentValue = currentSelect.value;
                currentSelect.querySelectorAll('option').forEach(option => {
                    if (option.value !== '') {
                        if (selectedValues.includes(option.value) && option.value !== currentValue) {
                            option.disabled = true;
                        } else {
                            option.disabled = false;
                        }
                    }
                });
            });
        }
    </script>
}
