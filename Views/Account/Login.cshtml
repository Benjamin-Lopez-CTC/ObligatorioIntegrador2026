@model ObligatorioIntegrador2026.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html class="dark" lang="es">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>Zánganos S.A. - Acceso Interno</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700&amp;family=Inter:wght@400;500&amp;family=JetBrains+Mono:wght@500&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-secondary-fixed-variant": "#474746",
                        "on-primary-container": "#715f00",
                        "surface-container-high": "#292a2a",
                        "on-primary": "#3a3000",
                        "surface-dim": "#121414",
                        "secondary-container": "#474746",
                        "secondary-fixed": "#e5e2e1",
                        "on-surface-variant": "#cfc6ab",
                        "primary-fixed-dim": "#e7c400",
                        "on-tertiary-container": "#606060",
                        "surface": "#121414",
                        "outline": "#989077",
                        "surface-container-highest": "#343535",
                        "inverse-primary": "#6f5d00",
                        "on-error-container": "#ffdad6",
                        "on-background": "#e3e2e2",
                        "surface-tint": "#e7c400",
                        "on-tertiary": "#303030",
                        "tertiary-fixed": "#e4e2e1",
                        "tertiary-fixed-dim": "#c8c6c5",
                        "on-error": "#690005",
                        "secondary-fixed-dim": "#c8c6c5",
                        "background": "#121414",
                        "surface-container-lowest": "#0d0e0f",
                        "secondary": "#c8c6c5",
                        "surface-container": "#1e2020",
                        "on-secondary-container": "#b7b5b4",
                        "surface-bright": "#383939",
                        "on-surface": "#e3e2e2",
                        "error": "#ffb4ab",
                        "on-tertiary-fixed-variant": "#474746",
                        "on-primary-fixed": "#221b00",
                        "inverse-surface": "#e3e2e2",
                        "error-container": "#93000a",
                        "on-tertiary-fixed": "#1b1c1c",
                        "inverse-on-surface": "#2f3131",
                        "surface-container-low": "#1a1c1c",
                        "on-secondary-fixed": "#1b1b1c",
                        "on-secondary": "#303030",
                        "outline-variant": "#4c4732",
                        "surface-variant": "#343535",
                        "primary-fixed": "#ffe165",
                        "primary-container": "#ffd900",
                        "primary": "#fff7e6",
                        "tertiary": "#faf7f7",
                        "tertiary-container": "#dddbda",
                        "on-primary-fixed-variant": "#544600"
                    },
                    borderRadius: {
                        'none': '0',
                        'sm': '0.0625rem',
                        DEFAULT: '0.125rem',
                        'md': '0.1875rem',
                        'lg': '0.25rem',
                        'xl': '0.5rem',
                        '2xl': '1rem',
                        '3xl': '1.5rem',
                        'full': '9999px',
                    },
                    "spacing": {
                        "container-max": "1600px",
                        "unit": "8px",
                        "margin-mobile": "20px",
                        "margin-desktop": "64px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "body-md": ["Inter"],
                        "display": ["Hanken Grotesk"],
                        "headline-lg": ["Hanken Grotesk"],
                        "label-caps": ["JetBrains Mono"],
                        "headline-lg-mobile": ["Hanken Grotesk"],
                        "body-sm": ["Inter"]
                    },
                    "fontSize": {
                        "body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "display": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "headline-lg": ["32px", {"lineHeight": "1.2", "fontWeight": "600"}],
                        "label-caps": ["12px", {"lineHeight": "1.0", "letterSpacing": "0.1em", "fontWeight": "500"}],
                        "headline-lg-mobile": ["24px", {"lineHeight": "1.2", "fontWeight": "600"}],
                        "body-sm": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>
    <style>
        body {
            background-color: #121414;
            color: #e3e2e2;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col font-body-md text-body-md">
    <!-- Main Content Canvas -->
    <main class="flex-grow flex items-center justify-center px-margin-mobile md:px-margin-desktop py-20 relative overflow-hidden">
        <!-- Abstract Decorative Element (Subtle industrial texture) -->
        <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: radial-gradient(#FFD900 1px, transparent 1px); background-size: 40px 40px;"></div>
        <div class="w-full max-w-[440px] z-10">
            <!-- Branding Section -->
            <div class="text-center mb-10">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded mb-6"><img src="~/Logo.png" alt="Logo" class="w-full h-full object-contain" /></div>
                <h1 class="font-display text-display text-on-surface mb-2 tracking-tight">Zánganos S.A.</h1>
                <p class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest">Sistema de Gestión Interna</p>
            </div>
            <!-- Login Form Card -->
            <div class="bg-surface-container border border-secondary-container p-8 md:p-10 rounded">
                <form asp-action="Login" asp-controller="Account" method="post" class="space-y-6">
                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="text-error font-body-sm mb-4"></div>

                    <!-- Username Field -->
                    <div class="space-y-2">
                        <label class="block font-label-caps text-label-caps text-outline uppercase tracking-wider" for="username">Usuario</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[20px]" data-icon="person">person</span>
                            <input asp-for="Username" class="w-full bg-surface-container-high border border-secondary-container text-on-surface pl-10 pr-4 py-3 rounded focus:outline-none focus:border-primary-container transition-colors placeholder:text-on-secondary-fixed-variant" placeholder="ej: f.alvarez" type="text">
                        </div>
                        <span asp-validation-for="Username" class="text-error text-xs"></span>
                    </div>
                    <!-- Password Field -->
                    <div class="space-y-2">
                        <label class="block font-label-caps text-label-caps text-outline uppercase tracking-wider" for="password">Contraseña</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[20px]" data-icon="lock">lock</span>
                            <input asp-for="Password" class="w-full bg-surface-container-high border border-secondary-container text-on-surface pl-10 pr-4 py-3 rounded focus:outline-none focus:border-primary-container transition-colors placeholder:text-on-secondary-fixed-variant" placeholder="••••••••" type="password">
                        </div>
                        <span asp-validation-for="Password" class="text-error text-xs"></span>
                    </div>

                    <!-- Submit Button -->
                    <button class="w-full bg-primary-container text-on-primary font-body-md py-4 rounded hover:opacity-90 active:opacity-80 transition-all flex items-center justify-center gap-2 group" type="submit">
                        Iniciar Sesión
                        <span class="material-symbols-outlined text-[20px]" data-icon="arrow_forward">arrow_forward</span>
                    </button>
                </form>
            </div>
            <!-- Footer-like Meta Info -->
            <div class="mt-12 text-center">
                <p class="font-label-caps text-label-caps text-on-secondary-fixed-variant flex items-center justify-center gap-2"><span class="material-symbols-outlined text-[14px]" data-icon="language">language</span>ZÁNGANOS S.A. - PROPIEDAD DE MATÍAS VERGES</p>
            </div>
        </div>
    </main>
    <!-- Footer -->
    <footer class="grid grid-cols-1 md:grid-cols-3 items-center py-6 px-4 md:px-8 bg-surface-container border-t border-surface-container-highest mt-auto w-full gap-4">
        <span class="font-label-caps text-label-caps font-bold text-primary-container text-center md:text-left">Zánganos S.A.</span>
        <div class="flex flex-wrap justify-center gap-4">
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary-container transition-opacity" href="/docs/Documentaci%C3%B3n%20Obligatorio%20AP%20Hito%204%20-%20Benjam%C3%ADn%20L%C3%B3pez%20y%20Felipe%20Alvarez.pdf" download>Documentación Técnica</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary-container transition-opacity hidden sm:inline" href="javascript:void(0)" onclick="openApiSupportModal()">Soporte API</a>
        </div>
        <span class="font-body-sm text-body-sm text-on-surface-variant text-center md:text-right">Felipe Alvarez y Benjamín López - 2026</span>
    </footer>

    <!-- Modal Soporte API -->
    <div id="modalSoporteApi" class="fixed inset-0 z-[60] flex items-center justify-center bg-black/80 p-4" style="opacity: 0; pointer-events: none; transition: opacity 0.25s ease-out;">
        <div class="bg-surface-container border border-outline-variant rounded-lg w-full max-w-lg shadow-2xl flex flex-col max-h-[85vh]" style="transition: transform 0.25s ease-out, opacity 0.25s ease-out;">
            <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
                <h4 class="font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-primary-container">api</span>
                    <span>Soporte API de Escaneo</span>
                </h4>
                <button type="button" onclick="closeApiSupportModal()" class="text-on-surface-variant hover:text-primary-container transition-colors p-1" title="Cerrar">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="p-6 overflow-y-auto grow space-y-6">
                <p class="font-body-md text-on-surface-variant">
                    El sistema de escaneo de colmenas funciona de forma híbrida dependiendo de la conexión a Internet:
                </p>
                <div class="bg-surface-container-high border border-outline-variant p-4 rounded-lg space-y-2">
                    <div class="flex items-center gap-2 text-primary-container font-semibold">
                        <span class="material-symbols-outlined text-[20px]">cloud</span>
                        <span>Modo Online (Con Conexión)</span>
                    </div>
                    <p class="font-body-sm text-on-surface-variant">
                        Utiliza la API de <strong class="text-on-surface">Google Gemini (modelo gemini-2.5-flash)</strong> en la nube para procesar la imagen capturada por la cámara y extraer con alta precisión los 6 dígitos del código de la colmena.
                    </p>
                    <div class="pt-1">
                        <a href="https://ai.google.dev/gemini-api/docs" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-caps text-label-caps text-primary-container hover:underline text-xs">
                            Documentación de Gemini <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                        </a>
                    </div>
                </div>
                <div class="bg-surface-container-high border border-outline-variant p-4 rounded-lg space-y-2">
                    <div class="flex items-center gap-2 text-primary-container font-semibold">
                        <span class="material-symbols-outlined text-[20px]">cloud_off</span>
                        <span>Modo Offline (Sin Conexión)</span>
                    </div>
                    <p class="font-body-sm text-on-surface-variant">
                        Ejecuta reconocimiento de caracteres (OCR) de forma local. Usa <strong class="text-on-surface">ONNX Runtime Web</strong> compilado en WebAssembly para procesar los modelos de <strong class="text-on-surface">PaddleOCR</strong> directamente en el navegador sin consumir datos.
                    </p>
                    <div class="pt-1 flex flex-wrap gap-x-4 gap-y-2">
                        <a href="https://github.com/PaddlePaddle/PaddleOCR" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-caps text-label-caps text-primary-container hover:underline text-xs">
                            GitHub PaddleOCR <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                        </a>
                        <a href="https://onnxruntime.ai/docs/tutorials/web/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-caps text-label-caps text-primary-container hover:underline text-xs">
                            ONNX Web <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                        </a>
                        <a href="https://www.npmjs.com/package/ppu-paddle-ocr" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-caps text-label-caps text-primary-container hover:underline text-xs">
                            Librería ppu-paddle-ocr <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                        </a>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-surface-container-highest flex justify-end shrink-0">
                <button type="button" onclick="closeApiSupportModal()" class="bg-primary-container text-on-primary hover:bg-primary-fixed transition-colors px-6 py-2 rounded font-label-caps text-label-caps">
                    Cerrar
                </button>
            </div>
        </div>
    </div>

    <script>
        function openApiSupportModal() {
            const modal = document.getElementById('modalSoporteApi');
            if (modal) {
                modal.style.opacity = '1';
                modal.style.pointerEvents = 'auto';
            }
        }
        function closeApiSupportModal() {
            const modal = document.getElementById('modalSoporteApi');
            if (modal) {
                modal.style.opacity = '0';
                modal.style.pointerEvents = 'none';
            }
        }
    </script>
</body>
</html>
