@model ObligatorioIntegrador2026.Models.MovimientosViewModel
@{
    ViewData["Title"] = "Historial de Movimientos";
}



<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <!-- Header Section -->
    <header class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-surface-variant pb-8 mt-8">
        <div class="flex flex-col gap-2">
            <h1 class="font-display text-display text-on-surface">Historial de Movimientos</h1>
            <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl">
                Registro logístico y seguimiento de reubicaciones de colmenas para optimización de floración y polinización.
            </p>
        </div>
        <button onclick="openModal('modalRegistro')" class="bg-primary-container text-on-primary font-label-caps text-label-caps px-6 py-3 rounded hover:bg-primary-fixed transition-colors flex items-center gap-2 shrink-0">
            <span class="material-symbols-outlined text-[18px]">add</span>
            Registrar Nuevo Movimiento
        </button>
    </header>

    <!-- Vigentes Section -->
    <section class="mt-8 mb-12">
        <h2 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface mb-6">En Progreso</h2>
        
        @if (!Model.Vigentes.Any())
        {
            <div class="bg-surface-container border border-surface-variant rounded p-8 text-center">
                <p class="text-on-surface-variant font-body-md">No hay movimientos en progreso actualmente.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var mov in Model.Vigentes)
                {
                    var totalDays = (mov.FechaRegreso.Date - mov.FechaSalida.Date).Days;
                    var passedDays = (DateTime.Now.Date - mov.FechaSalida.Date).Days;
                    var remainingDays = totalDays - passedDays;
                    
                    var isOverdue = remainingDays < 0;
                    var isExpiring = remainingDays >= 0 && remainingDays <= 3;
                    
                    var statusText = isOverdue ? "Pendiente de Retorno" : (isExpiring ? "Por Expirar" : "En Destino");
                    var statusColorClass = isOverdue ? "text-error" : (isExpiring ? "text-primary-container" : "text-primary-container");
                    var statusBgClass = isOverdue ? "bg-error-container text-on-error-container border-error/50" : (isExpiring ? "bg-surface-container-highest text-primary-container border-primary-container/50" : "bg-surface-container-highest text-primary-container border-primary-container/30");
                    var statusIcon = isOverdue ? "warning" : (isExpiring ? "schedule" : "local_shipping");
                    
                    var progressPercentage = totalDays > 0 ? Math.Min(100, Math.Max(0, (int)((float)passedDays / totalDays * 100))) : 100;
                    if (isOverdue) progressPercentage = 100;

                    var barColor = isOverdue ? "bg-error" : "bg-primary-container";

                    <article class="bg-surface-container border @(isOverdue ? "border-error" : "border-surface-variant") rounded-lg p-6 flex flex-col gap-6 relative overflow-hidden group hover:border-outline transition-colors">
                        @if(isOverdue)
                        {
                            <div class="absolute top-0 left-0 w-full h-1 bg-error"></div>
                        }

                        <div class="flex flex-wrap justify-between items-start gap-4 relative">
                            <div class="flex flex-col gap-1 min-w-fit">
                                <span class="font-label-caps text-label-caps text-on-surface-variant">ID COLMENA</span>
                                <span class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface">
                                    @(string.IsNullOrEmpty(mov.Colmena.Identificador) ? mov.Colmena.CodigoEscaneo : mov.Colmena.Identificador)
                                </span>
                            </div>
                            
                            <!-- Three dots menu -->
                            <div class="relative">
                                <button onclick="toggleDropdown('dropdown-@mov.Id')" class="text-on-surface-variant hover:text-primary-container transition-colors p-1 rounded-full outline-none">
                                    <span class="material-symbols-outlined">more_vert</span>
                                </button>
                                <div id="dropdown-@mov.Id" class="hidden absolute right-0 mt-2 w-56 bg-surface-container-high border border-outline-variant rounded shadow-xl z-10 py-1 overflow-hidden">
                                    <button onclick="openEditDateModal(@mov.Id, '@mov.FechaRegreso.ToString("yyyy-MM-dd")')" class="w-full text-left px-4 py-3 font-body-sm text-on-surface hover:bg-surface-variant flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">edit_calendar</span> Editar fecha límite
                                    </button>
                                    <button onclick="updateStatus(@mov.Id, 'Completado')" class="w-full text-left px-4 py-3 font-body-sm text-on-surface hover:bg-surface-variant flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">check_circle</span> Marcar como completado
                                    </button>
                                    <button onclick="updateStatus(@mov.Id, 'Cancelado')" class="w-full text-left px-4 py-3 font-body-sm text-error hover:bg-surface-variant flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">cancel</span> Cancelar movimiento
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="flex">
                            <div class="@statusBgClass border px-3 py-1 rounded font-label-caps text-label-caps flex items-center gap-1 shrink-0 whitespace-nowrap">
                                <span class="material-symbols-outlined text-[14px]">@statusIcon</span>
                                @statusText
                            </div>
                        </div>

                        <div class="flex items-center gap-4 bg-surface-container-highest p-4 rounded-lg border border-outline-variant">
                            <div class="flex-1 flex flex-col">
                                <span class="font-label-caps text-label-caps text-on-surface-variant mb-1">ORIGEN</span>
                                <span class="font-body-md text-body-md text-on-surface">@mov.ApiarioOrigen.Nombre</span>
                            </div>
                            <span class="material-symbols-outlined text-primary-container">arrow_forward</span>
                            <div class="flex-1 flex flex-col text-right">
                                <span class="font-label-caps text-label-caps text-on-surface-variant mb-1">DESTINO</span>
                                <span class="font-body-md text-body-md text-on-surface">@mov.ApiarioDestino.Nombre</span>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div class="flex flex-col gap-1">
                                <span class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">event_note</span> Razón
                                </span>
                                <span class="font-body-md text-body-md text-on-surface truncate" title="@mov.Razon">@mov.Razon</span>
                            </div>
                            <div class="flex flex-col gap-1 text-right">
                                <span class="font-label-caps text-label-caps text-on-surface-variant flex items-center justify-end gap-1">
                                    <span class="material-symbols-outlined text-[14px]">calendar_today</span> Salida
                                </span>
                                <span class="font-body-md text-body-md text-on-surface">@mov.FechaSalida.ToString("dd MMM yyyy")</span>
                            </div>
                        </div>

                        <div class="flex flex-col gap-2 mt-auto pt-4 border-t border-surface-variant">
                            <div class="flex justify-between font-label-caps text-label-caps">
                                <span class="text-on-surface-variant">Duración: @totalDays Días</span>
                                <span class="@statusColorClass">Día @(passedDays < 0 ? 0 : passedDays)</span>
                            </div>
                            <div class="w-full h-[4px] bg-surface-variant rounded-full overflow-hidden">
                                <div class="h-full @barColor" style="width: @progressPercentage%"></div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <!-- Pasados Section -->
    <section class="mb-12">
        <h2 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface mb-6">Historial</h2>
        
        @if (!Model.Pasados.Any())
        {
            <div class="bg-surface-container border border-surface-variant rounded p-8 text-center">
                <p class="text-on-surface-variant font-body-md">No hay historial de movimientos.</p>
            </div>
        }
        else
        {
            <div class="bg-surface-container border border-surface-variant rounded overflow-hidden">
                <div class="overflow-x-auto md:overflow-visible responsive-table">
                    <table class="w-full text-left border-collapse" id="historyTable">
                        <thead>
                            <tr class="border-b border-surface-variant bg-surface-container-low">
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">ID Colmena</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Origen</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Destino</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Razón</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Salida</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap">Retorno</th>
                                <th class="p-4 font-label-caps text-label-caps text-on-surface-variant whitespace-nowrap text-right">Estado</th>
                            </tr>
                        </thead>
                        <tbody id="historyBody">
                            @foreach (var mov in Model.Pasados)
                            {
                                <tr class="border-b border-surface-variant hover:bg-surface-container-high transition-colors history-row">
                                    <td data-label="ID Colmena" class="p-4 font-body-sm text-on-surface whitespace-nowrap md:whitespace-normal">
                                        @(string.IsNullOrEmpty(mov.Colmena.Identificador) ? mov.Colmena.CodigoEscaneo : mov.Colmena.Identificador)
                                    </td>
                                    <td data-label="Origen" class="p-4 font-body-sm text-on-surface-variant whitespace-nowrap md:whitespace-normal">@mov.ApiarioOrigen.Nombre</td>
                                    <td data-label="Destino" class="p-4 font-body-sm text-on-surface-variant whitespace-nowrap md:whitespace-normal">@mov.ApiarioDestino.Nombre</td>
                                    <td data-label="Razón" class="p-4 font-body-sm text-on-surface-variant max-w-[200px] truncate whitespace-nowrap md:whitespace-normal" title="@mov.Razon">@mov.Razon</td>
                                    <td data-label="Salida" class="p-4 font-body-sm text-on-surface-variant whitespace-nowrap md:whitespace-normal">@mov.FechaSalida.ToString("dd MMM yyyy")</td>
                                    <td data-label="Retorno" class="p-4 font-body-sm text-on-surface-variant whitespace-nowrap md:whitespace-normal">@mov.FechaRegreso.ToString("dd MMM yyyy")</td>
                                    <td data-label="Estado" class="p-4 font-body-sm whitespace-nowrap text-right">
                                        @if(mov.Estado == "Completado")
                                        {
                                            <span class="inline-flex items-center gap-1 text-primary-container bg-surface-container-highest px-2 py-1 rounded font-label-caps text-label-caps">
                                                <span class="material-symbols-outlined text-[14px]">check_circle</span> Completado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 text-on-surface-variant bg-surface-container-highest px-2 py-1 rounded font-label-caps text-label-caps">
                                                <span class="material-symbols-outlined text-[14px]">cancel</span> Cancelado
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Pagination Controls -->
                <div class="p-4 flex items-center justify-between border-t border-surface-variant">
                    <span class="font-body-sm text-on-surface-variant" id="pageInfo">Mostrando 1-10</span>
                    <div class="flex items-center gap-1">
                        <button onclick="changePage(-1)" class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded hover:text-primary-container hover:border-primary-container transition-colors disabled:opacity-50" id="btnPrevPage">
                            <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                        </button>
                        <div id="paginationNumbers" class="flex items-center gap-1">
                            <!-- Filled by JS -->
                        </div>
                        <button onclick="changePage(1)" class="w-8 h-8 flex items-center justify-center border border-outline-variant rounded hover:text-primary-container hover:border-primary-container transition-colors disabled:opacity-50" id="btnNextPage">
                            <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                        </button>
                    </div>
                </div>
            </div>
        }
    </section>
</div>

<!-- Modal Registrar Movimiento -->
<div id="modalRegistro" class="fixed inset-0 z-50 flex items-center justify-center modal-backdrop bg-black/75 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-lg modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface">Nuevo Movimiento</h4>
            <button type="button" onclick="closeModal('modalRegistro')" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar">
            <form id="formRegistro" class="flex flex-col gap-4">
                <div class="flex flex-col gap-2">
                    <label class="font-label-caps text-label-caps text-on-surface">Apiario de Origen</label>
                    <select id="origenSelect" onchange="loadColmenas()" class="bg-surface-container-high border border-outline-variant text-on-surface font-body-md rounded p-3 focus:outline-none focus:border-primary-container w-full" required>
                        <option value="">Seleccione apiario...</option>
                        @foreach(var apiario in Model.Apiarios)
                        {
                            <option value="@apiario.Id">@apiario.Nombre</option>
                        }
                    </select>
                </div>
                
                <div class="flex flex-col gap-2">
                    <label class="font-label-caps text-label-caps text-on-surface">Colmena</label>
                    <select id="colmenaSelect" class="bg-surface-container-high border border-outline-variant text-on-surface font-body-md rounded p-3 focus:outline-none focus:border-primary-container w-full disabled:opacity-50" disabled required>
                        <option value="">Primero seleccione origen...</option>
                    </select>
                </div>

                <div class="flex flex-col gap-2">
                    <label class="font-label-caps text-label-caps text-on-surface">Apiario de Destino</label>
                    <select id="destinoSelect" class="bg-surface-container-high border border-outline-variant text-on-surface font-body-md rounded p-3 focus:outline-none focus:border-primary-container w-full" required>
                        <option value="">Seleccione destino...</option>
                        @foreach(var apiario in Model.Apiarios)
                        {
                            <option value="@apiario.Id">@apiario.Nombre</option>
                        }
                    </select>
                </div>

                <div class="flex flex-col gap-2">
                    <label class="font-label-caps text-label-caps text-on-surface">Razón del movimiento</label>
                    <input type="text" id="razonInput" class="bg-surface-container-high border border-outline-variant text-on-surface font-body-md rounded p-3 focus:outline-none focus:border-primary-container w-full" placeholder="Ej: Polinización, Refugio, etc." required maxlength="200" />
                </div>

                <div class="flex flex-col gap-2">
                    <label class="font-label-caps text-label-caps text-on-surface">Fecha de Regreso Estimada</label>
                    <input type="date" id="fechaRegresoInput" onchange="calcularDuracion()" class="bg-surface-container-high border border-outline-variant text-on-surface font-body-md rounded p-3 focus:outline-none focus:border-primary-container w-full" style="color-scheme: dark;" required />
                    <span id="duracionText" class="font-body-sm text-primary-container hidden mt-1"></span>
                </div>
                
                <div class="pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-end gap-3 mt-4">
                    <button type="button" onclick="closeModal('modalRegistro')" class="border border-outline text-on-surface hover:bg-surface-container-high px-5 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex transition-colors">
                        Cancelar
                    </button>
                    <button type="button" onclick="submitRegistro()" id="btnSubmitRegistro" class="bg-primary-container text-on-primary hover:bg-primary-fixed px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex transition-colors">
                        Registrar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Editar Fecha -->
<div id="modalEditDate" class="fixed inset-0 z-50 flex items-center justify-center modal-backdrop bg-black/75 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-sm modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 class="font-headline-lg text-lg font-bold text-on-surface">Editar Fecha Límite</h4>
            <button type="button" onclick="closeModal('modalEditDate')" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar">
            <input type="hidden" id="editMovimientoId" />
            <div class="flex flex-col gap-2">
                <label class="font-label-caps text-label-caps text-on-surface">Nueva Fecha</label>
                <input type="date" id="editFechaInput" class="bg-surface-container-high border border-outline-variant text-on-surface font-body-md rounded p-3 focus:outline-none focus:border-primary-container w-full" style="color-scheme: dark;" required />
            </div>
            <div class="pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-end gap-3 mt-6">
                <button type="button" onclick="closeModal('modalEditDate')" class="border border-outline text-on-surface hover:bg-surface-container-high px-5 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex transition-colors">
                    Cancelar
                </button>
                <button type="button" onclick="submitEditDate()" id="btnSubmitEditDate" class="bg-primary-container text-on-primary hover:bg-primary-fixed px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex transition-colors">
                    Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmación Genérico / Alerta -->
<div id="modalConfirmacion" class="fixed inset-0 z-[60] flex items-center justify-center modal-backdrop bg-black/85 modal-hidden p-4">
    <div class="bg-surface-container border border-outline-variant rounded w-full max-w-md modal-container shadow-2xl flex flex-col max-h-[75vh] md:max-h-[85vh]">
        <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
            <h4 id="confirmTitle" class="font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2">
                <span id="confirmIcon" class="material-symbols-outlined text-[20px]">warning</span>
                <span id="confirmTitleText">Confirmación</span>
            </h4>
            <button type="button" onclick="closeConfirmModal()" class="text-on-surface-variant hover:text-primary-container transition-colors p-1">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto grow custom-scrollbar space-y-4 text-center">
            <p id="confirmMessage" class="font-body-md text-body-md text-on-surface-variant">¿Estás seguro?</p>
            <p id="confirmSubMessage" class="text-sm font-medium hidden"></p>
            <div class="pt-4 border-t border-surface-container-highest flex flex-col sm:flex-row justify-center gap-3 mt-4">
                <button type="button" id="btnCancelConfirm" onclick="closeConfirmModal()" class="border border-outline text-on-surface hover:bg-surface-container-high transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                    Cancelar
                </button>
                <button type="button" id="btnConfirmAction" class="transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex">
                    Confirmar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Custom Alert/Confirm System
        let confirmCallback = null;

        // Modal Visual Controls are now loaded globally from _Layout.cshtml

        function showConfirm(title, message, confirmText, isDestructive, onConfirm) {
            const titleTextEl = document.getElementById('confirmTitleText');
            const titleEl = titleTextEl.parentElement;
            const iconEl = document.getElementById('confirmIcon');
            const messageEl = document.getElementById('confirmMessage');
            const subMessageEl = document.getElementById('confirmSubMessage');
            const btnConfirm = document.getElementById('btnConfirmAction');
            const btnCancel = document.getElementById('btnCancelConfirm');

            titleTextEl.textContent = title;
            messageEl.textContent = message;

            if (isDestructive) {
                // Style as destructive (error/red)
                titleEl.className = "font-headline-lg text-lg font-bold text-error flex items-center gap-2";
                iconEl.textContent = "warning";
                iconEl.className = "material-symbols-outlined text-[20px] text-error";
                
                subMessageEl.textContent = "Esta acción no se puede deshacer.";
                subMessageEl.className = "text-sm text-error/80 font-medium block";
                subMessageEl.classList.remove('hidden');

                btnConfirm.textContent = confirmText;
                btnConfirm.className = "bg-error-container/30 border border-error text-error hover:bg-error/20 transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex";
            } else {
                // Style as constructive (primary/yellow)
                titleEl.className = "font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2";
                iconEl.textContent = "check_circle";
                iconEl.className = "material-symbols-outlined text-[20px] text-primary-container";
                
                subMessageEl.classList.add('hidden');

                btnConfirm.textContent = confirmText;
                btnConfirm.className = "bg-primary-container text-on-primary hover:bg-primary-fixed transition-colors px-6 py-2.5 rounded font-label-caps text-label-caps w-full sm:w-auto text-center justify-center flex";
            }

            btnCancel.classList.remove('hidden'); // Always show cancel for confirmation
            confirmCallback = onConfirm;

            const modal = document.getElementById('modalConfirmacion');
            showModal(modal);
        }

        function closeConfirmModal() {
            const modal = document.getElementById('modalConfirmacion');
            hideModal(modal);
            confirmCallback = null;
        }

        document.getElementById('btnConfirmAction').addEventListener('click', function() {
            if (confirmCallback) {
                confirmCallback();
            }
            closeConfirmModal();
        });
        // Dropdown toggle logic
        function toggleDropdown(id) {
            const el = document.getElementById(id);
            if (el.classList.contains('hidden')) {
                // close others
                document.querySelectorAll('[id^="dropdown-"]').forEach(d => d.classList.add('hidden'));
                el.classList.remove('hidden');
            } else {
                el.classList.add('hidden');
            }
        }

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.relative')) {
                document.querySelectorAll('[id^="dropdown-"]').forEach(d => d.classList.add('hidden'));
            }
        });

        // Modals
        function openModal(id) {
            const modal = document.getElementById(id);
            showModal(modal);
            if (id === 'modalRegistro') {
                document.getElementById('formRegistro').reset();
                document.getElementById('colmenaSelect').innerHTML = '<option value="">Primero seleccione origen...</option>';
                document.getElementById('colmenaSelect').disabled = true;
                document.getElementById('duracionText').classList.add('hidden');
            }
        }

        function closeModal(id) {
            const modal = document.getElementById(id);
            hideModal(modal);
        }

        // Load Colmenas
        async function loadColmenas() {
            const apiarioId = document.getElementById('origenSelect').value;
            const colSelect = document.getElementById('colmenaSelect');
            const destSelect = document.getElementById('destinoSelect');

            if (!apiarioId) {
                colSelect.innerHTML = '<option value="">Primero seleccione origen...</option>';
                colSelect.disabled = true;
                
                // Reset dest options
                Array.from(destSelect.options).forEach(opt => opt.disabled = false);
                return;
            }

            // Disable same dest apiary
            Array.from(destSelect.options).forEach(opt => {
                if (opt.value === apiarioId) opt.disabled = true;
                else opt.disabled = false;
            });

            if (destSelect.value === apiarioId) {
                destSelect.value = '';
            }

            colSelect.disabled = true;
            colSelect.innerHTML = '<option value="">Cargando colmenas...</option>';

            try {
                const res = await fetch(`/Mas/GetColmenasPorApiario?apiarioId=${apiarioId}`);
                const data = await res.json();
                
                if (data.success && data.data.length > 0) {
                    colSelect.innerHTML = '<option value="">Seleccione colmena...</option>';
                    data.data.forEach(c => {
                        colSelect.innerHTML += `<option value="${c.id}">${c.text}</option>`;
                    });
                    colSelect.disabled = false;
                } else {
                    colSelect.innerHTML = '<option value="">No hay colmenas en este apiario</option>';
                }
            } catch (err) {
                colSelect.innerHTML = '<option value="">Error al cargar</option>';
            }
        }

        function calcularDuracion() {
            const fechaVal = document.getElementById('fechaRegresoInput').value;
            const duracionEl = document.getElementById('duracionText');
            
            if (!fechaVal) {
                duracionEl.classList.add('hidden');
                return;
            }

            const today = new Date();
            today.setHours(0,0,0,0);
            
            // Reemplazar los guiones por barras para que no tome UTC erróneo, o parsearlo de a partes
            const parts = fechaVal.split('-');
            const targetDate = new Date(parts[0], parts[1]-1, parts[2]);
            
            const diffTime = targetDate - today;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); 

            if (diffDays <= 0) {
                duracionEl.textContent = 'La fecha debe ser en el futuro.';
                duracionEl.classList.remove('hidden', 'text-primary-container');
                duracionEl.classList.add('text-error');
            } else {
                duracionEl.textContent = `Duración estimada: ${diffDays} días`;
                duracionEl.classList.remove('hidden', 'text-error');
                duracionEl.classList.add('text-primary-container');
            }
        }

        async function submitRegistro() {
            const origen = document.getElementById('origenSelect').value;
            const colmena = document.getElementById('colmenaSelect').value;
            const destino = document.getElementById('destinoSelect').value;
            const razon = document.getElementById('razonInput').value;
            const fecha = document.getElementById('fechaRegresoInput').value;

            if (!origen || !colmena || !destino || !razon || !fecha) {
                showToast('Por favor complete todos los campos obligatorios.', 'error');
                return;
            }

            const btn = document.getElementById('btnSubmitRegistro');
            btn.disabled = true;
            btn.textContent = 'Guardando...';

            try {
                const res = await fetch('/Mas/RegistrarMovimiento', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        ApiarioOrigenId: parseInt(origen),
                        ColmenaId: parseInt(colmena),
                        ApiarioDestinoId: parseInt(destino),
                        Razon: razon,
                        FechaRegreso: fecha
                    })
                });

                const data = await res.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    showToast(data.message || 'Error al guardar el movimiento.', 'error');
                    btn.disabled = false;
                    btn.textContent = 'Registrar';
                }
            } catch (err) {
                showToast('Hubo un problema al intentar comunicarse con el servidor.', 'error');
                btn.disabled = false;
                btn.textContent = 'Registrar';
            }
        }

        function updateStatus(id, estado) {
            const isDestructive = estado === 'Cancelado';
            const actionVerb = isDestructive ? 'cancelar' : 'completar';
            const title = isDestructive ? 'Cancelar Movimiento' : 'Completar Movimiento';
            const message = `¿Estás seguro de que deseas ${actionVerb} este traslado? ${isDestructive ? 'Esta acción no se puede deshacer y la colmena permanecerá en su lugar.' : 'La colmena quedará oficialmente registrada en su apiario de destino.'}`;
            const btnText = isDestructive ? 'Sí, Cancelar' : 'Sí, Completar';

            showConfirm(title, message, btnText, isDestructive, async () => {
                try {
                    const res = await fetch(`/Mas/ActualizarEstadoMovimiento?id=${id}&nuevoEstado=${encodeURIComponent(estado)}`, {
                        method: 'POST'
                    });
                    const data = await res.json();
                    if (data.success) {
                        window.location.reload();
                    } else {
                        showToast(data.message || 'Error al actualizar el estado.', 'error');
                    }
                } catch (err) {
                    showToast('No se pudo contactar al servidor.', 'error');
                }
            });
        }

        function openEditDateModal(id, currentDate) {
            document.getElementById('dropdown-' + id).classList.add('hidden');
            document.getElementById('editMovimientoId').value = id;
            document.getElementById('editFechaInput').value = currentDate;
            const modal = document.getElementById('modalEditDate');
            showModal(modal);
        }

        async function submitEditDate() {
            const id = document.getElementById('editMovimientoId').value;
            const fecha = document.getElementById('editFechaInput').value;

            if (!fecha) {
                showToast('Seleccione una fecha de retorno válida.', 'error');
                return;
            }

            const btn = document.getElementById('btnSubmitEditDate');
            btn.disabled = true;
            btn.textContent = 'Guardando...';

            try {
                const res = await fetch(`/Mas/EditarFechaRegreso?id=${id}&nuevaFecha=${encodeURIComponent(fecha)}`, {
                    method: 'POST'
                });
                const data = await res.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    showToast(data.message || 'Error al actualizar la fecha.', 'error');
                    btn.disabled = false;
                    btn.textContent = 'Guardar';
                }
            } catch (err) {
                showToast('Hubo un error al guardar la nueva fecha.', 'error');
                btn.disabled = false;
                btn.textContent = 'Guardar';
            }
        }

        // Pagination
        let currentPage = 1;
        const rowsPerPage = 10;
        const rows = document.querySelectorAll('.history-row');

        function renderPaginationControls(totalPages) {
            const paginationNumbers = document.getElementById('paginationNumbers');
            if (!paginationNumbers) return;
            paginationNumbers.innerHTML = '';
            
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                    const btn = document.createElement('button');
                    btn.className = `w-8 h-8 flex items-center justify-center border rounded font-body-sm transition-colors ${i === currentPage ? 'bg-primary-container text-on-primary border-primary-container' : 'border-outline-variant text-on-surface hover:text-primary-container hover:border-primary-container'}`;
                    btn.textContent = i;
                    btn.addEventListener('click', () => {
                        showPage(i);
                    });
                    paginationNumbers.appendChild(btn);
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                    const dots = document.createElement('span');
                    dots.className = 'w-8 h-8 flex items-center justify-center text-on-surface-variant font-body-sm';
                    dots.textContent = '...';
                    paginationNumbers.appendChild(dots);
                }
            }
        }

        function showPage(page) {
            const totalPages = Math.ceil(rows.length / rowsPerPage) || 1;
            if (page < 1) page = 1;
            if (page > totalPages) page = totalPages;
            
            currentPage = page;
            
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;

            rows.forEach((row, index) => {
                if (index >= start && index < end) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });

            const displayedStart = rows.length === 0 ? 0 : start + 1;
            const displayedEnd = Math.min(end, rows.length);
            document.getElementById('pageInfo').innerText = `Mostrando ${displayedStart}-${displayedEnd} de ${rows.length}`;

            document.getElementById('btnPrevPage').disabled = currentPage === 1;
            document.getElementById('btnNextPage').disabled = currentPage === totalPages;
            renderPaginationControls(totalPages);
        }

        function changePage(delta) {
            showPage(currentPage + delta);
        }

        if (rows.length > 0) {
            showPage(1);
        }
    </script>
}
