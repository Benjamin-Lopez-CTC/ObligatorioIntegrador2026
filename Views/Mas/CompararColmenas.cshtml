@{
    ViewData["Title"] = "Comparar Colmenas";
}

<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<!-- Header Section -->
<section class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mt-8">
    <div>
        <h2 class="font-display text-display text-on-surface mb-2">Comparar Colmenas</h2>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl">
            Análisis cruzado de métricas vitales y rendimiento de producción. Seleccione los identificadores de las colmenas para visualizar las diferencias clave.
        </p>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <button class="md:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-transparent border border-primary-container text-primary-container hover:bg-primary-container/10 transition-colors rounded font-label-caps text-label-caps">
            <span class="material-symbols-outlined text-[18px]">tune</span> Filtrar
        </button>
    </div>
</section>
<!-- Selection Control -->
<div class="bg-surface-container-low border border-outline-variant rounded p-6 mt-8">
    <div class="flex flex-col md:flex-row gap-6 items-center">
        <div class="flex-1 w-full relative">
            <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2">COLMENA A</label>
            <select class="w-full bg-surface-container border border-outline-variant text-on-surface font-body-md p-3 rounded focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container appearance-none transition-colors">
                <option selected="">COL-042-NTE</option>
                <option>COL-085-SJO</option>
                <option>COL-112-EST</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-10 text-on-surface-variant pointer-events-none">expand_more</span>
        </div>
        <div class="flex items-center justify-center h-12 w-12 rounded-full border border-outline-variant bg-surface-container-high my-2 md:my-0 mt-6 md:mt-8 shrink-0">
            <span class="material-symbols-outlined text-primary-container">compare_arrows</span>
        </div>
        <div class="flex-1 w-full relative">
            <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2">COLMENA B</label>
            <select class="w-full bg-surface-container border border-outline-variant text-on-surface font-body-md p-3 rounded focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container appearance-none transition-colors">
                <option>COL-042-NTE</option>
                <option selected="">COL-085-SJO</option>
                <option>COL-112-EST</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-10 text-on-surface-variant pointer-events-none">expand_more</span>
        </div>
    </div>
</div>
<!-- KPI Comparison -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
    <!-- KPI 1: Peso -->
    <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col hover:border-primary-container/50 transition-colors">
        <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex items-center justify-between">
            PESO (KG)
            <span class="material-symbols-outlined text-[18px]">scale</span>
        </h3>
        <div class="flex items-end justify-between mb-3">
            <div>
                <div class="text-[10px] text-primary-container mb-1 font-label-caps">COL-042-NTE</div>
                <div class="font-display text-headline-lg text-on-surface">45.2 <span class="text-body-sm">kg</span></div>
            </div>
            <div class="text-right">
                <div class="text-[10px] text-on-surface-variant mb-1 font-label-caps">COL-085-SJO</div>
                <div class="font-display text-headline-lg text-on-surface-variant">42.8 <span class="text-body-sm">kg</span></div>
            </div>
        </div>
        <div class="mt-auto">
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full mb-1.5 flex">
                <div class="bg-primary-container h-[4px] rounded-full" style="width: 90%;"></div>
            </div>
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full flex">
                <div class="bg-surface-variant h-[4px] rounded-full" style="width: 85%;"></div>
            </div>
            <div class="flex justify-between mt-3 font-label-caps text-[10px] text-on-surface-variant">
                <span class="text-primary-container">+2.4 kg Dif.</span>
                <span class="">Base: COL-042</span>
            </div>
        </div>
    </div>
    <!-- KPI 2: Temp. Int. -->
    <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col hover:border-primary-container/50 transition-colors">
        <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex items-center justify-between">
            TEMP. INT. (°C)
            <span class="material-symbols-outlined text-[18px]">thermostat</span>
        </h3>
        <div class="flex items-end justify-between mb-3">
            <div>
                <div class="text-[10px] text-primary-container mb-1 font-label-caps">COL-042-NTE</div>
                <div class="font-display text-headline-lg text-on-surface">34.5<span class="text-body-sm">°C</span></div>
            </div>
            <div class="text-right">
                <div class="text-[10px] text-on-surface-variant mb-1 font-label-caps">COL-085-SJO</div>
                <div class="font-display text-headline-lg text-on-surface-variant">32.0<span class="text-body-sm">°C</span></div>
            </div>
        </div>
        <div class="mt-auto">
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full mb-1.5 flex">
                <div class="bg-primary-container h-[4px] rounded-full" style="width: 86%;"></div>
            </div>
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full flex">
                <div class="bg-surface-variant h-[4px] rounded-full" style="width: 80%;"></div>
            </div>
            <div class="flex justify-between mt-3 font-label-caps text-[10px] text-on-surface-variant">
                <span class="text-primary-container">-2.5°C Dif.</span>
                <span class="">Base: COL-042</span>
            </div>
        </div>
    </div>
    <!-- KPI 3: Estado -->
    <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col hover:border-primary-container/50 transition-colors">
        <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex items-center justify-between">
            ESTADO GENERAL
            <span class="material-symbols-outlined text-[18px]">health_metrics</span>
        </h3>
        <div class="flex items-end justify-between mb-3">
            <div>
                <div class="text-[10px] text-primary-container mb-1 font-label-caps">COL-042-NTE</div>
                <div class="inline-flex items-center gap-1 text-primary-container font-bold"><span class="material-symbols-outlined text-[20px]">check_circle</span>Óptimo</div>
            </div>
            <div class="text-right">
                <div class="text-[10px] text-on-surface-variant mb-1 font-label-caps">COL-085-SJO</div>
                <div class="inline-flex items-center gap-1 text-error font-bold"><span class="material-symbols-outlined text-[20px]">warning</span>Alerta</div>
            </div>
        </div>
        <div class="mt-auto">
            <div class="grid grid-cols-2 gap-2 mt-4">
                <div class="h-1 bg-primary-container rounded-full"></div>
                <div class="h-1 bg-error rounded-full"></div>
            </div>
            <div class="flex justify-between mt-3 font-label-caps text-[10px] text-on-surface-variant">
                <span class="text-error">Divergencia</span>
                <span class="">Comparativa de Salud</span>
            </div>
        </div>
    </div>
</div>
<!-- Detailed Comparison Table -->
<div class="bg-surface-container-low border border-outline-variant rounded mt-8 mb-12 responsive-table p-4 md:p-0">
    <div class="p-6 border-b border-outline-variant flex justify-between items-center md:rounded-t">
        <h3 class="font-headline-lg-mobile text-[20px] font-semibold text-on-surface">Métricas Detalladas</h3>
    </div>
    <div class="overflow-x-auto md:overflow-visible">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container border-b border-outline-variant font-label-caps text-label-caps text-on-surface-variant">
                    <th class="p-4 font-medium">Dato / Métrica</th>
                    <th class="p-4 font-medium text-primary-container border-l border-outline-variant">COL-042-NTE</th>
                    <th class="p-4 font-medium border-l border-outline-variant">COL-085-SJO</th>
                    <th class="p-4 font-medium border-l border-outline-variant">Observación</th>
                </tr>
            </thead>
            <tbody class="font-body-sm text-on-surface">
                <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                    <td data-label="DATO / MÉTRICA" class="p-4 border-b border-surface-container-highest md:border-none">ID Colmena</td>
                    <td data-label="COLMENA A" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant font-label-caps text-primary-container">#HIVE-0042</td>
                    <td data-label="COLMENA B" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant font-label-caps text-on-surface-variant">#HIVE-0089</td>
                    <td data-label="OBSERVACIÓN" class="p-4 md:border-none md:border-l md:border-outline-variant text-on-surface-variant">N/A</td>
                </tr>
                <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                    <td data-label="DATO / MÉTRICA" class="p-4 border-b border-surface-container-highest md:border-none">Apiario de Origen</td>
                    <td data-label="COLMENA A" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant">Sector Norte Alpha</td>
                    <td data-label="COLMENA B" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant">Sector Norte Alpha</td>
                    <td data-label="OBSERVACIÓN" class="p-4 md:border-none md:border-l md:border-outline-variant text-on-surface-variant">Iguales</td>
                </tr>
                <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                    <td data-label="DATO / MÉTRICA" class="p-4 border-b border-surface-container-highest md:border-none">Estado</td>
                    <td data-label="COLMENA A" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant">
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 border border-primary-container rounded bg-primary-container/10 text-primary-container font-label-caps text-[10px]"><span class="material-symbols-outlined text-[12px]">check_circle</span>Óptimo</span>
                    </td>
                    <td data-label="COLMENA B" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant">
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 border border-error rounded bg-error/10 text-error font-label-caps text-[10px]"><span class="material-symbols-outlined text-[12px]">warning</span>Alerta</span>
                    </td>
                    <td data-label="OBSERVACIÓN" class="p-4 md:border-none md:border-l md:border-outline-variant text-error">Revisión Alerta</td>
                </tr>
                <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                    <td data-label="DATO / MÉTRICA" class="p-4 border-b border-surface-container-highest md:border-none">Peso (kg)</td>
                    <td data-label="COLMENA A" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant">45.2</td>
                    <td data-label="COLMENA B" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant">42.8</td>
                    <td data-label="OBSERVACIÓN" class="p-4 md:border-none md:border-l md:border-outline-variant text-on-surface-variant">-2.4 kg</td>
                </tr>
                <tr class="hover:bg-surface-container transition-colors">
                    <td data-label="DATO / MÉTRICA" class="p-4 border-b border-surface-container-highest md:border-none">Temp. Int.</td>
                    <td data-label="COLMENA A" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant">34.5°C</td>
                    <td data-label="COLMENA B" class="p-4 border-b border-surface-container-highest md:border-none md:border-l md:border-outline-variant">32.0°C</td>
                    <td data-label="OBSERVACIÓN" class="p-4 md:border-none md:border-l md:border-outline-variant text-on-surface-variant">-2.5°C</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
</div>
