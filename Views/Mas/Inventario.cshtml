@{
    ViewData["Title"] = "Inventario de Equipamiento";
}

<style>
    .icon-fill {
         font-variation-settings: 'FILL' 1;
    }
</style>

<!-- Hero Section -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 mt-8">
    <div>
        <h2 class="font-display text-display text-on-surface mb-2 tracking-tight">Inventario de Equipamiento</h2>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl">Gestión de herramientas, insumos médicos y materiales de trabajo para operaciones apícolas.</p>
    </div>
    <button class="bg-primary-container text-on-primary-container hover:bg-primary-fixed transition-colors px-6 py-3 rounded font-label-caps text-label-caps flex items-center justify-center gap-2 whitespace-nowrap shadow-sm">
        <span class="material-symbols-outlined text-[18px]">add</span>
        Registrar Nuevo Equipo
    </button>
</div>
<!-- Bento Grid Layout for Inventory -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter mb-12">
    <!-- Category: Herramientas (Spans 8 cols) -->
    <section class="md:col-span-8 bg-surface-container-low border border-outline-variant rounded-lg p-6">
        <div class="flex items-center gap-3 mb-6 pb-4 border-b border-surface-container-highest">
            <span class="material-symbols-outlined text-primary-container icon-fill">handyman</span>
            <h2 class="font-headline-lg text-headline-lg text-on-surface">Herramientas</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Item Card -->
            <div class="bg-background border border-outline-variant p-4 rounded group hover:border-primary-container transition-colors relative overflow-hidden">
                <div class="absolute top-0 left-0 w-1 h-full bg-outline-variant group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-start mb-2 pl-3">
                    <h3 class="font-body-md text-body-md font-semibold text-on-surface">Ahumador Inoxidable</h3>
                    <span class="font-label-caps text-label-caps bg-surface-container text-primary-container px-2 py-1 rounded border border-outline-variant">Stock: 12</span>
                </div>
                <p class="font-body-sm text-body-sm text-on-surface-variant mb-4 pl-3">Ahumador estándar de 10x25cm con fuelle de cuero sintético.</p>
                <div class="flex justify-between items-end pl-3">
                    <span class="font-label-caps text-label-caps text-on-surface">$45.00 / u</span>
                    <button class="text-primary-container hover:text-primary-fixed transition-colors">
                        <span class="material-symbols-outlined text-sm">edit</span>
                    </button>
                </div>
            </div>
            <!-- Item Card -->
            <div class="bg-background border border-outline-variant p-4 rounded group hover:border-primary-container transition-colors relative overflow-hidden">
                <div class="absolute top-0 left-0 w-1 h-full bg-outline-variant group-hover:bg-primary-container transition-colors"></div>
                <div class="flex justify-between items-start mb-2 pl-3">
                    <h3 class="font-body-md text-body-md font-semibold text-on-surface">Palanca de Manejo</h3>
                    <span class="font-label-caps text-label-caps bg-surface-container text-primary-container px-2 py-1 rounded border border-outline-variant">Stock: 24</span>
                </div>
                <p class="font-body-sm text-body-sm text-on-surface-variant mb-4 pl-3">Pinza y palanca universal para extracción de marcos.</p>
                <div class="flex justify-between items-end pl-3">
                    <span class="font-label-caps text-label-caps text-on-surface">$15.50 / u</span>
                    <button class="text-primary-container hover:text-primary-fixed transition-colors">
                        <span class="material-symbols-outlined text-sm">edit</span>
                    </button>
                </div>
            </div>
        </div>
    </section>
    <!-- Category: Medicamentos (Spans 4 cols) -->
    <section class="md:col-span-4 bg-surface-container-low border border-outline-variant rounded-lg p-6 flex flex-col">
        <div class="flex items-center gap-3 mb-6 pb-4 border-b border-surface-container-highest">
            <span class="material-symbols-outlined text-primary-container icon-fill">medication</span>
            <h2 class="font-headline-lg text-headline-lg text-on-surface">Medicamentos</h2>
        </div>
        <div class="flex flex-col gap-4 flex-1">
            <!-- Minimal List Item -->
            <div class="flex justify-between items-center pb-3 border-b border-surface-container-highest group cursor-pointer">
                <div>
                    <h3 class="font-body-sm text-body-sm text-on-surface font-medium group-hover:text-primary-container transition-colors">Ácido Oxálico (Glicerina)</h3>
                    <span class="font-label-caps text-label-caps text-on-surface-variant text-[10px]">Tratamiento Varroa</span>
                </div>
                <div class="text-right">
                    <div class="font-label-caps text-label-caps text-on-surface">50 Tiras</div>
                    <div class="font-label-caps text-label-caps text-primary-container text-[10px]">$12.00</div>
                </div>
            </div>
            <!-- Minimal List Item -->
            <div class="flex justify-between items-center pb-3 border-b border-surface-container-highest group cursor-pointer">
                <div>
                    <h3 class="font-body-sm text-body-sm text-on-surface font-medium group-hover:text-primary-container transition-colors">Amitraz (Tiras)</h3>
                    <span class="font-label-caps text-label-caps text-on-surface-variant text-[10px]">Tratamiento Varroa</span>
                </div>
                <div class="text-right">
                    <div class="font-label-caps text-label-caps text-on-surface">15 Pqts</div>
                    <div class="font-label-caps text-label-caps text-primary-container text-[10px]">$22.50</div>
                </div>
            </div>
            <button class="mt-auto w-full py-2 border border-outline-variant text-on-surface hover:border-primary-container hover:text-primary-container rounded transition-colors font-label-caps text-label-caps flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">add_shopping_cart</span>
                Solicitar Insumos
            </button>
        </div>
    </section>
    <!-- Category: Materiales (Spans 12 cols) -->
    <section class="md:col-span-12 bg-surface-container-low border border-outline-variant rounded-lg p-6 mt-4">
        <div class="flex items-center gap-3 mb-6 pb-4 border-b border-surface-container-highest">
            <span class="material-symbols-outlined text-primary-container icon-fill">inventory_2</span>
            <h2 class="font-headline-lg text-headline-lg text-on-surface">Materiales y Consumibles</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-surface-container-highest">
                        <th class="font-label-caps text-label-caps text-on-surface-variant py-3 px-4">Descripción</th>
                        <th class="font-label-caps text-label-caps text-on-surface-variant py-3 px-4">Tipo</th>
                        <th class="font-label-caps text-label-caps text-on-surface-variant py-3 px-4 text-right">Stock</th>
                        <th class="font-label-caps text-label-caps text-on-surface-variant py-3 px-4 text-right">Precio Un.</th>
                        <th class="font-label-caps text-label-caps text-on-surface-variant py-3 px-4 text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-b border-surface-container-highest hover:bg-surface-container transition-colors">
                        <td class="font-body-sm text-body-sm text-on-surface py-3 px-4">Alzas Melarias (Media)</td>
                        <td class="font-body-sm text-body-sm text-on-surface-variant py-3 px-4">Madera</td>
                        <td class="font-body-sm text-body-sm text-on-surface py-3 px-4 text-right">120</td>
                        <td class="font-label-caps text-label-caps text-on-surface py-3 px-4 text-right">$8.00</td>
                        <td class="py-3 px-4 text-center">
                            <span class="inline-block px-2 py-1 bg-surface-container-high border border-outline-variant rounded font-label-caps text-label-caps text-on-surface text-[10px]">Adecuado</span>
                        </td>
                    </tr>
                    <tr class="border-b border-surface-container-highest hover:bg-surface-container transition-colors">
                        <td class="font-body-sm text-body-sm text-on-surface py-3 px-4">Marcos Alambrados</td>
                        <td class="font-body-sm text-body-sm text-on-surface-variant py-3 px-4">Madera/Alambre</td>
                        <td class="font-body-sm text-body-sm text-on-surface py-3 px-4 text-right">450</td>
                        <td class="font-label-caps text-label-caps text-on-surface py-3 px-4 text-right">$1.50</td>
                        <td class="py-3 px-4 text-center">
                            <span class="inline-block px-2 py-1 bg-surface-container-high border border-outline-variant rounded font-label-caps text-label-caps text-on-surface text-[10px]">Adecuado</span>
                        </td>
                    </tr>
                    <tr class="hover:bg-surface-container transition-colors">
                        <td class="font-body-sm text-body-sm text-on-surface py-3 px-4">Cera Estampada</td>
                        <td class="font-body-sm text-body-sm text-on-surface-variant py-3 px-4">Cera Orgánica</td>
                        <td class="font-body-sm text-body-sm text-on-surface py-3 px-4 text-right text-error">5 kg</td>
                        <td class="font-label-caps text-label-caps text-on-surface py-3 px-4 text-right">$18.00</td>
                        <td class="py-3 px-4 text-center">
                            <span class="inline-block px-2 py-1 bg-error-container/30 border border-error rounded font-label-caps text-label-caps text-error text-[10px]">Crítico</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</div>
