@model IEnumerable<ObligatorioIntegrador2026.Models.Apiario>
@using System.Text.Json

@{
    ViewData["Title"] = "Comparar Apiarios";

    var options = new JsonSerializerOptions
    {
        ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    var apiariosJson = JsonSerializer.Serialize(Model.Select(a => new {
        id = a.Id,
        nombre = a.Nombre,
        stringIdentificador = a.StringIdentificador,
        ubicacionTexto = a.UbicacionTexto,
        fechaCreacion = a.FechaCreacion.ToString("yyyy-MM-dd"),
        fechaCreacionDisplay = a.FechaCreacion.ToString("dd MMM yyyy"),
        ultimaInspeccion = a.UltimaInspeccion.HasValue ? a.UltimaInspeccion.Value.ToString("yyyy-MM-dd") : null,
        ultimaInspeccionDisplay = a.UltimaInspeccion.HasValue ? a.UltimaInspeccion.Value.ToString("dd MMM yyyy") : "N/A",
        ultimaEdicionNota = a.UltimaEdicionNota.HasValue ? a.UltimaEdicionNota.Value.ToString("yyyy-MM-dd") : null,
        ultimaEdicionNotaDisplay = a.UltimaEdicionNota.HasValue ? a.UltimaEdicionNota.Value.ToString("dd MMM yyyy HH:mm") : "N/A",
        humedadInterna = a.HumedadInterna,
        colmenasActivas = a.Colmenas.Count,
        produccionMiel = a.Colmenas.Sum(c => c.ProduccionMielKg),
        temperaturaPromedio = a.Colmenas.Where(c => c.EsPiloto).Any() 
            ? Math.Round(a.Colmenas.Where(c => c.EsPiloto).Average(c => c.TemperaturaInterna), 1) 
            : 0.0,
        optimoCount = a.Colmenas.Count(c => c.Estado == "Óptimo"),
        alertaCount = a.Colmenas.Count(c => c.Estado == "Alerta"),
        criticoCount = a.Colmenas.Count(c => c.Estado == "Crítico")
    }), options);
}

<style>
    /* Remover la flecha por defecto del select en navegadores (evita doble flecha) */
    select#selectApiarioA, select#selectApiarioB {
        -webkit-appearance: none !important;
        -moz-appearance: none !important;
        appearance: none !important;
        background-image: none !important;
    }
    select#selectApiarioA::-ms-expand, select#selectApiarioB::-ms-expand {
        display: none !important;
    }
</style>

<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-8">
    <!-- Header Section -->
    <section class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <p class="font-label-caps text-label-caps text-on-surface-variant mb-2">HERRAMIENTAS DE ANÁLISIS</p>
            <h1 class="font-display text-headline-lg-mobile md:text-display text-on-surface mb-2">Comparar Apiarios</h1>
            <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl">
                Análisis de rendimiento y métricas de salud en tiempo real. Seleccione ubicaciones para comparar los datos de producción lado a lado.
            </p>
        </div>
    </section>

    <!-- Selection Control -->
    <div class="bg-surface-container-low border border-outline-variant rounded p-6 mt-8">
        <div class="flex flex-col md:flex-row gap-6 items-center">
            <!-- Selector A -->
            <div class="flex-1 w-full relative">
                <label for="selectApiarioA" class="block font-label-caps text-label-caps text-on-surface-variant mb-2">APIARIO A</label>
                <div class="relative">
                    <select id="selectApiarioA" class="w-full bg-surface-container border border-outline-variant text-on-surface font-body-md p-3 pr-10 rounded focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container appearance-none transition-colors">
                        <!-- Cargado por JS -->
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                </div>
            </div>

            <!-- Swap Button -->
            <button type="button" id="btnSwap" class="flex items-center justify-center h-12 w-12 rounded-full border border-outline-variant bg-surface-container-high my-2 md:my-0 mt-6 md:mt-8 shrink-0 hover:bg-surface-container-highest hover:border-primary-container transition-all group focus:outline-none focus:ring-2 focus:ring-primary-container" title="Intercambiar selecciones">
                <span class="material-symbols-outlined text-primary-container group-hover:rotate-180 transition-transform duration-300">swap_horiz</span>
            </button>

            <!-- Selector B -->
            <div class="flex-1 w-full relative">
                <label for="selectApiarioB" class="block font-label-caps text-label-caps text-on-surface-variant mb-2">APIARIO B</label>
                <div class="relative">
                    <select id="selectApiarioB" class="w-full bg-surface-container border border-outline-variant text-on-surface font-body-md p-3 pr-10 rounded focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container appearance-none transition-colors">
                        <!-- Cargado por JS -->
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI Comparison -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
        <!-- Honey Production Card -->
        <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col hover:border-primary-container/50 transition-colors">
            <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-6 flex items-center justify-between border-b border-outline-variant pb-2">
                PRODUCCIÓN TOTAL (KG)
                <span class="material-symbols-outlined text-[18px] text-primary-container">hive</span>
            </h3>
            
            <div class="space-y-4 flex-grow">
                <!-- Apiario A -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center text-body-md">
                        <span id="lblKpi1NombreA" class="font-semibold text-primary-container uppercase truncate max-w-[200px]">APIARIO A</span>
                        <span id="valKpi1A" class="font-display font-bold text-on-surface">0 kg</span>
                    </div>
                    <div class="w-full bg-surface-container-highest h-3 rounded-full overflow-hidden">
                        <div id="barKpi1A" class="bg-primary-container h-full rounded-full transition-all duration-500" style="width: 0%;"></div>
                    </div>
                </div>

                <!-- Apiario B -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center text-body-md">
                        <span id="lblKpi1NombreB" class="font-semibold text-on-surface-variant uppercase truncate max-w-[200px]">APIARIO B</span>
                        <span id="valKpi1B" class="font-display font-bold text-on-surface-variant">0 kg</span>
                    </div>
                    <div class="w-full bg-surface-container-highest h-3 rounded-full overflow-hidden">
                        <div id="barKpi1B" class="bg-outline h-full rounded-full transition-all duration-500" style="width: 0%;"></div>
                    </div>
                </div>
            </div>

            <!-- Resumen Explicativo -->
            <div class="mt-6 pt-4 border-t border-outline-variant flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 text-body-sm">
                <span id="explainKpi1" class="text-on-surface font-medium flex items-center gap-1.5">
                    <!-- Rellenado por JS -->
                </span>
                <span id="varKpi1" class="font-label-caps text-xs bg-primary-container/10 px-2.5 py-1 rounded text-primary-container font-semibold">
                    0% Var
                </span>
            </div>
        </div>

        <!-- Active Hives Card -->
        <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col hover:border-primary-container/50 transition-colors">
            <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-6 flex items-center justify-between border-b border-outline-variant pb-2">
                COLMENAS ACTIVAS
                <span class="material-symbols-outlined text-[18px] text-primary-container">home_work</span>
            </h3>
            
            <div class="space-y-4 flex-grow">
                <!-- Apiario A -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center text-body-md">
                        <span id="lblKpi2NombreA" class="font-semibold text-primary-container uppercase truncate max-w-[200px]">APIARIO A</span>
                        <span id="valKpi2A" class="font-display font-bold text-on-surface">0</span>
                    </div>
                    <div class="w-full bg-surface-container-highest h-3 rounded-full overflow-hidden">
                        <div id="barKpi2A" class="bg-primary-container h-full rounded-full transition-all duration-500" style="width: 0%;"></div>
                    </div>
                </div>

                <!-- Apiario B -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center text-body-md">
                        <span id="lblKpi2NombreB" class="font-semibold text-on-surface-variant uppercase truncate max-w-[200px]">APIARIO B</span>
                        <span id="valKpi2B" class="font-display font-bold text-on-surface-variant">0</span>
                    </div>
                    <div class="w-full bg-surface-container-highest h-3 rounded-full overflow-hidden">
                        <div id="barKpi2B" class="bg-outline h-full rounded-full transition-all duration-500" style="width: 0%;"></div>
                    </div>
                </div>
            </div>

            <!-- Resumen Explicativo -->
            <div class="mt-6 pt-4 border-t border-outline-variant flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 text-body-sm">
                <span id="explainKpi2" class="text-on-surface font-medium flex items-center gap-1.5">
                    <!-- Rellenado por JS -->
                </span>
                <span id="varKpi2" class="font-label-caps text-xs bg-primary-container/10 px-2.5 py-1 rounded text-primary-container font-semibold">
                    0% Var
                </span>
            </div>
        </div>
    </div>

    <!-- Detailed Comparison Table -->
    <div class="bg-surface-container-low border border-outline-variant rounded overflow-hidden mt-8 mb-12">
        <div class="p-6 border-b border-outline-variant bg-surface-container-high">
            <h3 class="font-headline-lg-mobile text-[20px] font-semibold text-on-surface">Tabla de Comparación Detallada</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container border-b border-outline-variant font-label-caps text-label-caps text-on-surface-variant">
                        <th class="p-4 font-medium w-1/3">Métrica</th>
                        <th id="thApiarioA" class="p-4 font-medium text-primary-container border-l border-outline-variant w-1/4">Apiario A</th>
                        <th id="thApiarioB" class="p-4 font-medium border-l border-outline-variant w-1/4">Apiario B</th>
                        <th class="p-4 font-medium border-l border-outline-variant w-1/6">Diferencia</th>
                    </tr>
                </thead>
                <tbody class="font-body-sm text-on-surface">
                    <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">event</span> Última inspección</td>
                        <td id="tdInspeccionA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdInspeccionB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdInspeccionDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                    <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">calendar_today</span> Fecha de creación</td>
                        <td id="tdCreacionA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdCreacionB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdCreacionDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                    <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">edit_note</span> Última edición de nota de estado</td>
                        <td id="tdNotaEdicionA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdNotaEdicionB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdNotaEdicionDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                    <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">location_on</span> Ubicación</td>
                        <td id="tdUbicacionA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdUbicacionB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdUbicacionDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                    <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">thermostat</span> Temperatura</td>
                        <td id="tdTempA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdTempB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdTempDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                    <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">humidity_percentage</span> Humedad</td>
                        <td id="tdHumA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdHumB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdHumDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                    <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors text-[#4CAF50]">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px]">check_circle</span> Cantidad de colmenas en estado Óptimo</td>
                        <td id="tdOptimoA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdOptimoB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdOptimoDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                    <tr class="border-b border-outline-variant hover:bg-surface-container transition-colors text-primary-container">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px]">info</span> Cantidad de colmenas en estado Alerta</td>
                        <td id="tdAlertaA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdAlertaB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdAlertaDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                    <tr class="hover:bg-surface-container transition-colors text-error">
                        <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px]">warning</span> Cantidad de colmenas en estado Crítico</td>
                        <td id="tdCriticoA" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdCriticoB" class="p-4 border-l border-outline-variant">-</td>
                        <td id="tdCriticoDiff" class="p-4 border-l border-outline-variant text-on-surface-variant">-</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const apiarios = @Html.Raw(apiariosJson);

            if (!apiarios || apiarios.length === 0) {
                console.error("No hay apiarios disponibles para comparar.");
                return;
            }

            const selectA = document.getElementById("selectApiarioA");
            const selectB = document.getElementById("selectApiarioB");
            const btnSwap = document.getElementById("btnSwap");

            // Cargar opciones en los selects
            function populateSelects() {
                selectA.innerHTML = "";
                selectB.innerHTML = "";

                apiarios.forEach(ap => {
                    const optA = document.createElement("option");
                    optA.value = ap.id;
                    optA.textContent = `${ap.nombre} (${ap.stringIdentificador})`;
                    selectA.appendChild(optA);

                    const optB = document.createElement("option");
                    optB.value = ap.id;
                    optB.textContent = `${ap.nombre} (${ap.stringIdentificador})`;
                    selectB.appendChild(optB);
                });

                // Seleccionar por defecto el primero en A y el segundo en B (si hay más de uno)
                if (apiarios.length > 0) selectA.value = apiarios[0].id;
                if (apiarios.length > 1) selectB.value = apiarios[1].id;
                else if (apiarios.length > 0) selectB.value = apiarios[0].id;
            }

            // Deshabilitar recíprocamente las opciones duplicadas
            function syncSelectOptions() {
                const valA = selectA.value;
                const valB = selectB.value;

                Array.from(selectB.options).forEach(opt => {
                    opt.disabled = opt.value === valA;
                });

                Array.from(selectA.options).forEach(opt => {
                    opt.disabled = opt.value === valB;
                });
            }

            // Formatear diferencias numéricas sin color
            function formatNumericDiff(valA, valB, unit = "", decimals = 0) {
                const diff = valA - valB;
                const roundedDiff = parseFloat(diff.toFixed(decimals));
                
                if (roundedDiff > 0) {
                    return `+${roundedDiff}${unit}`;
                } else if (roundedDiff < 0) {
                    return `${roundedDiff}${unit}`;
                } else {
                    return `0${decimals > 0 ? ".0" : ""}${unit}`;
                }
            }

            // Formatear diferencias de texto y fechas (se muestra '-' ya que no se puede calcular diferencia numérica)
            function formatTextDiff(valA, valB) {
                return "-";
            }

            // Actualizar la vista comparativa completa
            function updateComparison() {
                const idA = parseInt(selectA.value);
                const idB = parseInt(selectB.value);

                const apA = apiarios.find(ap => ap.id === idA);
                const apB = apiarios.find(ap => ap.id === idB);

                if (!apA || !apB) return;

                // --- 1. Nombres Dinámicos en la Tabla y KPIs ---
                document.getElementById("thApiarioA").textContent = apA.nombre;
                document.getElementById("thApiarioB").textContent = apB.nombre;

                // Nombres en KPI 1
                document.getElementById("lblKpi1NombreA").textContent = apA.nombre;
                document.getElementById("lblKpi1NombreB").textContent = apB.nombre;
                // Nombres en KPI 2
                document.getElementById("lblKpi2NombreA").textContent = apA.nombre;
                document.getElementById("lblKpi2NombreB").textContent = apB.nombre;

                // --- 2. Valores KPIs ---
                document.getElementById("valKpi1A").textContent = apA.produccionMiel.toLocaleString("es-UY") + " kg";
                document.getElementById("valKpi1B").textContent = apB.produccionMiel.toLocaleString("es-UY") + " kg";

                document.getElementById("valKpi2A").textContent = apA.colmenasActivas;
                document.getElementById("valKpi2B").textContent = apB.colmenasActivas;

                // --- 3. Barras de Progreso Relativas ---
                // KPI 1 (Miel)
                const maxMiel = Math.max(apA.produccionMiel, apB.produccionMiel);
                const bar1AWidth = maxMiel > 0 ? (apA.produccionMiel / maxMiel) * 100 : 0;
                const bar1BWidth = maxMiel > 0 ? (apB.produccionMiel / maxMiel) * 100 : 0;
                document.getElementById("barKpi1A").style.width = `${bar1AWidth}%`;
                document.getElementById("barKpi1B").style.width = `${bar1BWidth}%`;

                // KPI 2 (Colmenas)
                const maxColmenas = Math.max(apA.colmenasActivas, apB.colmenasActivas);
                const bar2AWidth = maxColmenas > 0 ? (apA.colmenasActivas / maxColmenas) * 100 : 0;
                const bar2BWidth = maxColmenas > 0 ? (apB.colmenasActivas / maxColmenas) * 100 : 0;
                document.getElementById("barKpi2A").style.width = `${bar2AWidth}%`;
                document.getElementById("barKpi2B").style.width = `${bar2BWidth}%`;

                // --- 4. Explicaciones y Variaciones en KPIs ---
                const diffMiel = apA.produccionMiel - apB.produccionMiel;
                const formattedDiffMiel = Math.abs(diffMiel).toLocaleString("es-UY");
                const explainKpi1 = document.getElementById("explainKpi1");
                if (diffMiel > 0) {
                    explainKpi1.innerHTML = `<span class="material-symbols-outlined text-[#4CAF50] text-[18px]">trending_up</span> <span><strong>${apA.nombre}</strong> produce <strong>${formattedDiffMiel} kg</strong> más.</span>`;
                } else if (diffMiel < 0) {
                    explainKpi1.innerHTML = `<span class="material-symbols-outlined text-error text-[18px]">trending_down</span> <span><strong>${apA.nombre}</strong> produce <strong>${formattedDiffMiel} kg</strong> menos.</span>`;
                } else {
                    explainKpi1.innerHTML = `<span class="material-symbols-outlined text-on-surface-variant text-[18px]">remove</span> <span>Ambos tienen la misma producción.</span>`;
                }

                const varKpi1 = document.getElementById("varKpi1");
                if (apB.produccionMiel > 0) {
                    const pctMiel = Math.round((diffMiel / apB.produccionMiel) * 100);
                    const sign = pctMiel >= 0 ? "+" : "";
                    varKpi1.textContent = `${sign}${pctMiel}% Var`;
                    varKpi1.className = pctMiel >= 0 
                        ? "font-label-caps text-xs bg-[#4CAF50]/10 px-2.5 py-1 rounded text-[#4CAF50] font-semibold" 
                        : "font-label-caps text-xs bg-error/10 px-2.5 py-1 rounded text-error font-semibold";
                    varKpi1.style.display = "inline-block";
                } else {
                    varKpi1.textContent = "N/A";
                    varKpi1.className = "font-label-caps text-xs bg-surface-variant px-2.5 py-1 rounded text-on-surface-variant font-semibold";
                }

                const diffCol = apA.colmenasActivas - apB.colmenasActivas;
                const absDiffCol = Math.abs(diffCol);
                const explainKpi2 = document.getElementById("explainKpi2");
                if (diffCol > 0) {
                    explainKpi2.innerHTML = `<span class="material-symbols-outlined text-[#4CAF50] text-[18px]">add_circle</span> <span><strong>${apA.nombre}</strong> tiene <strong>${absDiffCol}</strong> colmena${absDiffCol > 1 ? 's' : ''} más.</span>`;
                } else if (diffCol < 0) {
                    explainKpi2.innerHTML = `<span class="material-symbols-outlined text-error text-[18px]">remove_circle</span> <span><strong>${apA.nombre}</strong> tiene <strong>${absDiffCol}</strong> colmena${absDiffCol > 1 ? 's' : ''} menos.</span>`;
                } else {
                    explainKpi2.innerHTML = `<span class="material-symbols-outlined text-on-surface-variant text-[18px]">remove</span> <span>Ambos tienen la misma cantidad.</span>`;
                }

                const varKpi2 = document.getElementById("varKpi2");
                if (apB.colmenasActivas > 0) {
                    const pctCol = Math.round((diffCol / apB.colmenasActivas) * 100);
                    const sign = pctCol >= 0 ? "+" : "";
                    varKpi2.textContent = `${sign}${pctCol}% Var`;
                    varKpi2.className = pctCol >= 0 
                        ? "font-label-caps text-xs bg-[#4CAF50]/10 px-2.5 py-1 rounded text-[#4CAF50] font-semibold" 
                        : "font-label-caps text-xs bg-error/10 px-2.5 py-1 rounded text-error font-semibold";
                    varKpi2.style.display = "inline-block";
                } else {
                    varKpi2.textContent = "N/A";
                    varKpi2.className = "font-label-caps text-xs bg-surface-variant px-2.5 py-1 rounded text-on-surface-variant font-semibold";
                }

                // --- 5. Rellenar Tabla Detallada ---
                // Última Inspección
                document.getElementById("tdInspeccionA").textContent = apA.ultimaInspeccionDisplay;
                document.getElementById("tdInspeccionB").textContent = apB.ultimaInspeccionDisplay;
                document.getElementById("tdInspeccionDiff").innerHTML = formatTextDiff(apA.ultimaInspeccion, apB.ultimaInspeccion);

                // Fecha Creación
                document.getElementById("tdCreacionA").textContent = apA.fechaCreacionDisplay;
                document.getElementById("tdCreacionB").textContent = apB.fechaCreacionDisplay;
                document.getElementById("tdCreacionDiff").innerHTML = formatTextDiff(apA.fechaCreacion, apB.fechaCreacion);

                // Última Edición Nota de Estado
                document.getElementById("tdNotaEdicionA").textContent = apA.ultimaEdicionNotaDisplay;
                document.getElementById("tdNotaEdicionB").textContent = apB.ultimaEdicionNotaDisplay;
                document.getElementById("tdNotaEdicionDiff").innerHTML = formatTextDiff(apA.ultimaEdicionNota, apB.ultimaEdicionNota);

                // Ubicación
                document.getElementById("tdUbicacionA").textContent = apA.ubicacionTexto;
                document.getElementById("tdUbicacionB").textContent = apB.ubicacionTexto;
                document.getElementById("tdUbicacionDiff").innerHTML = formatTextDiff(apA.ubicacionTexto, apB.ubicacionTexto);

                // Temperatura
                document.getElementById("tdTempA").textContent = `${apA.temperaturaPromedio} °C`;
                document.getElementById("tdTempB").textContent = `${apB.temperaturaPromedio} °C`;
                document.getElementById("tdTempDiff").innerHTML = formatNumericDiff(apA.temperaturaPromedio, apB.temperaturaPromedio, " °C", 1);

                // Humedad
                document.getElementById("tdHumA").textContent = `${apA.humedadInterna} %`;
                document.getElementById("tdHumB").textContent = `${apB.humedadInterna} %`;
                document.getElementById("tdHumDiff").innerHTML = formatNumericDiff(apA.humedadInterna, apB.humedadInterna, " %", 0);

                // Óptimo
                document.getElementById("tdOptimoA").textContent = apA.optimoCount;
                document.getElementById("tdOptimoB").textContent = apB.optimoCount;
                document.getElementById("tdOptimoDiff").innerHTML = formatNumericDiff(apA.optimoCount, apB.optimoCount, "", 0);

                // Alerta
                document.getElementById("tdAlertaA").textContent = apA.alertaCount;
                document.getElementById("tdAlertaB").textContent = apB.alertaCount;
                document.getElementById("tdAlertaDiff").innerHTML = formatNumericDiff(apA.alertaCount, apB.alertaCount, "", 0);

                // Crítico
                document.getElementById("tdCriticoA").textContent = apA.criticoCount;
                document.getElementById("tdCriticoB").textContent = apB.criticoCount;
                document.getElementById("tdCriticoDiff").innerHTML = formatNumericDiff(apA.criticoCount, apB.criticoCount, "", 0);
            }

            // Event Listeners para cambios
            selectA.addEventListener("change", function () {
                syncSelectOptions();
                updateComparison();
            });

            selectB.addEventListener("change", function () {
                syncSelectOptions();
                updateComparison();
            });

            // Botón de intercambio
            btnSwap.addEventListener("click", function () {
                const temp = selectA.value;
                selectA.value = selectB.value;
                selectB.value = temp;

                // Forzar sincronización de deshabilitados y actualizar
                syncSelectOptions();
                updateComparison();
            });

            // Inicializar página
            populateSelects();
            syncSelectOptions();
            updateComparison();
        });
    </script>
}
