@{
    ViewData["Title"] = "Comparar Apiarios";
}

<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
<!-- Header Section -->
<section class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mt-8">
    <div>
        <h2 class="font-display text-display text-on-surface mb-2">Comparar Apiarios</h2>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl">
            Análisis de rendimiento y métricas de salud en tiempo real. Seleccione múltiples ubicaciones para enfrentar datos de producción.
        </p>
    </div>
    <div class="flex gap-3 w-full md:w-auto">
        <button class="md:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-transparent border border-outline-variant text-on-surface hover:border-primary-container hover:text-primary-container transition-colors rounded font-label-caps text-label-caps">
            <span class="material-symbols-outlined text-[18px]">tune</span> Filtrar
        </button>
    </div>
</section>
<!-- Selection Control -->
<div class="bg-surface-container-low border border-outline-variant rounded p-6 mt-8">
    <div class="flex flex-col md:flex-row gap-6 items-center">
        <div class="flex-1 w-full relative">
            <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2">APIARIO A</label>
            <select class="w-full bg-surface-container border border-outline-variant text-on-surface font-body-md p-3 rounded focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container appearance-none transition-colors">
                <option selected="">Apiario Norte</option>
                <option>Apiario Este</option>
                <option>Apiario Oeste</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-10 text-on-surface-variant pointer-events-none">expand_more</span>
        </div>
        <div class="flex items-center justify-center h-12 w-12 rounded-full border border-outline-variant bg-surface-container-high my-2 md:my-0 mt-6 md:mt-8 shrink-0">
            <span class="material-symbols-outlined text-primary-container">compare_arrows</span>
        </div>
        <div class="flex-1 w-full relative">
            <label class="block font-label-caps text-label-caps text-on-surface-variant mb-2">APIARIO B</label>
            <select class="w-full bg-surface-container border border-outline-variant text-on-surface font-body-md p-3 rounded focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container appearance-none transition-colors">
                <option selected="">Apiario Sur</option>
                <option>Apiario Este</option>
                <option>Apiario Oeste</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-10 text-on-surface-variant pointer-events-none">expand_more</span>
        </div>
    </div>
</div>
<!-- KPI Comparison -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
    <!-- KPI 1 -->
    <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col hover:border-primary-container/50 transition-colors">
        <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex items-center justify-between">
            PRODUCCIÓN TOTAL (KG)
            <span class="material-symbols-outlined text-[18px]">hive</span>
        </h3>
        <div class="flex items-end justify-between mb-3">
            <div>
                <div class="text-[10px] text-primary-container mb-1 font-label-caps">NORTE</div>
                <div class="font-display text-headline-lg text-on-surface">1,245</div>
            </div>
            <div class="text-right">
                <div class="text-[10px] text-on-surface-variant mb-1 font-label-caps">SUR</div>
                <div class="font-display text-headline-lg text-on-surface-variant">980</div>
            </div>
        </div>
        <div class="mt-auto">
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full mb-1.5 flex">
                <div class="bg-primary-container h-[4px] rounded-full" style="width: 100%;"></div>
            </div>
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full flex">
                <div class="bg-surface-variant h-[4px] rounded-full" style="width: 78%;"></div>
            </div>
            <div class="flex justify-between mt-3 font-label-caps text-[10px] text-on-surface-variant">
                <span class="text-primary-container">+27% Var</span>
                <span class="">Base: Norte</span>
            </div>
        </div>
    </div>
    <!-- KPI 2 -->
    <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col hover:border-primary-container/50 transition-colors">
        <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex items-center justify-between">
            COLMENAS ACTIVAS
            <span class="material-symbols-outlined text-[18px]">home_work</span>
        </h3>
        <div class="flex items-end justify-between mb-3">
            <div>
                <div class="text-[10px] text-primary-container mb-1 font-label-caps">NORTE</div>
                <div class="font-display text-headline-lg text-on-surface">42</div>
            </div>
            <div class="text-right">
                <div class="text-[10px] text-on-surface-variant mb-1 font-label-caps">SUR</div>
                <div class="font-display text-headline-lg text-on-surface-variant">38</div>
            </div>
        </div>
        <div class="mt-auto">
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full mb-1.5 flex">
                <div class="bg-primary-container h-[4px] rounded-full" style="width: 100%;"></div>
            </div>
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full flex">
                <div class="bg-surface-variant h-[4px] rounded-full" style="width: 90%;"></div>
            </div>
            <div class="flex justify-between mt-3 font-label-caps text-[10px] text-on-surface-variant">
                <span class="text-primary-container">+10% Var</span>
                <span class="">Base: Norte</span>
            </div>
        </div>
    </div>
    <!-- KPI 3 -->
    <div class="bg-surface-container-low border border-outline-variant rounded p-6 flex flex-col hover:border-primary-container/50 transition-colors">
        <h3 class="font-label-caps text-label-caps text-on-surface-variant mb-4 flex items-center justify-between">
            SALUD PROMEDIO
            <span class="material-symbols-outlined text-[18px]">monitor_heart</span>
        </h3>
        <div class="flex items-end justify-between mb-3">
            <div>
                <div class="text-[10px] text-primary-container mb-1 font-label-caps">NORTE</div>
                <div class="font-display text-headline-lg text-on-surface">94<span class="text-body-md">%</span></div>
            </div>
            <div class="text-right">
                <div class="text-[10px] text-on-surface-variant mb-1 font-label-caps">SUR</div>
                <div class="font-display text-headline-lg text-on-surface-variant">88<span class="text-body-md">%</span></div>
            </div>
        </div>
        <div class="mt-auto">
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full mb-1.5 flex">
                <div class="bg-primary-container h-[4px] rounded-full" style="width: 94%;"></div>
            </div>
            <div class="w-full bg-surface-container-highest h-[4px] rounded-full flex">
                <div class="bg-surface-variant h-[4px] rounded-full" style="width: 88%;"></div>
            </div>
            <div class="flex justify-between mt-3 font-label-caps text-[10px] text-on-surface-variant">
                <span class="text-primary-container">+6.8% Var</span>
                <span class="">Base: Norte</span>
            </div>
        </div>
    </div>
</div>
<!-- Detailed Comparison Table -->
<div class="bg-surface-container-low border border-outline-variant rounded overflow-hidden mt-8 mb-12">
    <div class="p-6 border-b border-surface-container-highest">
        <h3 class="font-headline-lg-mobile text-[20px] font-semibold text-on-surface">Métricas Detalladas</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container border-b border-surface-container-highest font-label-caps text-label-caps text-on-surface-variant">
                    <th class="p-4 font-medium">Métrica</th>
                    <th class="p-4 font-medium text-primary-container border-l border-surface-container-highest">Norte</th>
                    <th class="p-4 font-medium border-l border-surface-container-highest">Sur</th>
                    <th class="p-4 font-medium border-l border-surface-container-highest">Diferencia</th>
                </tr>
            </thead>
            <tbody class="font-body-sm text-on-surface">
                <tr class="border-b border-surface-container-highest hover:bg-surface-container transition-colors">
                    <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">thermostat</span> Temp. Media Int.</td>
                    <td class="p-4 border-l border-surface-container-highest">34.5 °C</td>
                    <td class="p-4 border-l border-surface-container-highest">35.1 °C</td>
                    <td class="p-4 border-l border-surface-container-highest text-on-surface-variant">-0.6 °C</td>
                </tr>
                <tr class="border-b border-surface-container-highest hover:bg-surface-container transition-colors">
                    <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">water_drop</span> Humedad Rel.</td>
                    <td class="p-4 border-l border-surface-container-highest">42%</td>
                    <td class="p-4 border-l border-surface-container-highest">48%</td>
                    <td class="p-4 border-l border-surface-container-highest text-on-surface-variant">-6%</td>
                </tr>
                <tr class="border-b border-surface-container-highest hover:bg-surface-container transition-colors">
                    <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">warning</span> Alertas Activas</td>
                    <td class="p-4 border-l border-surface-container-highest">
                        <span class="inline-flex items-center bg-surface-container-highest text-on-surface px-2 py-1 rounded border border-outline-variant font-label-caps text-[10px]">2 VARROA</span>
                    </td>
                    <td class="p-4 border-l border-surface-container-highest">
                        <span class="inline-flex items-center bg-surface-container-highest text-on-surface px-2 py-1 rounded border border-outline-variant font-label-caps text-[10px]">0</span>
                    </td>
                    <td class="p-4 border-l border-surface-container-highest text-error">+2</td>
                </tr>
                <tr class="hover:bg-surface-container transition-colors">
                    <td class="p-4 flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-on-surface-variant">event</span> Última Inspección</td>
                    <td class="p-4 border-l border-surface-container-highest">Hace 2 días</td>
                    <td class="p-4 border-l border-surface-container-highest">Hace 5 días</td>
                    <td class="p-4 border-l border-surface-container-highest text-on-surface-variant">--</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
</div>
