@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string GetNavClass(string controller)
    {
        bool isActive = currentController == controller;
        return isActive 
            ? "px-4 py-2 font-label-caps text-label-caps text-primary-container bg-surface-container-high rounded-lg flex items-center gap-2 border-b-2 border-primary-container"
            : "px-4 py-2 font-label-caps text-label-caps text-on-surface-variant hover:text-primary-container transition-colors rounded-lg hover:bg-surface-container-high flex items-center gap-2";
    }

    string GetDropdownItemClass(string controller, string action)
    {
        bool isActive = currentController == controller && currentAction == action;
        return isActive
            ? "px-4 py-2 font-label-caps text-label-caps text-primary-container bg-surface-container-high flex items-center gap-2 border-l-2 border-primary-container"
            : "px-4 py-2 font-label-caps text-label-caps text-on-surface-variant hover:text-primary-container transition-colors hover:bg-surface-container-high flex items-center gap-2";
    }

    string GetMoreDropdownClass()
    {
        bool isActive = currentController == "Mas" || currentController == "Admin";
        return isActive
            ? "px-4 py-2 font-label-caps text-label-caps text-primary-container bg-surface-container-high rounded-lg flex items-center gap-2 border-b-2 border-primary-container"
            : "px-4 py-2 font-label-caps text-label-caps text-on-surface-variant hover:text-primary-container transition-colors rounded-lg hover:bg-surface-container-high flex items-center gap-2";
    }

    string GetIconStyle(string controller, string? action = null)
    {
        bool isActive = currentController == controller && (action == null || currentAction == action);
        return isActive ? "font-variation-settings: 'FILL' 1;" : "";
    }
}
<!DOCTYPE html>
<html class="dark" lang="es">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Zánganos S.A.</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;800&amp;family=Inter:wght@400;500&amp;family=JetBrains+Mono:wght@500&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "inverse-surface": "#e3e2e2",
                        "surface-dim": "#121414",
                        "on-tertiary-fixed-variant": "#474746",
                        "on-background": "#e3e2e2",
                        "on-primary-container": "#715f00",
                        "on-secondary-fixed": "#1b1b1c",
                        "tertiary-container": "#dddbda",
                        "on-surface-variant": "#cfc6ab",
                        "outline": "#989077",
                        "primary-container": "#ffd900",
                        "on-tertiary": "#303030",
                        "surface-tint": "#e7c400",
                        "secondary": "#c8c6c5",
                        "tertiary-fixed-dim": "#c8c6c5",
                        "primary-fixed-dim": "#e7c400",
                        "surface-container-high": "#292a2a",
                        "on-error": "#690005",
                        "surface-container-lowest": "#0d0e0f",
                        "on-secondary-container": "#b7b5b4",
                        "error": "#ffb4ab",
                        "secondary-fixed": "#e5e2e1",
                        "surface-variant": "#343535",
                        "error-container": "#93000a",
                        "tertiary": "#faf7f7",
                        "on-primary-fixed-variant": "#544600",
                        "outline-variant": "#4c4732",
                        "secondary-container": "#474746",
                        "on-primary": "#3a3000",
                        "inverse-primary": "#6f5d00",
                        "surface-bright": "#383939",
                        "surface": "#121414",
                        "primary-fixed": "#ffe165",
                        "on-primary-fixed": "#221b00",
                        "on-surface": "#e3e2e2",
                        "primary": "#fff7e6",
                        "on-error-container": "#ffdad6",
                        "surface-container": "#1e2020",
                        "on-tertiary-fixed": "#1b1c1c",
                        "on-secondary-fixed-variant": "#474746",
                        "on-secondary": "#303030",
                        "on-tertiary-container": "#606060",
                        "secondary-fixed-dim": "#c8c6c5",
                        "surface-container-highest": "#343535",
                        "inverse-on-surface": "#2f3131",
                        "background": "#121414",
                        "surface-container-low": "#1a1c1c",
                        "tertiary-fixed": "#e4e2e1"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "gutter": "24px",
                        "unit": "8px",
                        "margin-desktop": "64px",
                        "margin-mobile": "20px",
                        "container-max": "1600px"
                    },
                    "fontFamily": {
                        "display": ["Hanken Grotesk"],
                        "headline-lg": ["Hanken Grotesk"],
                        "body-md": ["Inter"],
                        "headline-lg-mobile": ["Hanken Grotesk"],
                        "label-caps": ["JetBrains Mono"],
                        "body-sm": ["Inter"]
                    },
                    "fontSize": {
                        "display": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "headline-lg": ["32px", {"lineHeight": "1.2", "fontWeight": "600"}],
                        "body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "headline-lg-mobile": ["24px", {"lineHeight": "1.2", "fontWeight": "600"}],
                        "label-caps": ["12px", {"lineHeight": "1.0", "letterSpacing": "0.1em", "fontWeight": "500"}],
                        "body-sm": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        body {
            background-color: #1E1E1E;
            color: #e3e2e2;
        }
    </style>
</head>
<body class="font-body-md text-body-md antialiased overflow-x-hidden bg-surface min-h-screen flex flex-col">
    <!-- Top Navigation Bar -->
    <header class="w-full bg-surface-container border-b border-surface-container-highest z-40 sticky top-0">
        <div class="max-w-container-max mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a asp-controller="Home" asp-action="Index" class="font-headline-lg-mobile text-headline-lg-mobile font-bold text-primary-container tracking-tight flex items-center">
                    <img src="~/Logo.png" alt="Logo" class="w-8 h-8 mr-2 object-contain align-middle" />Zánganos S.A.
                </a>
                <nav class="hidden md:flex items-center gap-1">
                    <a asp-controller="Home" asp-action="Index" class="@GetNavClass("Home")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Home")">dashboard</span> Dashboard
                    </a>
                    <a asp-controller="Apiarios" asp-action="Index" class="@GetNavClass("Apiarios")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Apiarios")">location_on</span> Apiarios
                    </a>
                    <a asp-controller="Colmenas" asp-action="Index" class="@GetNavClass("Colmenas")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Colmenas")">hive</span> Colmenas
                    </a>
                    <a asp-controller="Informes" asp-action="Index" class="@GetNavClass("Informes")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Informes")">assessment</span> Informes
                    </a>
                    <div class="relative group">
                        <button class="@GetMoreDropdownClass()">
                            <span class="material-symbols-outlined text-[18px]">more_horiz</span> Más
                            <span class="material-symbols-outlined text-[18px]">expand_more</span>
                        </button>
                        <div class="absolute top-full right-0 w-48 bg-surface-container border border-surface-container-highest rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 flex flex-col py-1">
                            <a asp-controller="Mas" asp-action="Movimientos" class="@GetDropdownItemClass("Mas", "Movimientos")">
                                <span class="material-symbols-outlined text-[18px]">local_shipping</span> Movimientos
                            </a>
                            <a asp-controller="Mas" asp-action="CompararApiarios" class="@GetDropdownItemClass("Mas", "CompararApiarios")">
                                <span class="material-symbols-outlined text-[18px]">compare_arrows</span> Comparar Apiarios
                            </a>
                            <a asp-controller="Mas" asp-action="CompararColmenas" class="@GetDropdownItemClass("Mas", "CompararColmenas")">
                                <span class="material-symbols-outlined text-[18px]">difference</span> Comparar Colmenas
                            </a>
                            <a asp-controller="Mas" asp-action="Finanzacion" class="@GetDropdownItemClass("Mas", "Finanzacion")">
                                <span class="material-symbols-outlined text-[18px]">payments</span> Cálculo de Costos
                            </a>
                            <a asp-controller="Mas" asp-action="Inventario" class="@GetDropdownItemClass("Mas", "Inventario")">
                                <span class="material-symbols-outlined text-[18px]">inventory</span> Inventario
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="RegistroLogins" class="@GetDropdownItemClass("Admin", "RegistroLogins")">
                                    <span class="material-symbols-outlined text-[18px]">login</span> Registro Logins
                                </a>
                            }
                        </div>
                    </div>
                </nav>
            </div>
            <div class="flex items-center gap-4">
                <button class="text-on-surface-variant hover:text-primary-container transition-colors focus:ring-2 focus:ring-primary-container outline-none rounded-full p-1">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <div class="flex items-center gap-3">
                    <div class="text-right hidden md:block">
                        <p class="font-label-caps text-label-caps text-on-surface">@User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value</p>
                        <p class="font-body-sm text-body-sm text-on-surface-variant text-[10px]">
                            @(User.IsInRole("Admin") ? "Administrador" : "Apicultor")
                        </p>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-surface-container-high border border-outline-variant flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-on-surface-variant text-[20px]">person</span>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                    <button type="submit" class="text-on-surface-variant hover:text-error transition-colors focus:ring-2 focus:ring-error outline-none rounded-full p-1 ml-2" title="Cerrar sesión">
                        <span class="material-symbols-outlined">logout</span>
                    </button>
                </form>
                <button class="md:hidden text-on-surface-variant hover:text-primary-container transition-colors">
                    <span class="material-symbols-outlined">menu</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="flex flex-col md:flex-row justify-between items-center py-6 px-4 md:px-8 bg-surface-container border-t border-surface-container-highest mt-auto w-full">
        <span class="font-label-caps text-label-caps font-bold text-primary-container mb-4 md:mb-0">Zánganos S.A.</span>
        <div class="flex flex-wrap justify-center gap-4 mb-4 md:mb-0">
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary-container transition-opacity" href="#">Documentación Técnica</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary-container transition-opacity hidden sm:inline" href="#">Soporte API</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary-container transition-opacity" href="#">Privacidad</a>
        </div>
        <span class="font-body-sm text-body-sm text-on-surface-variant text-center md:text-right">Felipe Alvarez y Benjamin Lopez - 2026</span>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
