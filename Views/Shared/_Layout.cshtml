@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string GetNavClass(string controller, string? action = null)
    {
        bool isActive = false;
        if (controller == "Home" && currentController == "Home")
        {
            isActive = true;
        }
        else if (controller == "Apiarios")
        {
            isActive = currentController == "Apiarios" || (currentController == "Mas" && currentAction == "CompararApiarios");
        }
        else if (controller == "Colmenas")
        {
            isActive = currentController == "Colmenas" || (currentController == "Mas" && currentAction == "CompararColmenas");
        }
        else if (controller == "Extracciones")
        {
            isActive = currentController == "Extracciones";
        }
        else if (controller == "Mas" && action == "Movimientos")
        {
            isActive = currentController == "Mas" && currentAction == "Movimientos";
        }
        return isActive 
            ? "px-4 py-2 font-label-caps text-label-caps text-primary-container bg-surface-container-high rounded flex items-center gap-2 border-b-2 border-primary-container"
            : "px-4 py-2 font-label-caps text-label-caps text-on-surface-variant hover:text-primary-container transition-colors rounded hover:bg-surface-container-high flex items-center gap-2";
    }

    string GetDropdownItemClass(string controller, string action)
    {
        bool isActive = currentController == controller && currentAction == action;
        return isActive
            ? "px-4 py-2 font-label-caps text-label-caps text-primary-container bg-surface-container-high flex items-center gap-2 border-l-2 border-primary-container"
            : "px-4 py-2 font-label-caps text-label-caps text-on-surface-variant hover:text-primary-container transition-colors hover:bg-surface-container-high flex items-center gap-2";
    }

    string GetMoreDropdownClass()
    {
        bool isActive = (currentController == "Mas" && currentAction == "Inventario")
                     || (currentController == "Mas" && currentAction == "Finanzacion")
                     || currentController == "Informes"
                     || currentController == "Admin";
        return isActive
            ? "px-4 py-2 font-label-caps text-label-caps text-primary-container bg-surface-container-high rounded flex items-center gap-2 border-b-2 border-primary-container"
            : "px-4 py-2 font-label-caps text-label-caps text-on-surface-variant hover:text-primary-container transition-colors rounded hover:bg-surface-container-high flex items-center gap-2";
    }

    string GetIconStyle(string controller, string? action = null)
    {
        bool isActive = false;
        if (controller == "Home" && currentController == "Home")
        {
            isActive = true;
        }
        else if (controller == "Apiarios")
        {
            isActive = currentController == "Apiarios" || (currentController == "Mas" && currentAction == "CompararApiarios");
        }
        else if (controller == "Colmenas")
        {
            isActive = currentController == "Colmenas" || (currentController == "Mas" && currentAction == "CompararColmenas");
        }
        else if (controller == "Extracciones")
        {
            isActive = currentController == "Extracciones";
        }
        else if (controller == "Mas" && action == "Movimientos")
        {
            isActive = currentController == "Mas" && currentAction == "Movimientos";
        }
        return isActive ? "font-variation-settings: 'FILL' 1;" : "";
    }
}
<!DOCTYPE html>
<html class="dark" lang="es">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Zánganos S.A.</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="manifest" href="~/manifest.json" />
    <meta name="theme-color" content="#121414" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;800&amp;family=Inter:wght@400;500&amp;family=JetBrains+Mono:wght@500&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "inverse-surface": "#e3e2e2",
                        "surface-dim": "#121414",
                        "on-tertiary-fixed-variant": "#474746",
                        "on-background": "#e3e2e2",
                        "on-primary-container": "#715f00",
                        "on-secondary-fixed": "#1b1b1c",
                        "tertiary-container": "#dddbda",
                        "on-surface-variant": "#cfc6ab",
                        "outline": "#989077",
                        "primary-container": "#ffd900",
                        "on-tertiary": "#303030",
                        "surface-tint": "#e7c400",
                        "secondary": "#c8c6c5",
                        "tertiary-fixed-dim": "#c8c6c5",
                        "primary-fixed-dim": "#e7c400",
                        "surface-container-high": "#292a2a",
                        "on-error": "#690005",
                        "surface-container-lowest": "#0d0e0f",
                        "on-secondary-container": "#b7b5b4",
                        "error": "#ffb4ab",
                        "secondary-fixed": "#e5e2e1",
                        "surface-variant": "#343535",
                        "error-container": "#93000a",
                        "tertiary": "#faf7f7",
                        "on-primary-fixed-variant": "#544600",
                        "outline-variant": "#4c4732",
                        "secondary-container": "#474746",
                        "on-primary": "#3a3000",
                        "inverse-primary": "#6f5d00",
                        "surface-bright": "#383939",
                        "surface": "#121414",
                        "primary-fixed": "#ffe165",
                        "on-primary-fixed": "#221b00",
                        "on-surface": "#e3e2e2",
                        "primary": "#fff7e6",
                        "on-error-container": "#ffdad6",
                        "surface-container": "#1e2020",
                        "on-tertiary-fixed": "#1b1c1c",
                        "on-secondary-fixed-variant": "#474746",
                        "on-secondary": "#303030",
                        "on-tertiary-container": "#606060",
                        "secondary-fixed-dim": "#c8c6c5",
                        "surface-container-highest": "#343535",
                        "inverse-on-surface": "#2f3131",
                        "background": "#121414",
                        "surface-container-low": "#1a1c1c",
                        "tertiary-fixed": "#e4e2e1"
                    },
                    borderRadius: {
                        'none': '0',
                        'sm': '0.0625rem',
                        DEFAULT: '0.125rem',
                        'md': '0.1875rem',
                        'lg': '0.25rem',
                        'xl': '0.5rem',
                        '2xl': '1rem',
                        '3xl': '1.5rem',
                        'full': '9999px',
                    },
                    "spacing": {
                        "gutter": "24px",
                        "unit": "8px",
                        "margin-desktop": "64px",
                        "margin-mobile": "20px",
                        "container-max": "1600px"
                    },
                    "fontFamily": {
                        "display": ["Hanken Grotesk"],
                        "headline-lg": ["Hanken Grotesk"],
                        "body-md": ["Inter"],
                        "headline-lg-mobile": ["Hanken Grotesk"],
                        "label-caps": ["JetBrains Mono"],
                        "body-sm": ["Inter"]
                    },
                    "fontSize": {
                        "display": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "headline-lg": ["32px", {"lineHeight": "1.2", "fontWeight": "600"}],
                        "body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "headline-lg-mobile": ["24px", {"lineHeight": "1.2", "fontWeight": "600"}],
                        "label-caps": ["12px", {"lineHeight": "1.0", "letterSpacing": "0.1em", "fontWeight": "500"}],
                        "body-sm": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        body {
            background-color: #1E1E1E;
            color: #e3e2e2;
        }
        /* Estilos para convertir tabla en tarjetas en móvil */
        @@media (max-width: 767px) {
            .responsive-table table, .responsive-table thead, .responsive-table tbody, .responsive-table th, .responsive-table td, .responsive-table tr {
                display: block;
            }
            .responsive-table thead tr {
                position: absolute;
                top: -9999px;
                left: -9999px;
            }
            .responsive-table tr {
                border: 1px solid theme('colors.outline-variant');
                border-radius: 0.5rem;
                margin-bottom: 1rem;
                background-color: theme('colors.surface-container.DEFAULT');
                padding: 1rem;
            }
            .responsive-table td {
                border: none !important;
                padding: 0.5rem 0 !important;
                position: relative;
                padding-left: 50% !important;
                text-align: right;
                display: flex;
                justify-content: flex-end;
                align-items: center;
                min-height: 2.5rem;
            }
            .responsive-table td::before {
                content: attr(data-label);
                position: absolute;
                left: 0;
                width: 45%;
                padding-right: 10px;
                white-space: nowrap;
                text-align: left;
                font-size: 0.65rem;
                font-weight: 700;
                letter-spacing: 0.05em;
                color: theme('colors.on-surface-variant');
                text-transform: uppercase;
            }
        }
        /* Custom animations for modals */
        .modal-backdrop {
            transition: opacity 0.25s ease-out;
        }
        .modal-container {
            transition: transform 0.25s ease-out, opacity 0.25s ease-out;
            max-height: 75vh;
            overflow-y: auto !important;
        }
        @@media (min-width: 768px) {
            .modal-container {
                max-height: 85vh;
            }
        }
        .modal-hidden {
            opacity: 0;
            pointer-events: none;
        }
        .modal-hidden .modal-container {
            transform: scale(0.95);
            opacity: 0;
        }
    </style>
</head>
<body class="font-body-md text-body-md antialiased overflow-x-hidden bg-surface min-h-screen flex flex-col">
    <!-- Top Navigation Bar -->
    <header class="w-full bg-surface-container border-b border-surface-container-highest z-40 sticky top-0">
        <div class="max-w-container-max mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a asp-controller="Home" asp-action="Index" class="font-headline-lg-mobile text-headline-lg-mobile font-bold text-primary-container tracking-tight flex items-center">
                    <img src="~/Logo.png" alt="Logo" class="w-8 h-8 mr-2 object-contain align-middle" />Zánganos S.A.
                </a>
                <nav class="hidden md:flex items-center gap-1">
                    <a asp-controller="Home" asp-action="Index" class="@GetNavClass("Home")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Home")">dashboard</span> Dashboard
                    </a>
                    <a asp-controller="Apiarios" asp-action="Index" class="@GetNavClass("Apiarios")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Apiarios")">location_on</span> Apiarios
                    </a>
                    <a asp-controller="Colmenas" asp-action="Index" class="@GetNavClass("Colmenas")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Colmenas")">hive</span> Colmenas
                    </a>
                    <a asp-controller="Extracciones" asp-action="Index" class="@GetNavClass("Extracciones")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Extracciones")">agriculture</span> Extracciones
                    </a>
                    <a asp-controller="Mas" asp-action="Movimientos" class="@GetNavClass("Mas", "Movimientos")">
                        <span class="material-symbols-outlined text-[18px]" style="@GetIconStyle("Mas", "Movimientos")">local_shipping</span> Movimientos
                    </a>
                    <div class="relative group">
                        <button class="@GetMoreDropdownClass()">
                            <span class="material-symbols-outlined text-[18px]">more_horiz</span> Más
                            <span class="material-symbols-outlined text-[18px]">expand_more</span>
                        </button>
                        <div class="absolute top-full left-1/2 -translate-x-1/2 w-48 bg-surface-container border border-outline-variant rounded shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 flex flex-col py-1">
                            <a asp-controller="Mas" asp-action="Inventario" class="@GetDropdownItemClass("Mas", "Inventario")">
                                <span class="material-symbols-outlined text-[18px]">inventory</span> Inventario
                            </a>
                            <a asp-controller="Mas" asp-action="Finanzacion" class="@GetDropdownItemClass("Mas", "Finanzacion")">
                                <span class="material-symbols-outlined text-[18px]">payments</span> Finanzación
                            </a>
                            <a asp-controller="Informes" asp-action="Index" class="@GetDropdownItemClass("Informes", "Index")">
                                <span class="material-symbols-outlined text-[18px]">assessment</span> Informes
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="RegistroLogins" class="@GetDropdownItemClass("Admin", "RegistroLogins")">
                                    <span class="material-symbols-outlined text-[18px]">login</span> Registro Logins
                                </a>
                            }
                        </div>
                    </div>
                </nav>
            </div>
            <div class="flex items-center gap-4">

                <div class="flex items-center gap-3">
                    <div class="text-right hidden md:block">
                        <p class="font-label-caps text-label-caps text-on-surface">@User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value</p>
                        <p class="font-body-sm text-body-sm text-on-surface-variant text-[10px]">
                            @(User.IsInRole("Admin") ? "Administrador" : "Apicultor")
                        </p>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-surface-container-high border border-outline-variant flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-on-surface-variant text-[20px]">person</span>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                    <button type="submit" class="text-on-surface-variant hover:text-error transition-colors focus:ring-2 focus:ring-error outline-none rounded p-1 ml-2" title="Cerrar sesión">
                        <span class="material-symbols-outlined">logout</span>
                    </button>
                </form>
                <button id="btnOpenMobileMenu" class="md:hidden text-on-surface-variant hover:text-primary-container transition-colors p-2">
                    <span class="material-symbols-outlined">menu</span>
                </button>
            </div>
        </div>
    </header>

    <!-- Mobile Navigation Menu -->
    <div id="mobileMenu" class="fixed inset-0 z-50 bg-surface/95 backdrop-blur-sm flex flex-col md:hidden transform translate-x-full transition-transform duration-300">
        <div class="flex items-center justify-between p-4 border-b border-surface-container-highest">
            <a asp-controller="Home" asp-action="Index" class="font-headline-lg-mobile text-headline-lg-mobile font-bold text-primary-container tracking-tight flex items-center">
                <img src="~/Logo.png" alt="Logo" class="w-8 h-8 mr-2 object-contain align-middle" />Zánganos S.A.
            </a>
            <button id="btnCloseMobileMenu" class="text-on-surface-variant hover:text-primary-container transition-colors p-2">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <nav class="flex flex-col gap-2 p-4 flex-grow overflow-y-auto">
            <!-- Same links as desktop but vertical -->
            <a asp-controller="Home" asp-action="Index" class="@GetNavClass("Home") py-4">
                <span class="material-symbols-outlined text-[20px]" style="@GetIconStyle("Home")">dashboard</span> Dashboard
            </a>
            <a asp-controller="Apiarios" asp-action="Index" class="@GetNavClass("Apiarios") py-4">
                <span class="material-symbols-outlined text-[20px]" style="@GetIconStyle("Apiarios")">location_on</span> Apiarios
            </a>
            <a asp-controller="Colmenas" asp-action="Index" class="@GetNavClass("Colmenas") py-4">
                <span class="material-symbols-outlined text-[20px]" style="@GetIconStyle("Colmenas")">hive</span> Colmenas
            </a>
            <a asp-controller="Extracciones" asp-action="Index" class="@GetNavClass("Extracciones") py-4">
                <span class="material-symbols-outlined text-[20px]" style="@GetIconStyle("Extracciones")">agriculture</span> Extracciones
            </a>
            <a asp-controller="Mas" asp-action="Movimientos" class="@GetNavClass("Mas", "Movimientos") py-4">
                <span class="material-symbols-outlined text-[20px]" style="@GetIconStyle("Mas", "Movimientos")">local_shipping</span> Movimientos
            </a>
            <div class="mt-4 pt-4 border-t border-surface-container-highest">
                <p class="font-label-caps text-label-caps text-on-surface-variant mb-2">MÁS OPCIONES</p>
                <a asp-controller="Mas" asp-action="Inventario" class="@GetDropdownItemClass("Mas", "Inventario") py-3">
                    <span class="material-symbols-outlined text-[18px]">inventory</span> Inventario
                </a>
                <a asp-controller="Mas" asp-action="Finanzacion" class="@GetDropdownItemClass("Mas", "Finanzacion") py-3">
                    <span class="material-symbols-outlined text-[18px]">payments</span> Finanzación
                </a>
                <a asp-controller="Informes" asp-action="Index" class="@GetDropdownItemClass("Informes", "Index") py-3">
                    <span class="material-symbols-outlined text-[18px]">assessment</span> Informes
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="RegistroLogins" class="@GetDropdownItemClass("Admin", "RegistroLogins") py-3">
                        <span class="material-symbols-outlined text-[18px]">login</span> Registro Logins
                    </a>
                }
            </div>
        </nav>
        <div class="p-4 border-t border-surface-container-highest">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-surface-container-high border border-outline-variant flex items-center justify-center overflow-hidden">
                    <span class="material-symbols-outlined text-on-surface-variant text-[24px]">person</span>
                </div>
                <div class="text-left">
                    <p class="font-label-caps text-label-caps text-on-surface">@User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value</p>
                    <p class="font-body-sm text-body-sm text-on-surface-variant text-[10px]">
                        @(User.IsInRole("Admin") ? "Administrador" : "Apicultor")
                    </p>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" class="w-full">
                <button type="submit" class="w-full border border-error text-error hover:bg-error/10 transition-colors px-4 py-3 rounded flex items-center justify-center gap-2 font-label-caps text-label-caps" title="Cerrar sesión">
                    <span class="material-symbols-outlined">logout</span> Cerrar Sesión
                </button>
            </form>
        </div>
    </div>

    <main class="flex-grow">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="grid grid-cols-1 md:grid-cols-3 items-center py-6 px-4 md:px-8 bg-surface-container border-t border-surface-container-highest mt-auto w-full gap-4">
        <span class="font-label-caps text-label-caps font-bold text-primary-container text-center md:text-left">Zánganos S.A.</span>
        <div class="flex flex-wrap justify-center gap-4">
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary-container transition-opacity" href="/docs/Documentaci%C3%B3n%20Obligatorio%20AP%20Hito%204%20-%20Benjam%C3%ADn%20L%C3%B3pez%20y%20Felipe%20Alvarez.pdf" download>Documentación Técnica</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary-container transition-opacity hidden sm:inline" href="javascript:void(0)" onclick="openApiSupportModal()">Soporte API</a>
        </div>
        <span class="font-body-sm text-body-sm text-on-surface-variant text-center md:text-right">Felipe Alvarez y Benjamín López - 2026</span>
    </footer>

    <!-- Modal Soporte API -->
    <div id="modalSoporteApi" class="fixed inset-0 z-[60] flex items-center justify-center modal-backdrop bg-black/80 modal-hidden p-4">
        <div class="bg-surface-container border border-outline-variant rounded-lg w-full max-w-lg modal-container shadow-2xl flex flex-col max-h-[85vh]">
            <div class="px-6 py-4 border-b border-surface-container-highest flex items-center justify-between shrink-0">
                <h4 class="font-headline-lg text-lg font-bold text-on-surface flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-primary-container">api</span>
                    <span>Soporte API de Escaneo</span>
                </h4>
                <button type="button" onclick="closeApiSupportModal()" class="text-on-surface-variant hover:text-primary-container transition-colors p-1" title="Cerrar">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="p-6 overflow-y-auto grow custom-scrollbar space-y-6">
                <p class="font-body-md text-on-surface-variant">
                    El sistema de escaneo de colmenas funciona de forma híbrida dependiendo de la conexión a Internet:
                </p>
                
                <!-- Gemini Online -->
                <div class="bg-surface-container-high border border-outline-variant p-4 rounded-lg space-y-2">
                    <div class="flex items-center gap-2 text-primary-container font-semibold">
                        <span class="material-symbols-outlined text-[20px]">cloud</span>
                        <span>Modo Online (Con Conexión)</span>
                    </div>
                    <p class="font-body-sm text-on-surface-variant">
                        Utiliza la API de <strong class="text-on-surface">Google Gemini (modelo gemini-2.5-flash)</strong> en la nube para procesar la imagen capturada por la cámara y extraer con alta precisión los 6 dígitos del código de la colmena.
                    </p>
                    <div class="pt-1">
                        <a href="https://ai.google.dev/gemini-api/docs" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-caps text-label-caps text-primary-container hover:underline text-xs">
                            Documentación de Gemini <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                        </a>
                    </div>
                </div>

                <!-- PaddleOCR Offline -->
                <div class="bg-surface-container-high border border-outline-variant p-4 rounded-lg space-y-2">
                    <div class="flex items-center gap-2 text-primary-container font-semibold">
                        <span class="material-symbols-outlined text-[20px]">cloud_off</span>
                        <span>Modo Offline (Sin Conexión)</span>
                    </div>
                    <p class="font-body-sm text-on-surface-variant">
                        Ejecuta reconocimiento de caracteres (OCR) de forma local. Usa <strong class="text-on-surface">ONNX Runtime Web</strong> compilado en WebAssembly para procesar los modelos de <strong class="text-on-surface">PaddleOCR</strong> directamente en el navegador sin consumir datos.
                    </p>
                    <div class="pt-1 flex flex-wrap gap-x-4 gap-y-2">
                        <a href="https://github.com/PaddlePaddle/PaddleOCR" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-caps text-label-caps text-primary-container hover:underline text-xs">
                            GitHub PaddleOCR <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                        </a>
                        <a href="https://onnxruntime.ai/docs/tutorials/web/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-caps text-label-caps text-primary-container hover:underline text-xs">
                            ONNX Web <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                        </a>
                        <a href="https://www.npmjs.com/package/ppu-paddle-ocr" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-caps text-label-caps text-primary-container hover:underline text-xs">
                            Librería ppu-paddle-ocr <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                        </a>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-surface-container-highest flex justify-end shrink-0">
                <button type="button" onclick="closeApiSupportModal()" class="bg-primary-container text-on-primary hover:bg-primary-fixed transition-colors px-6 py-2 rounded font-label-caps text-label-caps">
                    Cerrar
                </button>
            </div>
        </div>
    </div>

    <!-- Global Notification Toast Container -->
    <div id="toast-container" class="fixed bottom-4 left-4 right-4 md:left-auto md:right-6 md:bottom-6 z-50 flex flex-col items-center md:items-end gap-3 pointer-events-none"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        function showToast(message, type = "success") {
            const container = document.getElementById("toast-container");
            if (!container) return;

            const toast = document.createElement("div");
            // Mobile: full width, slide up. Desktop: max-w-sm, slide left.
            toast.className = `flex items-center gap-3 bg-surface-container border-l-4 p-4 rounded shadow-2xl transition-all duration-300 transform translate-y-12 md:translate-y-0 md:translate-x-12 opacity-0 pointer-events-auto w-full md:w-auto md:max-w-sm`;
            
            if (type === "success") {
                toast.className += " border-primary-container";
            } else if (type === "error") {
                toast.className += " border-error";
            }

            const icon = type === "success" ? "check_circle" : "error";
            const iconColor = type === "success" ? "text-primary-container" : "text-error";

            toast.innerHTML = `
                <span class="material-symbols-outlined ${iconColor}">${icon}</span>
                <div class="text-on-surface text-sm font-body-sm font-medium pr-2 flex-grow">${message}</div>
                <button onclick="this.parentElement.remove()" class="text-on-surface-variant hover:text-on-surface transition-colors shrink-0">
                    <span class="material-symbols-outlined text-[16px]">close</span>
                </button>
            `;

            container.appendChild(toast);

            // Animate in
            setTimeout(() => {
                toast.classList.remove("translate-y-12", "md:translate-x-12", "opacity-0");
                toast.classList.add("translate-y-0", "md:translate-x-0", "opacity-100");
            }, 50);

            // Auto remove after 3.5s
            setTimeout(() => {
                toast.classList.remove("translate-y-0", "md:translate-x-0", "opacity-100");
                toast.classList.add("translate-y-12", "md:translate-x-12", "opacity-0");
                setTimeout(() => toast.remove(), 300);
            }, 3500);
        }

        function updateBodyScroll() {
            const activeModals = Array.from(document.querySelectorAll('.modal-backdrop')).filter(m => !m.classList.contains('modal-hidden'));
            if (activeModals.length > 0) {
                document.body.style.overflow = "hidden";
            } else {
                document.body.style.overflow = "";
            }
        }

        window.showModal = function(el) {
            if (!el) return;
            el.classList.remove("modal-hidden");
            updateBodyScroll();
        };

        window.hideModal = function(el) {
            if (!el) return;
            el.classList.add("modal-hidden");
            updateBodyScroll();
        };

        window.openApiSupportModal = function() {
            const modal = document.getElementById("modalSoporteApi");
            if (modal) showModal(modal);
        };

        window.closeApiSupportModal = function() {
            const modal = document.getElementById("modalSoporteApi");
            if (modal) hideModal(modal);
        };
    </script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                showToast("@TempData["SuccessMessage"]", "success");
            });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                showToast("@TempData["ErrorMessage"]", "error");
            });
        </script>
    }
    <script>
        const btnOpenMenu = document.getElementById('btnOpenMobileMenu');
        const btnCloseMenu = document.getElementById('btnCloseMobileMenu');
        const mobileMenu = document.getElementById('mobileMenu');

        if(btnOpenMenu && btnCloseMenu && mobileMenu) {
            btnOpenMenu.addEventListener('click', () => {
                mobileMenu.classList.remove('translate-x-full');
            });
            btnCloseMenu.addEventListener('click', () => {
                mobileMenu.classList.add('translate-x-full');
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('ServiceWorker registered'))
                    .catch(err => console.log('ServiceWorker registration failed', err));
            });
        }
    </script>
    <script src="~/js/db.js"></script>
    <script src="~/js/offline-sync.js"></script>
</body>
</html>
